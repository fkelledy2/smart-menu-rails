<div class="container-fluid px-4 py-5">
  <div class="row">
    <div class="col-12 col-lg-8 col-xl-6">

      <div class="mb-4">
        <h1 class="pb-2 border-bottom"><%= t('two_factor.backup_codes.title') %></h1>
        <p class="text-muted"><%= t('two_factor.backup_codes.subtitle') %></p>
      </div>

      <% if flash[:notice].present? %>
        <div class="alert alert-success"><%= flash[:notice] %></div>
      <% end %>

      <div class="card shadow-sm border-0 mb-4">
        <div class="card-body px-4 py-4">
          <div class="alert alert-warning mb-4">
            <strong><%= t('two_factor.backup_codes.save_warning_title') %></strong>
            <%= t('two_factor.backup_codes.save_warning_body') %>
          </div>

          <div class="row g-2 mb-4">
            <% @backup_codes.each do |code| %>
              <div class="col-6">
                <code class="d-block p-2 bg-light rounded text-center fw-bold letter-spacing-1">
                  <%= code %>
                </code>
              </div>
            <% end %>
          </div>

          <div class="d-flex gap-2">
            <%= link_to t('two_factor.backup_codes.done_button'),
                users_security_path,
                class: 'btn btn-primary' %>
          </div>
        </div>
      </div>

    </div>
  </div>
</div>
