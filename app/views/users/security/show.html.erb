<div class="container-fluid px-4 py-5">
  <div class="row">
    <div class="col-12 col-lg-8 col-xl-6">

      <div class="mb-4">
        <h1 class="pb-2 border-bottom"><%= t('two_factor.security.title') %></h1>
        <p class="text-muted"><%= t('two_factor.security.subtitle') %></p>
      </div>

      <%= render 'shared/flash_messages' %>

      <!-- 2FA Status Card -->
      <div class="card shadow-sm border-0 mb-4">
        <div class="card-body px-4 py-4">
          <div class="d-flex align-items-center justify-content-between mb-3">
            <h5 class="mb-0"><%= t('two_factor.security.totp_title') %></h5>
            <% if current_user.two_factor_enabled? %>
              <span class="badge bg-success"><%= t('two_factor.security.status_enabled') %></span>
            <% else %>
              <span class="badge bg-secondary"><%= t('two_factor.security.status_disabled') %></span>
            <% end %>
          </div>

          <% if current_user.two_factor_enabled? %>
            <p class="text-muted small mb-3">
              <%= t('two_factor.security.enabled_at',
                  date: l(current_user.otp_enabled_at, format: :long)) %>
            </p>
            <p class="text-muted small mb-4">
              <%= t('two_factor.security.backup_codes_remaining', count: @backup_code_count) %>
            </p>

            <!-- Disable 2FA -->
            <details class="mb-3">
              <summary class="text-danger fw-semibold" style="cursor: pointer;">
                <%= t('two_factor.security.disable_2fa') %>
              </summary>
              <div class="mt-3 p-3 border rounded bg-light">
                <%= form_with url: users_security_path, method: :delete do |f| %>
                  <div class="mb-3">
                    <label class="form-label"><%= t('two_factor.security.current_password') %></label>
                    <%= f.password_field :current_password, class: 'form-control',
                        autocomplete: 'current-password' %>
                  </div>
                  <div class="mb-3">
                    <label class="form-label"><%= t('two_factor.security.otp_code_label') %></label>
                    <%= f.text_field :otp_code, class: 'form-control',
                        autocomplete: 'one-time-code', inputmode: 'numeric', maxlength: 10,
                        placeholder: t('two_factor.security.otp_or_backup') %>
                  </div>
                  <%= f.submit t('two_factor.security.confirm_disable'),
                      class: 'btn btn-danger',
                      data: { confirm: t('two_factor.security.disable_confirm_prompt') } %>
                <% end %>
              </div>
            </details>

            <!-- Regenerate backup codes -->
            <details>
              <summary class="text-warning fw-semibold" style="cursor: pointer;">
                <%= t('two_factor.security.regenerate_backup_codes') %>
              </summary>
              <div class="mt-3 p-3 border rounded bg-light">
                <p class="text-muted small"><%= t('two_factor.security.regenerate_warning') %></p>
                <%= form_with url: regenerate_backup_codes_users_security_path, method: :post do |f| %>
                  <div class="mb-3">
                    <label class="form-label"><%= t('two_factor.security.current_password') %></label>
                    <%= f.password_field :current_password, class: 'form-control',
                        autocomplete: 'current-password' %>
                  </div>
                  <%= f.submit t('two_factor.security.confirm_regenerate'),
                      class: 'btn btn-warning' %>
                <% end %>
              </div>
            </details>

          <% else %>
            <p class="text-muted mb-4"><%= t('two_factor.security.not_enabled_description') %></p>
            <%= link_to t('two_factor.security.enable_button'),
                new_users_security_path,
                class: 'btn btn-primary' %>
          <% end %>
        </div>
      </div>

    </div>
  </div>
</div>
