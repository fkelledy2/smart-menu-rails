<div class="container px-3 py-4">
  <div class="row justify-content-center">
    <div class="col-12 col-sm-11 col-md-8 col-lg-6 col-xl-5">

      <div class="text-center mb-4">
        <h1 class="pb-2 border-bottom d-inline-block"><%= t('two_factor.otp_challenge.title') %></h1>
        <p class="text-muted mt-3"><%= t('two_factor.otp_challenge.subtitle') %></p>
      </div>

      <% if flash[:alert].present? %>
        <div class="alert alert-danger" role="alert">
          <%= flash[:alert] %>
        </div>
      <% end %>

      <% if @locked_until.present? %>
        <div class="alert alert-warning" role="alert">
          <%= t('two_factor.otp_challenge.locked_message', time: @locked_until.strftime('%H:%M')) %>
        </div>
      <% end %>

      <%= form_with url: users_otp_challenge_path, method: :post,
          data: { turbo_frame: '_top' } do |f| %>
        <div class="mb-3">
          <label for="otp_code" class="form-label fw-semibold">
            <%= t('two_factor.otp_challenge.code_label') %>
          </label>
          <%= f.text_field :otp_code,
              id: 'otp_code',
              class: 'form-control form-control-lg text-center',
              autocomplete: 'one-time-code',
              inputmode: 'numeric',
              maxlength: 10,
              autofocus: true,
              placeholder: '000000',
              data: {
                controller: 'otp-input',
                action: 'input->otp-input#autoSubmit',
              } %>
          <div class="form-text"><%= t('two_factor.otp_challenge.backup_hint') %></div>
        </div>

        <div class="form-check mb-3">
          <%= f.check_box :trust_device, id: 'trust_device', class: 'form-check-input', checked: false %>
          <label class="form-check-label" for="trust_device">
            <%= t('two_factor.otp_challenge.trust_device') %>
          </label>
        </div>

        <div class="d-grid mb-3">
          <%= f.submit t('two_factor.otp_challenge.verify_button'),
              class: 'btn btn-primary btn-lg' %>
        </div>
      <% end %>

      <div class="text-center">
        <%= link_to t('two_factor.otp_challenge.back_to_login'), new_user_session_path,
            class: 'text-decoration-none text-muted small' %>
      </div>

    </div>
  </div>
</div>
