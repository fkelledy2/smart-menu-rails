<%= form_with model: [:admin, cost], local: true do |f| %>
  <% if cost.errors.any? %>
    <div class="alert alert-danger">
      <ul class="mb-0">
        <% cost.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="row g-3">
    <div class="col-md-3">
      <%= f.label :service, class: 'form-label' %>
      <%= f.select :service, ExternalServiceMonthlyCost::SERVICES.map { |s| [s.humanize, s] },
            {}, class: 'form-select' %>
    </div>
    <div class="col-md-3">
      <%= f.label :month, class: 'form-label' %>
      <%= f.date_field :month, class: 'form-control' %>
    </div>
    <div class="col-md-2">
      <%= f.label :currency, class: 'form-label' %>
      <%= f.select :currency, ExternalServiceMonthlyCost::CURRENCIES, {}, class: 'form-select' %>
    </div>
    <div class="col-md-2">
      <%= f.label :amount_cents, 'Amount (cents)', class: 'form-label' %>
      <%= f.number_field :amount_cents, class: 'form-control', min: 0 %>
    </div>
    <div class="col-md-2">
      <%= f.label :source, class: 'form-label' %>
      <%= f.select :source, ExternalServiceMonthlyCost::SOURCES, {}, class: 'form-select' %>
    </div>
    <div class="col-12">
      <%= f.label :notes, class: 'form-label' %>
      <%= f.text_area :notes, class: 'form-control', rows: 2 %>
    </div>
  </div>

  <div class="mt-3">
    <%= f.submit class: 'btn btn-primary' %>
    <%= link_to 'Cancel', admin_vendor_costs_path, class: 'btn btn-link' %>
  </div>
<% end %>
