<%# Admin: Edit Marketing QR Code form %>
<% content_for :title, "Edit QR: #{@qr_code.name.presence || @qr_code.token}" %>

<div class="container-fluid py-4 mw-600">
  <nav aria-label="breadcrumb" class="mb-3">
    <span class="text-muted">
      <%= link_to 'Admin', admin_root_path, class: 'text-muted text-decoration-none' %> /
      <%= link_to 'QR Codes', admin_marketing_qr_codes_path, class: 'text-muted text-decoration-none' %> /
      <%= link_to @qr_code.name.presence || @qr_code.token, admin_marketing_qr_code_path(@qr_code), class: 'text-muted text-decoration-none' %> /
      Edit
    </span>
  </nav>
  <h1 class="h3 mb-1">Edit QR Code</h1>

  <div class="card">
    <div class="card-body">
      <%= render 'form', qr_code: @qr_code %>
    </div>
  </div>
</div>
