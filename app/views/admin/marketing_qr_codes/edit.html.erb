<%# Admin: Edit Marketing QR Code form %>
<% content_for :title, "Edit QR: #{@qr_code.name.presence || @qr_code.token}" %>

<div class="container-fluid py-4 mw-600">
  <%= render 'shared/admin_breadcrumb',
        crumbs: [{ label: 'Admin', url: admin_marketing_qr_codes_path },
                 { label: 'Marketing QR Codes', url: admin_marketing_qr_codes_path },
                 { label: @qr_code.name.presence || @qr_code.token, url: admin_marketing_qr_code_path(@qr_code) }],
        current: 'Edit' %>
  <div class="d-flex align-items-center gap-2 mb-4">
    <%= link_to '← Back', admin_marketing_qr_code_path(@qr_code), class: 'btn btn-sm btn-outline-secondary' %>
    <h1 class="h3 mb-1 ms-2">Edit QR Code</h1>
  </div>

  <div class="card">
    <div class="card-body">
      <%= render 'form', qr_code: @qr_code %>
    </div>
  </div>
</div>
