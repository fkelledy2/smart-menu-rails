<%# Single Kanban lead card %>
<% search_text = [
     lead.restaurant_name,
     lead.contact_name,
     lead.discovered_restaurant&.city_name,
     lead.assigned_to&.email&.split('@')&.first,
   ].compact.join(' ').downcase %>
<div class="crm-lead-card"
     data-lead-id="<%= lead.id %>"
     data-crm-kanban-target="card"
     data-search="<%= search_text %>"
     data-assigned="<%= lead.assigned_to_id.present? %>"
     id="crm-lead-card-<%= lead.id %>">
  <div class="d-flex justify-content-between align-items-start mb-1">
    <%= link_to lead.restaurant_name,
          admin_crm_lead_path(lead),
          class: 'fw-semibold text-decoration-none text-dark stretched-link fs-13',
          data: {
            turbo_frame: 'crm_lead_modal',
            action: 'click->crm-kanban#openLeadModal',
          } %>
  </div>

  <% if lead.contact_name.present? %>
    <p class="text-muted mb-1 fs-12"><%= lead.contact_name %></p>
  <% end %>

  <% dr = lead.discovered_restaurant %>
  <% if dr %>
    <div class="d-flex flex-wrap gap-1 mb-1">
      <% if dr.city_name.present? %>
        <span class="badge bg-light text-secondary border fs-10">
          <i class="bi bi-geo-alt me-1"></i><%= dr.city_name %>
        </span>
      <% end %>
      <% if dr.establishment_type_label_text.present? && dr.establishment_type_label_text != 'Unknown' %>
        <span class="badge bg-light text-secondary border fs-10"><%= dr.establishment_type_label_text %></span>
      <% end %>
    </div>
    <div class="d-flex align-items-center gap-2 mb-1" style="position: relative; z-index: 1;">
      <% if dr.website_url.present? %>
        <a href="<%= dr.website_url %>" target="_blank" rel="noopener"
           class="text-muted fs-10 text-decoration-none text-truncate" style="max-width: 140px;"
           title="<%= dr.website_url %>">
          <i class="bi bi-globe2 me-1"></i><%= dr.website_url.delete_prefix('https://').delete_prefix('http://').truncate(30) %>
        </a>
      <% end %>
      <%= link_to admin_discovered_restaurant_path(dr),
            class: 'text-muted fs-10 text-decoration-none ms-auto flex-shrink-0',
            title: 'View discovery record',
            target: '_blank' do %>
        <i class="bi bi-box-arrow-up-right me-1"></i>Discovery
      <% end %>
    </div>
  <% elsif lead.source.present? %>
    <p class="text-muted mb-1 fs-11">
      <i class="bi bi-person-lines-fill me-1"></i><%= lead.source.humanize %>
    </p>
  <% end %>

  <div class="d-flex justify-content-between align-items-center mt-2">
    <% if lead.assigned_to %>
      <span class="badge bg-light text-dark border fs-10">
        <%= lead.assigned_to.email.split('@').first %>
      </span>
    <% else %>
      <% unassigned_class = %w[new contacted].include?(lead.stage) ? 'bg-success' : 'bg-warning text-dark' %>
      <span class="badge <%= unassigned_class %> fs-10">Unassigned</span>
    <% end %>

    <span class="text-muted fs-10">
      <%= lead.last_activity_at ? time_ago_in_words(lead.last_activity_at) + ' ago' : '—' %>
    </span>
  </div>
</div>
