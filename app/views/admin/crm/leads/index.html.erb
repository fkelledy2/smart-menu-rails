<%# Admin CRM: Kanban board %>
<% content_for :title, 'CRM Sales Pipeline — Admin' %>

<div data-controller="crm-kanban"
     data-crm-kanban-transitions-value="<%= Crm::LeadTransitionService::FORWARD_TRANSITIONS.to_json %>"
     data-crm-kanban-lost-reasons-value="<%= CrmLead::LOST_REASONS.to_json %>">
  <div class="container-fluid py-4 pb-2">
    <div class="d-flex justify-content-between align-items-center">
      <div>
        <h1 class="h3 mb-1">Sales Pipeline</h1>
        <p class="text-muted mb-0">
          Drag cards between columns to update stage.
          <% if @needs_assignment_count > 0 %>
            <span class="badge bg-warning text-dark ms-2">
              <%= @needs_assignment_count %> unassigned demo-booked <%= 'lead'.pluralize(@needs_assignment_count) %>
            </span>
          <% end %>
        </p>
      </div>
      <div class="d-flex gap-2 align-items-center">
        <div class="input-group input-group-sm" style="width: 260px;">
          <span class="input-group-text bg-white border-end-0"><i class="bi bi-search text-muted"></i></span>
          <input type="search"
                 class="form-control border-start-0 ps-0"
                 placeholder="Filter by name, city or assignee…"
                 data-action="input->crm-kanban#search">
        </div>
        <%= link_to admin_crm_leads_path, class: 'btn btn-outline-secondary btn-sm', title: 'Refresh board' do %>
          <i class="bi bi-arrow-clockwise me-1"></i>Refresh
        <% end %>
        <%= link_to 'New Lead', new_admin_crm_lead_path, class: 'btn btn-primary btn-sm' %>
      </div>
    </div>
  </div>

  <div class="crm-kanban-board d-flex gap-3 pb-3 px-4" style="min-height: 70vh; overflow-x: auto; overflow-y: visible;">
    <% CrmLead::STAGES.each do |stage| %>
      <%
        is_converted = stage == 'lost'
        col_title_extra = stage == 'converted' ? ' title="Use the Convert button on a lead to move here"' : ''
      %>
      <div class="crm-kanban-column flex-shrink-0"
           style="width: 260px;"
           data-stage="<%= stage %>">
        <div class="d-flex justify-content-between align-items-center mb-2">
          <h6 class="mb-0 text-uppercase fw-semibold text-kanban-header">
            <%= stage.humanize %>
            <% if stage == 'converted' %>
              <i class="bi bi-lock-fill ms-1 text-muted" style="font-size: 0.6rem;" title="Use the Convert button on a lead"></i>
            <% end %>
          </h6>
          <span class="badge bg-secondary rounded-pill">
            <%= (@leads_by_stage[stage] || []).size %>
          </span>
        </div>

        <div class="crm-kanban-cards d-flex flex-column gap-2"
             data-stage="<%= stage %>"
             data-crm-kanban-target="cardList"
             id="crm-stage-<%= stage %>">
          <% (@leads_by_stage[stage] || []).each do |lead| %>
            <%= render 'card', lead: lead %>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>
</div>

<%# Lead detail modal — content loaded via Turbo Frame %>
<div class="modal fade" id="leadModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-xl modal-dialog-scrollable">
    <div class="modal-content">
      <div class="modal-header border-0 pb-0">
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body pt-0">
        <%= turbo_frame_tag 'crm_lead_modal' do %>
          <div class="d-flex justify-content-center py-5">
            <div class="spinner-border text-secondary" role="status">
              <span class="visually-hidden">Loading…</span>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>

<%# Lost reason modal — shown when a card is dragged to the "lost" column %>
<div class="modal fade" id="crmLostReasonModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-sm">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title"><i class="bi bi-x-circle me-2 text-danger"></i>Mark as Lost</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body" id="crmLostReasonForm">
        <div class="mb-3">
          <label class="form-label fw-semibold small">Reason <span class="text-danger">*</span></label>
          <select name="lost_reason" class="form-select form-select-sm">
            <option value="">Select reason…</option>
            <% CrmLead::LOST_REASONS.each do |reason| %>
              <option value="<%= reason %>"><%= reason.humanize %></option>
            <% end %>
          </select>
          <div class="invalid-feedback">Please select a reason.</div>
        </div>
        <div class="mb-1">
          <label class="form-label fw-semibold small">Notes <span class="text-muted fw-normal">(optional)</span></label>
          <textarea name="lost_reason_notes" class="form-control form-control-sm" rows="2" placeholder="Any additional context…"></textarea>
        </div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Cancel</button>
        <button type="button" class="btn btn-danger btn-sm" id="crmLostReasonConfirm">
          <i class="bi bi-check-lg me-1"></i>Confirm Lost
        </button>
      </div>
    </div>
  </div>
</div>
