<%# Admin CRM: Lead detail %>
<% content_for :title, "#{@lead.restaurant_name} — CRM" %>

<%= turbo_frame_tag 'crm_lead_modal' do %>
<div class="container-fluid py-4 mw-960">
  <div class="mb-3">
    <%= link_to 'Pipeline', admin_crm_leads_path, class: 'text-muted text-decoration-none' %>
    <span class="text-muted mx-1">/</span>
    <span><%= @lead.restaurant_name %></span>
  </div>

  <div class="d-flex justify-content-between align-items-start mb-4">
    <div>
      <h1 class="h3 mb-1"><%= @lead.restaurant_name %></h1>
      <span class="badge text-bg-primary"><%= @lead.stage.humanize %></span>
    </div>
    <div class="d-flex gap-2">
      <%# Link to matching demo booking if one exists for this contact's email %>
      <% if @matching_booking %>
        <%= link_to admin_demo_booking_path(@matching_booking), class: 'btn btn-outline-secondary btn-sm' do %>
          <i class="bi bi-calendar-check me-1"></i>View Demo Booking
        <% end %>
      <% end %>
      <% if @lead.discovered_restaurant %>
        <%= link_to admin_discovered_restaurant_path(@lead.discovered_restaurant), class: 'btn btn-outline-secondary btn-sm' do %>
          <i class="bi bi-box-arrow-up-right me-1"></i>Discovery Record
        <% end %>
      <% end %>
      <% if @lead.stage == 'lost' %>
        <%= button_to 'Reopen', reopen_admin_crm_lead_path(@lead),
              method: :patch, class: 'btn btn-outline-warning btn-sm',
              form: { data: { turbo_confirm: 'Reopen this lead and move it back to Contacted?' } },
              data: { turbo_frame: '_top' } %>
      <% end %>
      <% unless %w[converted lost].include?(@lead.stage) %>
        <%= link_to 'Mark Converted', convert_admin_crm_lead_path(@lead),
              class: 'btn btn-success btn-sm',
              data: { action: 'crm-lead-detail#openConvertModal' } %>
      <% end %>
    </div>
  </div>

  <div class="row g-4">
    <%# Left column — contact details %>
    <div class="col-md-4">
      <div class="card border-0 shadow-sm">
        <div class="card-body">
          <h6 class="card-title text-muted text-uppercase fw-semibold text-kanban-header">Contact</h6>
          <% if @lead.contact_name.present? %>
            <p class="mb-1"><strong><%= @lead.contact_name %></strong></p>
          <% end %>
          <% if @lead.contact_email.present? %>
            <p class="mb-1 text-muted"><%= mail_to @lead.contact_email %></p>
          <% end %>
          <% if @lead.contact_phone.present? %>
            <p class="mb-1 text-muted"><%= @lead.contact_phone %></p>
          <% end %>
          <% if @lead.city.present? %>
            <p class="mb-1 text-muted fs-12">
              <i class="bi bi-geo-alt me-1"></i><%= @lead.city %>
            </p>
          <% end %>
          <hr class="my-2">
          <p class="mb-1 text-muted fs-12 fw-semibold text-uppercase">Assigned to</p>
          <%= form_with url: admin_crm_lead_path(@lead), method: :patch, scope: :crm_lead, class: 'mb-0', data: { turbo_frame: '_top' } do |f| %>
            <div class="d-flex gap-1">
              <%= f.select :assigned_to_id,
                    [['— Unassigned —', '']] + @users.map { |u| [u.email.split('@').first, u.id] },
                    { selected: @lead.assigned_to_id.to_s, include_blank: false },
                    { class: 'form-select form-select-sm' } %>
              <%= f.submit 'Save', class: 'btn btn-primary btn-sm flex-shrink-0' %>
            </div>
          <% end %>
          <% if @lead.restaurant %>
            <hr class="my-2">
            <p class="mb-0 fs-13">
              Restaurant: <%= link_to @lead.restaurant.name, [:admin, @lead.restaurant] rescue @lead.restaurant.name %>
            </p>
          <% end %>
          <% if @lead.converted_at %>
            <hr class="my-2">
            <p class="mb-0 text-success fs-12">
              Converted: <%= @lead.converted_at.strftime('%d %b %Y') %>
            </p>
          <% end %>
          <% if @lead.stage_lost? %>
            <hr class="my-2">
            <p class="mb-0 text-danger fs-12">
              Lost: <%= @lead.lost_reason&.humanize %><br>
              <% if @lead.lost_reason_notes.present? %>
                <span class="text-muted"><%= @lead.lost_reason_notes %></span>
              <% end %>
            </p>
          <% end %>
        </div>
      </div>

      <%# Stage transition panel %>
      <div class="card border-0 shadow-sm mt-3">
        <div class="card-body">
          <h6 class="card-title text-muted text-uppercase fw-semibold text-kanban-header">Move Stage</h6>
          <% allowed = Crm::LeadTransitionService::FORWARD_TRANSITIONS[@lead.stage] || [] %>
          <% if allowed.any? %>
            <div class="d-flex flex-column gap-1">
              <% allowed.each do |target_stage| %>
                <% already_here = target_stage == @lead.stage %>
                <% needs_assignee = target_stage == 'demo_completed' && @lead.assigned_to_id.blank? %>
                <% btn_disabled = already_here || needs_assignee %>
                <% if target_stage == 'lost' %>
                  <button type="button"
                          class="btn btn-danger btn-sm w-100 text-start"
                          data-action="click->crm-kanban#openLostModalForLead"
                          data-lead-id="<%= @lead.id %>"
                          <%= 'disabled' if btn_disabled %>>
                    Lost
                  </button>
                <% else %>
                  <%= button_to target_stage.humanize,
                        transition_admin_crm_lead_path(@lead),
                        params: { stage: target_stage },
                        method: :patch,
                        class: "btn btn-primary btn-sm w-100 text-start #{'disabled' if btn_disabled}",
                        disabled: btn_disabled,
                        title: needs_assignee ? 'Assign this lead before marking the demo as completed' : nil,
                        data: { turbo_frame: '_top' } %>
                <% end %>
              <% end %>
            </div>
          <% else %>
            <p class="text-muted mb-0 fs-12">No further transitions available.</p>
          <% end %>
        </div>
      </div>
    </div>

    <%# Right column — tabs %>
    <div class="col-md-8" data-controller="crm-lead-detail">
      <ul class="nav nav-tabs mb-3" id="leadDetailTabs" role="tablist">
        <li class="nav-item" role="presentation">
          <button class="nav-link active" id="notes-tab" data-bs-toggle="tab" data-bs-target="#notes" type="button" role="tab" aria-controls="notes" aria-selected="true">
            Notes
            <span class="badge text-bg-secondary ms-1"><%= @lead.crm_lead_notes.size %></span>
          </button>
        </li>
        <li class="nav-item" role="presentation">
          <button class="nav-link" id="activity-tab" data-bs-toggle="tab" data-bs-target="#activity" type="button" role="tab" aria-controls="activity" aria-selected="false">Activity</button>
        </li>
        <li class="nav-item" role="presentation">
          <button class="nav-link" id="emails-tab" data-bs-toggle="tab" data-bs-target="#emails" type="button" role="tab" aria-controls="emails" aria-selected="false">Emails</button>
        </li>
      </ul>

      <div class="tab-content" id="leadDetailTabContent">
        <%# Notes tab %>
        <div class="tab-pane fade show active" id="notes" role="tabpanel" aria-labelledby="notes-tab">
          <%= turbo_frame_tag 'crm_notes' do %>
            <%= form_with model: CrmLeadNote.new,
                  url: admin_crm_lead_notes_path(@lead),
                  data: { turbo_frame: 'crm_notes' },
                  class: 'mb-3' do |f| %>
              <div class="mb-2">
                <%= f.text_area :body,
                      class: 'form-control',
                      placeholder: 'Add a note...',
                      rows: 3 %>
              </div>
              <%= f.submit 'Add Note', class: 'btn btn-primary btn-sm' %>
            <% end %>

            <div id="crm-notes-list">
              <% @notes.each do |note| %>
                <%= render 'admin/crm/notes/note', note: note, lead: @lead %>
              <% end %>
              <% if @notes.empty? %>
                <p class="text-muted">No notes yet.</p>
              <% end %>
            </div>
          <% end %>
        </div>

        <%# Activity tab %>
        <div class="tab-pane fade" id="activity" role="tabpanel" aria-labelledby="activity-tab">
          <%= turbo_frame_tag 'crm_activity' do %>
            <% if @audits.any? %>
              <div class="list-group list-group-flush">
                <% @audits.each do |audit| %>
                  <div class="list-group-item px-0 py-2 border-0 border-bottom">
                    <div class="d-flex justify-content-between">
                      <span class="fs-13">
                        <strong><%= audit.actor&.email || 'System' %></strong>
                        <%= audit.event.humanize.downcase %>
                        <% if audit.field_name.present? %>
                          <em><%= audit.field_name %></em>
                          from <code><%= audit.from_value || '—' %></code>
                          to <code><%= audit.to_value || '—' %></code>
                        <% end %>
                      </span>
                      <span class="text-muted fs-11 text-nowrap">
                        <%= time_ago_in_words(audit.created_at) %> ago
                      </span>
                    </div>
                  </div>
                <% end %>
              </div>
              <%= link_to 'View full activity log', admin_crm_lead_audits_path(@lead), class: 'btn btn-link btn-sm mt-2' %>
            <% else %>
              <p class="text-muted">No activity recorded yet.</p>
            <% end %>
          <% end %>
        </div>

        <%# Emails tab %>
        <div class="tab-pane fade" id="emails" role="tabpanel" aria-labelledby="emails-tab">
          <%= link_to 'Compose Email',
                new_admin_crm_lead_email_send_path(@lead),
                class: 'btn btn-outline-primary btn-sm mb-3' %>
          <% if @email_sends.any? %>
            <div class="list-group list-group-flush">
              <% @email_sends.each do |send| %>
                <div class="list-group-item px-0 py-2 border-0 border-bottom">
                  <div class="d-flex justify-content-between align-items-start">
                    <div>
                      <strong class="fs-13"><%= send.subject %></strong>
                      <p class="text-muted mb-0 fs-12">
                        To: <%= send.to_email %> &bull; From: <%= send.sender.email %>
                      </p>
                    </div>
                    <span class="text-muted fs-11 text-nowrap">
                      <%= send.sent_at ? send.sent_at.strftime('%d %b %Y') : 'Pending' %>
                    </span>
                  </div>
                </div>
              <% end %>
            </div>
          <% else %>
            <p class="text-muted">No emails sent yet.</p>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div><%# /container-fluid %>
<% end %><%# /turbo_frame crm_lead_modal %>

<%# Convert modal %>
<div class="modal fade" id="convertModal" tabindex="-1" aria-labelledby="convertModalLabel" aria-hidden="true">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title" id="convertModalLabel">Mark as Converted</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <%= form_with url: convert_admin_crm_lead_path(@lead), method: :patch do |f| %>
        <div class="modal-body">
          <p>Link this lead to a Restaurant record to complete the conversion.</p>
          <div class="mb-3">
            <%= f.label :restaurant_id, 'Restaurant', class: 'form-label' %>
            <%= f.select :restaurant_id,
                  @restaurants.map { |r| [r.name, r.id] },
                  { prompt: 'Select restaurant...' },
                  class: 'form-select' %>
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
          <%= f.submit 'Convert Lead', class: 'btn btn-success' %>
        </div>
      <% end %>
    </div>
  </div>
</div>
