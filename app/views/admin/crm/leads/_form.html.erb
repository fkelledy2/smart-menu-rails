<%# Shared lead form — used by new and edit.
    Explicit URL avoids model-inferred double-namespace (CrmLead → admin_crm_crm_lead). %>
<%= form_with model: lead,
      url: lead.new_record? ? admin_crm_leads_path : admin_crm_lead_path(lead),
      method: lead.new_record? ? :post : :patch do |f| %>
  <% if lead.errors.any? %>
    <div class="alert alert-danger">
      <ul class="mb-0">
        <% lead.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="mb-3">
    <%= f.label :restaurant_name, 'Restaurant Name', class: 'form-label fw-semibold' %>
    <%= f.text_field :restaurant_name, class: 'form-control', placeholder: 'e.g. The Blue Duck' %>
  </div>

  <div class="mb-3">
    <%= f.label :contact_name, 'Contact Name', class: 'form-label fw-semibold' %>
    <%= f.text_field :contact_name, class: 'form-control' %>
  </div>

  <div class="mb-3">
    <%= f.label :contact_email, 'Contact Email', class: 'form-label fw-semibold' %>
    <%= f.email_field :contact_email, class: 'form-control' %>
  </div>

  <div class="mb-3">
    <%= f.label :contact_phone, 'Contact Phone', class: 'form-label fw-semibold' %>
    <%= f.telephone_field :contact_phone, class: 'form-control' %>
  </div>

  <div class="mb-3">
    <%= f.label :source, 'Source', class: 'form-label fw-semibold' %>
    <%= f.select :source,
          [['Manual', 'manual'], ['Calendly', 'calendly'], ['Referral', 'referral'], ['Website', 'website']],
          { prompt: 'Select source...' },
          class: 'form-select' %>
  </div>

  <div class="mb-4">
    <%= f.label :assigned_to_id, 'Assign To', class: 'form-label fw-semibold' %>
    <%= f.select :assigned_to_id,
          @users.map { |u| [u.email, u.id] },
          { prompt: 'Unassigned' },
          class: 'form-select' %>
  </div>

  <div class="d-flex gap-2">
    <%= f.submit lead.new_record? ? 'Create Lead' : 'Update Lead', class: 'btn btn-primary' %>
    <%= link_to 'Cancel',
          lead.new_record? ? admin_crm_leads_path : admin_crm_lead_path(lead),
          class: 'btn btn-outline-secondary' %>
  </div>
<% end %>
