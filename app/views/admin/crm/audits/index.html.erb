<%# Admin CRM: Full activity log %>
<% content_for :title, "Activity Log — #{@lead.restaurant_name}" %>

<div class="container-fluid py-4 mw-800">
  <div class="mb-3">
    <%= link_to 'Pipeline', admin_crm_leads_path, class: 'text-muted text-decoration-none' %>
    <span class="text-muted mx-1">/</span>
    <%= link_to @lead.restaurant_name, admin_crm_lead_path(@lead), class: 'text-muted text-decoration-none' %>
    <span class="text-muted mx-1">/</span>
    <span>Activity Log</span>
  </div>

  <h2 class="h3 mb-4">Activity Log</h2>

  <% if @audits.any? %>
    <div class="list-group list-group-flush">
      <% @audits.each do |audit| %>
        <div class="list-group-item px-0 py-3 border-0 border-bottom">
          <div class="d-flex justify-content-between align-items-start">
            <div>
              <strong><%= audit.actor&.email || 'System' %></strong>
              <span class="text-muted"><%= audit.event.humanize.downcase %></span>
              <% if audit.field_name.present? %>
                <span class="text-muted">
                  field <code><%= audit.field_name %></code>
                  from <code><%= audit.from_value.presence || '—' %></code>
                  to <code><%= audit.to_value.presence || '—' %></code>
                </span>
              <% end %>
              <% if audit.metadata.present? && audit.metadata.any? %>
                <div class="mt-1">
                  <% audit.metadata.each do |key, val| %>
                    <span class="badge bg-light text-dark border me-1 fs-10"><%= key %>: <%= val %></span>
                  <% end %>
                </div>
              <% end %>
            </div>
            <span class="text-muted ms-3 fs-12 text-nowrap">
              <%= audit.created_at.strftime('%d %b %Y %H:%M') %>
            </span>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <p class="text-muted">No activity recorded for this lead.</p>
  <% end %>
</div>
