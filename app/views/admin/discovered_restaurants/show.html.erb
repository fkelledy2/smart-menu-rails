<%# Admin: Discovered Restaurant detail & enrichment view %>
<% content_for :title, "#{@discovered_restaurant.name} — Discovery Queue — Admin" %>

<% place_details = @discovered_restaurant.place_details %>
<% deep_dive = @discovered_restaurant.metadata.is_a?(Hash) ? (@discovered_restaurant.metadata['website_deep_dive'] || {}) : {} %>
<% web_scrape = @discovered_restaurant.metadata.is_a?(Hash) ? (@discovered_restaurant.metadata['web_menu_scrape'] || {}) : {} %>
<% phone_candidates = begin
  c = Array(deep_dive['phones']).reject(&:blank?)
  gp = place_details['international_phone_number'].to_s.strip
  c << gp if gp.present?
  c.map { |p| p.to_s.strip }.reject(&:blank?).uniq
rescue StandardError; [] end %>
<% email_candidates = begin
  Array(deep_dive['emails']).reject(&:blank?).map { |e| e.to_s.strip.downcase }.reject(&:blank?).uniq
rescue StandardError; [] end %>
<% social_links = begin
  Array(deep_dive['social_links']).reject(&:blank?).uniq
rescue StandardError; [] end %>
<% establishment_type_options = {
  'Restaurant' => 'restaurant',
  'Bar' => 'bar',
  'Wine bar' => 'wine_bar',
  'Whiskey bar' => 'whiskey_bar',
} %>
<% field_sources = (@discovered_restaurant.metadata.is_a?(Hash) && @discovered_restaurant.metadata['field_sources'].is_a?(Hash)) ? @discovered_restaurant.metadata['field_sources'] : {} %>
<% source_badge = ->(field_name) {
  info = field_sources[field_name.to_s]
  return ''.html_safe unless info.is_a?(Hash) && info['source'].present?
  src = info['source'].to_s
  ts  = info['updated_at']
  label, cls = case src
    when 'ai_generated'          then ['AI', 'text-info']
    when 'google_places'         then ['Google', 'text-primary']
    when 'google_places_address_resolve' then ['Google (addr)', 'text-primary']
    when /google_places\+/       then ['Google + Web', 'text-primary']
    when 'website'               then ['Website', 'text-warning']
    when 'inferred'              then ['Inferred', 'text-secondary']
    when 'manual'                then ['Manual', 'text-success']
    else [src.humanize, 'text-secondary']
  end
  date_str = ts.present? ? (begin; Time.parse(ts).strftime('%b %d'); rescue; ts; end) : nil
  txt = date_str ? "#{label} · #{date_str}" : label
  %Q(<span class="#{cls}" style="font-size:0.7rem;margin-left:4px">#{ERB::Util.html_escape(txt)}</span>).html_safe
} %>
<% enrichment_active = [deep_dive['status'], web_scrape['status']].any? { |s| %w[queued scraping processing].include?(s) } %>

<%= render 'shared/admin_breadcrumb',
      crumbs: [{ label: 'Admin', url: admin_discovered_restaurants_path },
               { label: 'Discovery Queue', url: admin_discovered_restaurants_path }],
      current: @discovered_restaurant.name %>
<div class="container-fluid py-4"
     data-controller="discovered-restaurant-deep-dive discovered-restaurant-web-scrape"
     data-discovered-restaurant-deep-dive-status-url-value="<%= deep_dive_status_admin_discovered_restaurant_path(@discovered_restaurant) %>"
     data-discovered-restaurant-deep-dive-initial-status-value="<%= deep_dive['status'].to_s %>"
     data-discovered-restaurant-web-scrape-status-url-value="<%= web_menu_scrape_status_admin_discovered_restaurant_path(@discovered_restaurant) %>"
     data-discovered-restaurant-web-scrape-initial-status-value="<%= web_scrape['status'].to_s %>">

  <%# ── HEADER ── %>
  <nav aria-label="breadcrumb" class="mb-3">
    <span class="text-muted">
      <%= link_to 'Admin', admin_root_path, class: 'text-muted text-decoration-none' %> /
      <%= link_to 'Discovery Queue', admin_discovered_restaurants_path, class: 'text-muted text-decoration-none' %> /
      <%= @discovered_restaurant.name %>
    </span>
  </nav>
  <div class="d-flex align-items-center justify-content-between mb-3">
    <div class="d-flex align-items-center gap-2 flex-wrap">
      <h1 class="h3 mb-1"><%= @discovered_restaurant.name %></h1>
      <%= render 'shared/status_badge', status: @discovered_restaurant.status %>
      <span class="text-muted small">
        <i class="bi bi-calendar3 me-1" aria-hidden="true"></i>
        <%= (@discovered_restaurant.discovered_at || @discovered_restaurant.created_at).strftime('%Y-%m-%d') %>
      </span>
    </div>
    <div class="d-flex align-items-center gap-2">
      <% if enrichment_active %>
        <%= button_to kill_enrichment_admin_discovered_restaurant_path(@discovered_restaurant),
              method: :post,
              class: 'btn btn-sm btn-outline-danger',
              title: 'Stop all running enrichment processes',
              data: { turbo_confirm: 'Kill all running enrichment jobs?' } do %>
          <i class="bi bi-x-octagon me-1"></i>Kill Enrichment
        <% end %>
      <% end %>
    </div>
  </div>

  <%# ── PROVISIONING BAR (approved restaurants only) ── %>
  <% if @discovered_restaurant.approved? && @discovered_restaurant.restaurant %>
    <% restaurant = @discovered_restaurant.restaurant %>
    <% last_synced = @discovered_restaurant.metadata.is_a?(Hash) && @discovered_restaurant.metadata['last_synced_at'] %>
    <div class="alert alert-success d-flex align-items-center justify-content-between flex-wrap gap-2 py-2 mb-3"
         data-testid="provisioning-bar">
      <div class="d-flex align-items-center gap-2 flex-wrap">
        <i class="bi bi-lightning-charge-fill"></i>
        <span>Provisioned:</span>
        <%= link_to restaurant.name.presence || "##{restaurant.id}",
            edit_restaurant_path(restaurant, section: 'details'),
            target: '_blank',
            rel: 'noopener',
            class: 'fw-semibold' %>
        <% if restaurant.preview_published? %>
          <span class="badge bg-success bg-opacity-75 ms-1">
            <i class="bi bi-check-lg me-1"></i>Published
          </span>
        <% end %>
        <% if last_synced.present? %>
          <span class="text-muted small">
            Last synced: <%= Time.parse(last_synced).strftime('%b %d %H:%M') rescue last_synced %>
          </span>
        <% end %>
      </div>
      <%= link_to resync_to_restaurant_admin_discovered_restaurant_path(@discovered_restaurant),
            class: 'btn btn-sm btn-success',
            data: { turbo: true, turbo_method: :post } do %>
        <i class="bi bi-arrow-clockwise me-1"></i>Sync
      <% end %>
    </div>
  <% end %>

  <%# ── DETAIL FORM ── %>
  <div class="card mb-3" data-testid="discovered-restaurant-form">
    <div class="card-body">

      <%# Sources row %>
      <div class="d-flex align-items-center gap-3 flex-wrap small text-muted mb-4 pb-3 border-bottom">
        <% place_fetched_at = place_details['fetched_at'] %>
        <span>
          <%= link_to refresh_place_details_admin_discovered_restaurant_path(@discovered_restaurant),
                class: 'text-decoration-none',
                title: @discovered_restaurant.google_place_id,
                data: { turbo: true, turbo_method: :post } do %>
            <i class="bi bi-geo-alt me-1"></i>Google Place
            <i class="bi bi-arrow-clockwise ms-1"></i>
          <% end %>
          <% if place_fetched_at.present? %>
            <span class="text-muted ms-1">
              (last: <%= Time.parse(place_fetched_at).strftime('%b %d %H:%M') rescue place_fetched_at %>)
            </span>
          <% end %>
        </span>

        <% if sanitize_url(@discovered_restaurant.website_url).present? %>
          <span class="d-flex align-items-center gap-1">
            <i class="bi bi-globe"></i>
            <%= link_to 'Website', sanitize_url(@discovered_restaurant.website_url),
                target: '_blank', rel: 'noopener', class: 'text-decoration-none' %>
            <%= link_to deep_dive_website_admin_discovered_restaurant_path(@discovered_restaurant),
                  class: 'text-decoration-none ms-1',
                  title: 'Enrich from website',
                  data: { turbo: true, turbo_method: :post } do %>
              <i class="bi bi-arrow-clockwise"></i>
            <% end %>
            <% if %w[queued scraping processing].include?(deep_dive['status']) %>
              <span class="spinner-border spinner-border-sm" role="status" aria-label="Processing"></span>
            <% elsif deep_dive['extracted_at'].present? %>
              <span class="text-muted">
                (last: <%= Time.parse(deep_dive['extracted_at']).strftime('%b %d %H:%M') rescue deep_dive['extracted_at'] %>)
              </span>
            <% end %>
            <%= link_to scrape_web_menus_admin_discovered_restaurant_path(@discovered_restaurant),
                  class: 'text-decoration-none ms-1',
                  title: 'Scrape web menus',
                  data: { turbo: true, turbo_method: :post } do %>
              <i class="bi bi-file-earmark-text"></i>
            <% end %>
            <% if %w[queued scraping processing].include?(web_scrape['status']) %>
              <span class="spinner-border spinner-border-sm" role="status" aria-label="Scraping"></span>
            <% end %>
          </span>
        <% end %>

        <% if social_links.any? %>
          <span class="d-flex gap-1">
            <% social_links.each do |url| %>
              <% icon = case url
                   when /instagram/ then 'bi-instagram'
                   when /facebook/  then 'bi-facebook'
                   when /twitter|x\.com/ then 'bi-twitter-x'
                   when /tripadvisor/ then 'bi-star'
                   when /linkedin/ then 'bi-linkedin'
                   else 'bi-link-45deg'
                 end %>
              <%= link_to url, target: '_blank', rel: 'noopener', class: 'text-decoration-none' do %>
                <i class="bi <%= icon %>"></i>
              <% end %>
            <% end %>
          </span>
        <% end %>
      </div>

      <%= form_with model: @discovered_restaurant,
            url: admin_discovered_restaurant_path(@discovered_restaurant),
            method: :patch, local: true, data: { turbo: false } do |f| %>

        <%# Identity & Vibe %>
        <h2 class="h6 fw-semibold mb-3">Identity & Vibe</h2>
        <div class="row g-3 mb-4">
          <div class="col-md-6">
            <label class="form-label small text-muted mb-1">Name<%= source_badge.call(:name) %></label>
            <div class="form-control bg-light text-muted" aria-readonly="true"><%= @discovered_restaurant.name %></div>
          </div>
          <div class="col-md-6">
            <label class="form-label small text-muted mb-1">Type<%= source_badge.call(:establishment_types) %></label>
            <%= f.select :establishment_types,
                  options_for_select(establishment_type_options.to_a, Array(@discovered_restaurant.establishment_types)),
                  {}, { multiple: true, class: 'form-select', **select_data_attributes(:multi) } %>
          </div>
          <div class="col-12">
            <label class="form-label small text-muted mb-1">Description<%= source_badge.call(:description) %></label>
            <%= f.text_area :description, class: 'form-control', rows: 3,
                  placeholder: 'Restaurant description — enriched automatically from the website About page' %>
          </div>
          <div class="col-md-6">
            <label class="form-label small text-muted mb-1">Image Context<%= source_badge.call(:image_context) %></label>
            <%= f.text_field :image_context, class: 'form-control',
                  placeholder: 'Visual setting — AI generated from website context' %>
          </div>
          <div class="col-md-6">
            <label class="form-label small text-muted mb-1">Image Style Profile<%= source_badge.call(:image_style_profile) %></label>
            <%= f.text_area :image_style_profile, class: 'form-control', rows: 2,
                  placeholder: 'Visual direction for AI image generation — AI generated' %>
          </div>
        </div>

        <%# Practical Details %>
        <h2 class="h6 fw-semibold mb-3">Practical Details</h2>
        <div class="row g-3 mb-4">
          <div class="col-md-6">
            <label class="form-label small text-muted mb-1">Phone<%= source_badge.call(:preferred_phone) %></label>
            <% if phone_candidates.any? %>
              <%= f.select :preferred_phone,
                    options_for_select(phone_candidates, @discovered_restaurant.preferred_phone),
                    { include_blank: 'Select…' }, { class: 'form-select' } %>
            <% else %>
              <%= f.text_field :preferred_phone, class: 'form-control', placeholder: 'No candidates yet' %>
            <% end %>
          </div>
          <div class="col-md-6">
            <label class="form-label small text-muted mb-1">Email<%= source_badge.call(:preferred_email) %></label>
            <% if email_candidates.any? %>
              <%= f.select :preferred_email,
                    options_for_select(email_candidates, @discovered_restaurant.preferred_email),
                    { include_blank: 'Select…' }, { class: 'form-select' } %>
            <% else %>
              <%= f.email_field :preferred_email, class: 'form-control', placeholder: 'No candidates yet' %>
            <% end %>
          </div>
          <div class="col-md-6">
            <label class="form-label small text-muted mb-1">Address<%= source_badge.call(:address1) %></label>
            <%= f.text_field :address1, class: 'form-control',
                  placeholder: @discovered_restaurant.inferred_address1.presence || place_details['formatted_address'].to_s.truncate(60) %>
          </div>
          <div class="col-md-6">
            <label class="form-label small text-muted mb-1">City<%= source_badge.call(:city) %></label>
            <%= f.text_field :city, class: 'form-control',
                  placeholder: @discovered_restaurant.inferred_city.presence || @discovered_restaurant.city_name %>
          </div>
          <div class="col-md-3">
            <label class="form-label small text-muted mb-1">State<%= source_badge.call(:state) %></label>
            <%= f.text_field :state, class: 'form-control', placeholder: @discovered_restaurant.inferred_state %>
          </div>
          <div class="col-md-3">
            <label class="form-label small text-muted mb-1">Postcode<%= source_badge.call(:postcode) %></label>
            <%= f.text_field :postcode, class: 'form-control', placeholder: @discovered_restaurant.inferred_postcode %>
          </div>
          <div class="col-md-3">
            <label class="form-label small text-muted mb-1">Country<%= source_badge.call(:country_code) %></label>
            <%= f.text_field :country_code, class: 'form-control', maxlength: 2,
                  placeholder: @discovered_restaurant.inferred_country_code.presence || 'US' %>
          </div>
          <div class="col-md-3">
            <label class="form-label small text-muted mb-1">Currency<%= source_badge.call(:currency) %></label>
            <%= currency_select(f, :currency, %w[USD EUR GBP CAD AUD],
                  { include_blank: '— Select currency —' },
                  { class: 'form-select' }) %>
          </div>
        </div>

        <div class="d-flex align-items-center justify-content-between">
          <%= f.submit 'Save changes', class: 'btn btn-primary' %>
          <div class="d-flex gap-2">
            <%= button_to 'Approve',
                  approve_admin_discovered_restaurant_path(@discovered_restaurant),
                  method: :patch,
                  class: "btn btn-success #{'active' if @discovered_restaurant.approved?}",
                  data: { turbo_confirm: 'Approve this restaurant?' } %>
            <%= button_to 'Reject',
                  reject_admin_discovered_restaurant_path(@discovered_restaurant),
                  method: :patch,
                  class: "btn btn-outline-danger #{'active' if @discovered_restaurant.rejected?}",
                  data: { turbo_confirm: 'Reject this restaurant?' } %>
          </div>
        </div>
      <% end %>
    </div>
  </div>

  <%# ── WEB MENU SCRAPE STATUS ── %>
  <% if web_scrape.present? && web_scrape['status'].present? %>
    <%
      scrape_badge_class = case web_scrape['status']
        when 'queued', 'scraping', 'processing' then 'bg-warning text-dark'
        when 'completed' then 'bg-success'
        when 'failed' then 'bg-danger'
        when 'killed' then 'bg-secondary'
        else 'bg-secondary'
      end
    %>
    <div class="card mb-3" data-testid="discovered-restaurant-web-scrape">
      <div class="card-body">
        <h2 class="h6 fw-semibold mb-3">
          <i class="bi bi-file-earmark-text me-1"></i>Web Menu Scrape
          <span class="badge <%= scrape_badge_class %> ms-1"><%= web_scrape['status'].humanize %></span>
          <% if %w[queued scraping processing].include?(web_scrape['status']) %>
            <span class="spinner-border spinner-border-sm ms-1" role="status" aria-label="Running"></span>
          <% end %>
        </h2>
        <div class="small">
          <% if web_scrape['message'].present? %>
            <p class="mb-1"><%= web_scrape['message'] %></p>
          <% end %>
          <% if web_scrape['error'].present? %>
            <p class="mb-1 text-danger"><i class="bi bi-exclamation-circle me-1"></i><%= web_scrape['error'] %></p>
          <% end %>
          <div class="d-flex flex-wrap gap-3 text-muted">
            <% if web_scrape['html_pages_found'].present? %>
              <span>HTML pages: <strong class="text-body"><%= web_scrape['html_pages_found'] %></strong></span>
            <% end %>
            <% if web_scrape['pdf_urls_found'].present? %>
              <span>PDF URLs: <strong class="text-body"><%= web_scrape['pdf_urls_found'] %></strong></span>
            <% end %>
            <% if web_scrape['sections_count'].present? %>
              <span>Sections: <strong class="text-body"><%= web_scrape['sections_count'] %></strong></span>
            <% end %>
            <% if web_scrape['items_count'].present? %>
              <span>Items: <strong class="text-body"><%= web_scrape['items_count'] %></strong></span>
            <% end %>
          </div>
          <% if web_scrape['ocr_menu_import_id'].present? && @discovered_restaurant.restaurant.present? %>
            <div class="mt-2">
              <%= link_to "View import ##{web_scrape['ocr_menu_import_id']}",
                    restaurant_ocr_menu_import_path(@discovered_restaurant.restaurant, web_scrape['ocr_menu_import_id']),
                    class: 'text-decoration-none small' %>
            </div>
          <% end %>
          <% if web_scrape['updated_at'].present? %>
            <div class="mt-1 text-muted">
              Updated: <%= Time.parse(web_scrape['updated_at']).strftime('%b %d %H:%M') rescue web_scrape['updated_at'] %>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  <% end %>

  <%# ── MENU SOURCES ── %>
  <% menu_sources = @discovered_restaurant.menu_sources.order(:name, :id).to_a %>
  <% if menu_sources.any? %>
    <div class="card mb-3" data-testid="discovered-restaurant-menu-sources">
      <div class="card-body">
        <h2 class="h6 fw-semibold mb-3">Menu Sources</h2>
        <div class="table-responsive">
          <table class="table table-sm align-middle mb-0">
            <thead>
              <tr>
                <th>Name</th>
                <th>Type</th>
                <th>Source</th>
              </tr>
            </thead>
            <tbody>
              <% menu_sources.each do |ms| %>
                <tr>
                  <td>
                    <%= form_with url: admin_discovered_restaurant_menu_source_path(@discovered_restaurant, ms),
                          method: :patch, local: true, class: 'd-flex align-items-center gap-1' do |f| %>
                      <%= f.text_field :name, value: ms.display_name,
                            name: 'menu_source[name]',
                            class: 'form-control form-control-sm',
                            style: 'min-width: 0;' %>
                      <button type="submit" class="btn btn-sm btn-outline-secondary" title="Save name">
                        <i class="bi bi-floppy"></i>
                      </button>
                    <% end %>
                  </td>
                  <td>
                    <% if ms.pdf? %>
                      <span class="badge bg-danger-subtle text-danger">PDF</span>
                    <% else %>
                      <span class="badge bg-info-subtle text-info">HTML</span>
                    <% end %>
                  </td>
                  <td class="small">
                    <% if ms.latest_file.attached? %>
                      <%= link_to ms.latest_file.filename.to_s,
                          rails_blob_path(ms.latest_file, disposition: 'attachment'),
                          class: 'text-decoration-none' %>
                    <% elsif ms.source_url.present? %>
                      <%= link_to truncate(ms.source_url, length: 60),
                          sanitize_url(ms.source_url),
                          target: '_blank',
                          rel: 'noopener',
                          class: 'text-muted text-decoration-none',
                          title: ms.source_url %>
                    <% else %>
                      <span class="text-muted">—</span>
                    <% end %>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  <% end %>

</div>
