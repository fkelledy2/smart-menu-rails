<%= form_with model: snapshot,
              url: snapshot.persisted? ? admin_staff_cost_path(snapshot) : admin_staff_costs_path,
              method: snapshot.persisted? ? :patch : :post,
              local: true do |f| %>
  <% if snapshot.errors.any? %>
    <div class="alert alert-danger">
      <ul class="mb-0">
        <% snapshot.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="row g-3">
    <div class="col-md-3">
      <%= f.label :month, class: 'form-label' %>
      <%= f.date_field :month, class: 'form-control' %>
    </div>
    <div class="col-md-2">
      <%= f.label :currency, class: 'form-label' %>
      <%= f.select :currency, StaffCostSnapshot::CURRENCIES, {}, class: 'form-select' %>
    </div>
    <div class="col-md-2">
      <%= f.label :support_cost_cents, 'Support (cents)', class: 'form-label' %>
      <%= f.number_field :support_cost_cents, class: 'form-control', min: 0 %>
    </div>
    <div class="col-md-2">
      <%= f.label :staff_cost_cents, 'Staff (cents)', class: 'form-label' %>
      <%= f.number_field :staff_cost_cents, class: 'form-control', min: 0 %>
    </div>
    <div class="col-md-2">
      <%= f.label :other_ops_cost_cents, 'Other Ops (cents)', class: 'form-label' %>
      <%= f.number_field :other_ops_cost_cents, class: 'form-control', min: 0 %>
    </div>
    <div class="col-12">
      <%= f.label :notes, class: 'form-label' %>
      <%= f.text_area :notes, class: 'form-control', rows: 2 %>
    </div>
  </div>

  <div class="mt-3">
    <%= f.submit class: 'btn btn-primary' %>
    <%= link_to 'Cancel', admin_staff_costs_path, class: 'btn btn-link' %>
  </div>
<% end %>
