<div class="container-fluid py-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3 mb-1">Staff &amp; Support Costs</h1>
    <%= link_to 'Add Month', new_admin_staff_cost_path, class: 'btn btn-primary btn-sm' %>
  </div>
  <div class="card">
    <div class="table-responsive">
      <table class="table table-sm table-hover mb-0">
        <thead class="table-light">
          <tr><th>Month</th><th>Currency</th><th>Support</th><th>Staff</th><th>Other</th><th>Total</th><th></th></tr>
        </thead>
        <tbody>
          <% @snapshots.each do |s| %>
            <tr>
              <td><%= s.month&.strftime('%B %Y') %></td>
              <td><%= s.currency %></td>
              <td>&euro;<%= number_with_precision(s.support_cost_cents / 100.0, precision: 2) %></td>
              <td>&euro;<%= number_with_precision(s.staff_cost_cents / 100.0, precision: 2) %></td>
              <td>&euro;<%= number_with_precision(s.other_ops_cost_cents / 100.0, precision: 2) %></td>
              <td><strong>&euro;<%= number_with_precision(s.total_cost_euros, precision: 2) %></strong></td>
              <td>
                <%= link_to 'Edit', edit_admin_staff_cost_path(s), class: 'btn btn-outline-secondary btn-sm me-1' %>
                <%= button_to 'Delete', admin_staff_cost_path(s), method: :delete, class: 'btn btn-outline-danger btn-sm', form: { data: { turbo_confirm: 'Delete?' } } %>
              </td>
            </tr>
          <% end %>
          <% if @snapshots.empty? %>
            <tr><td colspan="7" class="text-center text-muted py-3">No staff cost entries yet.</td></tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
</div>
