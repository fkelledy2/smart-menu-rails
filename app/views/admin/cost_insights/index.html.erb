<div class="container-fluid py-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3 mb-1">Cost Insights Dashboard</h1>
    <div class="d-flex gap-2">
      <%= link_to 'Vendor Costs', admin_vendor_costs_path, class: 'btn btn-outline-secondary btn-sm' %>
      <%= link_to 'Staff Costs', admin_staff_costs_path, class: 'btn btn-outline-secondary btn-sm' %>
      <%= link_to 'Margin Policies', admin_margin_policies_path, class: 'btn btn-outline-secondary btn-sm' %>
      <%= link_to 'Pricing Models', admin_pricing_models_path, class: 'btn btn-outline-primary btn-sm' %>
    </div>
  </div>

  <!-- Month / Currency selector -->
  <%= form_with url: admin_cost_insights_path, method: :get, local: true, class: 'row g-2 align-items-end mb-4' do %>
    <div class="col-auto">
      <%= label_tag :month, 'Month', class: 'form-label small mb-1' %>
      <%= date_field_tag :month, @month.strftime('%Y-%m-%d'), class: 'form-control form-control-sm' %>
    </div>
    <div class="col-auto">
      <%= label_tag :currency, 'Currency', class: 'form-label small mb-1' %>
      <%= select_tag :currency, options_for_select([['EUR', 'EUR'], ['USD', 'USD']], @currency),
            class: 'form-select form-select-sm' %>
    </div>
    <%= submit_tag 'View', class: 'btn btn-secondary btn-sm' %>
  <% end %>

  <!-- Cost summary cards -->
  <div class="row g-3 mb-4">
    <div class="col-md-3">
      <div class="card border-0 bg-light h-100">
        <div class="card-body">
          <div class="text-muted small mb-1">Heroku (Production)</div>
          <div class="fs-4 fw-semibold">&euro;<%= number_with_precision(@totals.heroku_cents / 100.0, precision: 2) %></div>
        </div>
      </div>
    </div>
    <div class="col-md-3">
      <div class="card border-0 bg-light h-100">
        <div class="card-body">
          <div class="text-muted small mb-1">Vendor APIs</div>
          <div class="fs-4 fw-semibold">&euro;<%= number_with_precision(@totals.vendor_cents / 100.0, precision: 2) %></div>
        </div>
      </div>
    </div>
    <div class="col-md-3">
      <div class="card border-0 bg-light h-100">
        <div class="card-body">
          <div class="text-muted small mb-1">Staff + Support</div>
          <div class="fs-4 fw-semibold">&euro;<%= number_with_precision(@totals.staff_cents / 100.0, precision: 2) %></div>
        </div>
      </div>
    </div>
    <div class="col-md-3">
      <div class="card border-0 bg-primary bg-opacity-10 border-primary h-100">
        <div class="card-body">
          <div class="text-muted small mb-1">Total</div>
          <div class="fs-4 fw-semibold">&euro;<%= number_with_precision(@totals.total_cents / 100.0, precision: 2) %></div>
        </div>
      </div>
    </div>
  </div>

  <!-- Current margin policy -->
  <% if @margin_policy %>
    <div class="alert alert-info mb-4">
      <strong>Active Margin Policy:</strong> <%= @margin_policy.key %> —
      Target <%= @margin_policy.target_gross_margin_pct %>% gross margin
      (floor <%= @margin_policy.floor_gross_margin_pct %>%)
    </div>
  <% else %>
    <div class="alert alert-warning mb-4">
      No active margin policy. <% link_to 'Create one', new_admin_margin_policy_path %>
    </div>
  <% end %>

  <!-- Breakdown detail -->
  <div class="card mb-4">
    <div class="card-header"><h5 class="mb-0">Cost Breakdown</h5></div>
    <div class="card-body">
      <h6>Heroku by Environment</h6>
      <% if @totals.breakdown[:heroku].empty? %>
        <p class="text-muted small">No Heroku cost snapshots for this month.</p>
      <% else %>
        <ul class="list-unstyled small">
          <% @totals.breakdown[:heroku].each do |env, cents| %>
            <li><span class="badge bg-secondary me-2"><%= env %></span> &euro;<%= number_with_precision(cents / 100.0, precision: 2) %></li>
          <% end %>
        </ul>
      <% end %>

      <h6 class="mt-3">Vendor APIs</h6>
      <% if @totals.breakdown[:vendor].empty? %>
        <p class="text-muted small">No vendor cost entries for this month.</p>
      <% else %>
        <ul class="list-unstyled small">
          <% @totals.breakdown[:vendor].each do |svc, cents| %>
            <li><span class="badge bg-info text-dark me-2"><%= svc %></span> &euro;<%= number_with_precision(cents / 100.0, precision: 2) %></li>
          <% end %>
        </ul>
      <% end %>

      <h6 class="mt-3">Staff + Support</h6>
      <ul class="list-unstyled small">
        <li>Support: &euro;<%= number_with_precision(@totals.breakdown[:staff][:support] / 100.0, precision: 2) %></li>
        <li>Staff: &euro;<%= number_with_precision(@totals.breakdown[:staff][:staff] / 100.0, precision: 2) %></li>
        <li>Other ops: &euro;<%= number_with_precision(@totals.breakdown[:staff][:other_ops] / 100.0, precision: 2) %></li>
      </ul>
    </div>
  </div>

  <!-- Monthly rollup trigger -->
  <div class="card">
    <div class="card-body">
      <h5 class="card-title">Trigger Monthly Rollup</h5>
      <%= form_with url: trigger_monthly_rollup_admin_cost_insights_path, method: :post, local: true, class: 'd-flex gap-2 align-items-end' do %>
        <%= date_field_tag :month, @month.strftime('%Y-%m-%d'), class: 'form-control form-control-sm', style: 'width:180px' %>
        <%= submit_tag 'Run', class: 'btn btn-secondary btn-sm' %>
      <% end %>
    </div>
  </div>
</div>
