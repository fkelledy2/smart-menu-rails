<%= form_with model: [:admin, model], local: true do |f| %>
  <% if model.errors.any? %>
    <div class="alert alert-danger">
      <ul class="mb-0">
        <% model.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="row g-3 mb-4">
    <div class="col-md-3">
      <%= f.label :version, 'Version ID', class: 'form-label' %>
      <%= f.text_field :version, class: 'form-control', placeholder: 'e.g. 2026_Q2' %>
      <div class="form-text">Unique identifier for this pricing model.</div>
    </div>
    <div class="col-md-2">
      <%= f.label :currency, class: 'form-label' %>
      <%= f.select :currency, PricingModel::CURRENCIES, {}, class: 'form-select' %>
    </div>
  </div>

  <h5 class="mb-3">Cost Inputs</h5>
  <div class="card bg-light mb-4">
    <div class="card-body">
      <div class="row g-3">
        <div class="col-md-4">
          <label class="form-label">Total Monthly Cost (cents)</label>
          <input type="number" name="pricing_model[inputs_total_cost_cents]"
                 value="<%= model.inputs['total_cost_cents'] %>"
                 class="form-control" min="0"
                 placeholder="e.g. 500000 = €5000/month">
          <div class="form-text">
            Use the Cost Insights dashboard to get the total.
          </div>
        </div>
        <div class="col-md-3">
          <label class="form-label">Target Gross Margin (%)</label>
          <input type="number" name="pricing_model[inputs_target_gross_margin_pct]"
                 value="<%= model.inputs['target_gross_margin_pct'] %>"
                 class="form-control" min="1" max="99" step="0.5"
                 placeholder="e.g. 60">
        </div>
      </div>
    </div>
  </div>

  <div class="mt-3">
    <%= f.submit 'Save Draft', class: 'btn btn-primary' %>
    <%= link_to 'Cancel', admin_pricing_models_path, class: 'btn btn-link' %>
  </div>
<% end %>
