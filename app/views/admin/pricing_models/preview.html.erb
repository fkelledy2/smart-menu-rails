<% content_for :title, "Preview #{@model.version} — Admin" %>
<div class="container-fluid py-4">
  <%= render 'shared/admin_breadcrumb',
        crumbs: [{ label: 'Admin', url: admin_pricing_models_path },
                 { label: 'Pricing Models', url: admin_pricing_models_path },
                 { label: @model.version, url: admin_pricing_model_path(@model) }],
        current: 'Preview' %>
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3 mb-1">Preview: <%= @model.version %></h1>
  </div>

  <% if @margin_engine_result %>
    <div class="row g-3 mb-4">
      <div class="col-md-3">
        <div class="card border-0 bg-light h-100">
          <div class="card-body">
            <div class="text-muted small">Total Cost</div>
            <div class="fw-semibold">&euro;<%= number_with_precision(@margin_engine_result.total_cost_cents / 100.0, precision: 2) %></div>
          </div>
        </div>
      </div>
      <div class="col-md-3">
        <div class="card border-0 bg-light h-100">
          <div class="card-body">
            <div class="text-muted small">Required Revenue</div>
            <div class="fw-semibold">&euro;<%= number_with_precision(@margin_engine_result.required_revenue_cents / 100.0, precision: 2) %></div>
          </div>
        </div>
      </div>
      <div class="col-md-2">
        <div class="card border-0 bg-light h-100">
          <div class="card-body">
            <div class="text-muted small">Target Margin</div>
            <div class="fw-semibold"><%= @margin_engine_result.target_margin_pct %>%</div>
          </div>
        </div>
      </div>
      <div class="col-md-2">
        <div class="card border-0 bg-light h-100">
          <div class="card-body">
            <div class="text-muted small">Per Weight Unit</div>
            <div class="fw-semibold">&euro;<%= number_with_precision(@margin_engine_result.per_weight_unit_cents / 100.0, precision: 2) %></div>
          </div>
        </div>
      </div>
    </div>

    <div class="card mb-4">
      <div class="card-header fw-semibold">Computed Plan Prices</div>
      <div class="table-responsive">
        <table class="table table-sm mb-0">
          <thead class="table-light">
            <tr>
              <th>Plan</th>
              <th>Weight Multiplier</th>
              <th>Monthly Price</th>
              <th>Annual Price (10x monthly)</th>
              <th>Annual Savings</th>
            </tr>
          </thead>
          <tbody>
            <% @margin_engine_result.plan_prices.each do |pp| %>
              <tr>
                <td><strong><%= pp.plan_name %></strong></td>
                <td><%= pp.weight_multiplier %>x</td>
                <td>&euro;<%= number_with_precision(pp.monthly_price_cents / 100.0, precision: 2) %>/mo</td>
                <td>&euro;<%= number_with_precision(pp.annual_price_cents / 100.0, precision: 2) %>/yr</td>
                <td class="text-success small">
                  &euro;<%= number_with_precision(((pp.monthly_price_cents * 12) - pp.annual_price_cents) / 100.0, precision: 2) %> saved
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
  <% end %>

  <% if @plan_prices.any? %>
    <div class="card mb-4">
      <div class="card-header fw-semibold">Saved Plan Price Records</div>
      <div class="table-responsive">
        <table class="table table-sm mb-0">
          <thead class="table-light">
            <tr><th>Plan</th><th>Interval</th><th>Currency</th><th>Price</th></tr>
          </thead>
          <tbody>
            <% @plan_prices.each do |pp| %>
              <tr>
                <td><strong><%= pp.plan.name %></strong></td>
                <td><%= pp.interval %></td>
                <td><%= pp.currency %></td>
                <td>&euro;<%= number_with_precision(pp.price_euros, precision: 2) %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
  <% end %>

  <% if @model.draft? %>
    <div class="alert alert-info">
      These are the computed prices. When you publish, Stripe Price objects will be created for each row.
      <%= link_to 'Go to publish', admin_pricing_model_path(@model), class: 'alert-link' %>
    </div>
  <% end %>
</div>
