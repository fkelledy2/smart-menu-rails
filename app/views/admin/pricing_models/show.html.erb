<% content_for :title, "Pricing Model #{@model.version} — Admin" %>
<div class="container-fluid py-4">
  <%= render 'shared/admin_breadcrumb',
        crumbs: [{ label: 'Admin', url: admin_pricing_models_path },
                 { label: 'Pricing Models', url: admin_pricing_models_path }],
        current: @model.version %>
  <div class="d-flex justify-content-between align-items-center mb-4">
    <div>
      <h1 class="h3 mb-1">Pricing Model: <%= @model.version %></h1>
      <%= render 'shared/status_badge', status: @model.status %>
    </div>
    <div class="d-flex gap-2">
      <% if @model.draft? %>
        <%= link_to 'Edit', edit_admin_pricing_model_path(@model), class: 'btn btn-outline-secondary btn-sm' %>
        <%= link_to 'Preview Prices', preview_admin_pricing_model_path(@model), class: 'btn btn-outline-primary btn-sm' %>
      <% end %>
    </div>
  </div>

  <div class="row g-3 mb-4">
    <div class="col-md-2">
      <div class="card border-0 bg-light h-100">
        <div class="card-body">
          <div class="text-muted small">Currency</div>
          <div class="fw-semibold"><%= @model.currency %></div>
        </div>
      </div>
    </div>
    <div class="col-md-3">
      <div class="card border-0 bg-light h-100">
        <div class="card-body">
          <div class="text-muted small">Total Cost Input</div>
          <div class="fw-semibold">&euro;<%= number_with_precision(@model.inputs['total_cost_cents'].to_i / 100.0, precision: 2) %></div>
        </div>
      </div>
    </div>
    <div class="col-md-2">
      <div class="card border-0 bg-light h-100">
        <div class="card-body">
          <div class="text-muted small">Target Margin</div>
          <div class="fw-semibold"><%= @model.inputs['target_gross_margin_pct'] %>%</div>
        </div>
      </div>
    </div>
    <% if @model.published? %>
      <div class="col-md-3">
        <div class="card border-0 bg-success bg-opacity-10 h-100">
          <div class="card-body">
            <div class="text-muted small">Published At</div>
            <div class="fw-semibold"><%= @model.published_at&.strftime('%d %b %Y %H:%M') %></div>
            <div class="text-muted small">by User #<%= @model.published_by_user_id %></div>
          </div>
        </div>
      </div>
    <% end %>
  </div>

  <!-- Plan prices -->
  <% plan_prices = @model.pricing_model_plan_prices.includes(:plan).ordered %>
  <% if plan_prices.any? %>
    <div class="card mb-4">
      <div class="card-header"><h5 class="mb-0">Plan Prices</h5></div>
      <div class="table-responsive">
        <table class="table table-sm mb-0">
          <thead class="table-light">
            <tr><th>Plan</th><th>Interval</th><th>Currency</th><th>Price</th><th>Stripe Price ID</th></tr>
          </thead>
          <tbody>
            <% plan_prices.each do |pp| %>
              <tr>
                <td><strong><%= pp.plan.name %></strong></td>
                <td><span class="badge bg-secondary"><%= pp.interval %></span></td>
                <td><%= pp.currency %></td>
                <td>&euro;<%= number_with_precision(pp.price_euros, precision: 2) %></td>
                <td class="text-muted small"><%= pp.stripe_price_id || '—' %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
  <% end %>

  <!-- Publish action -->
  <% if @model.draft? %>
    <div class="card border-warning">
      <div class="card-header bg-warning bg-opacity-10">
        <h5 class="mb-0"><i class="bi bi-exclamation-triangle me-2" aria-hidden="true"></i>Publish — Irreversible Action</h5>
      </div>
      <div class="card-body">
        <p class="text-body small mb-3">
          Publishing will create Stripe Price records and lock this model. This action is irreversible.
          Run <strong>Preview</strong> first to verify computed prices.
        </p>
        <%= form_with url: publish_admin_pricing_model_path(@model), method: :post, local: true do %>
          <div class="mb-3">
            <%= label_tag :reason, 'Publish Reason (optional)', class: 'form-label' %>
            <%= text_field_tag :reason, nil, class: 'form-control', placeholder: 'e.g. Q2 2026 pricing update' %>
          </div>
          <%= submit_tag 'Publish and Create Stripe Prices',
                class: 'btn btn-warning',
                data: { turbo_confirm: 'Are you sure? This cannot be undone.' } %>
        <% end %>
      </div>
    </div>
  <% end %>
</div>
