<% content_for :title, 'Pricing Models — Admin' %>
<div class="container-fluid py-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3 mb-1">Pricing Models</h1>
    <%= link_to 'New Pricing Model', new_admin_pricing_model_path, class: 'btn btn-primary btn-sm' %>
  </div>

  <div class="alert alert-info mb-4">
    Cost-indexed pricing is
    <strong><%= Flipper.enabled?(:cost_indexed_pricing) ? 'ENABLED' : 'DISABLED' %></strong>
    (manage via Flipper UI).
  </div>

  <div class="card">
    <div class="table-responsive">
      <table class="table table-sm table-hover align-middle">
        <thead class="table-light">
          <tr>
            <th>Version</th><th>Status</th><th>Currency</th><th>Effective From</th>
            <th>Total Cost Input</th><th>Target Margin</th><th></th>
          </tr>
        </thead>
        <tbody>
          <% @models.each do |model| %>
            <tr>
              <td><strong><%= model.version %></strong></td>
              <td>
                <%= render 'shared/status_badge', status: model.status %>
              </td>
              <td><%= model.currency %></td>
              <td><%= model.effective_from&.strftime('%d %b %Y') || '—' %></td>
              <td class="text-muted small">
                &euro;<%= number_with_precision(model.inputs['total_cost_cents'].to_i / 100.0, precision: 2) %>
              </td>
              <td class="text-muted small">
                <%= model.inputs['target_gross_margin_pct'] %>%
              </td>
              <td class="text-end">
                <div class="d-flex justify-content-end gap-1">
                  <%= link_to 'View', admin_pricing_model_path(model), class: 'btn btn-outline-secondary btn-sm' %>
                  <% if model.draft? %>
                    <%= link_to 'Edit', edit_admin_pricing_model_path(model), class: 'btn btn-outline-secondary btn-sm' %>
                    <%= link_to 'Preview', preview_admin_pricing_model_path(model), class: 'btn btn-outline-primary btn-sm' %>
                    <%= button_to 'Delete', admin_pricing_model_path(model), method: :delete,
                          class: 'btn btn-outline-danger btn-sm',
                          form: { data: { turbo_confirm: 'Delete this draft?' } } %>
                  <% end %>
                </div>
              </td>
            </tr>
          <% end %>
          <% if @models.empty? %>
            <tr><td colspan="7" class="text-center text-muted py-3">No pricing models yet.</td></tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
</div>
