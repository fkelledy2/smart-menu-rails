<%# Admin: JWT Token detail %>
<% content_for :title, "#{@token.name} — API Token" %>

<div class="container-fluid py-4 mw-800">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <div>
      <%= link_to 'API Tokens', admin_jwt_tokens_path, class: 'text-muted text-decoration-none' %>
      <span class="text-muted mx-1">/</span>
      <span><%= @token.name %></span>
    </div>
    <% if @token.active? %>
      <%= button_to 'Revoke Token', revoke_admin_jwt_token_path(@token),
            method: :post,
            class: 'btn btn-danger btn-sm',
            form: { data: { turbo_confirm: 'Revoke this token? All API calls using it will immediately return 401.' } } %>
    <% end %>
  </div>

  <% if flash[:raw_jwt].present? %>
    <div class="alert alert-warning border-0 mb-4" role="alert">
      <h5 class="alert-heading">Copy your token now</h5>
      <p class="mb-2">This is the only time the raw JWT will be shown. It cannot be retrieved again.</p>
      <div class="d-flex gap-2 align-items-start">
        <pre class="bg-dark text-light rounded p-3 flex-grow-1 mb-0 fs-12" style="word-break: break-all;"><%= flash[:raw_jwt] %></pre>
      </div>
      <div class="mt-3 d-flex gap-2">
        <%= form_with url: send_email_admin_jwt_token_path(@token), method: :post, local: true, class: 'd-inline' do |f| %>
          <%= f.hidden_field :raw_jwt, value: flash[:raw_jwt] %>
          <%= f.text_field :recipient_email, placeholder: 'Recipient email', class: 'form-control form-control-sm d-inline-block', style: 'width: 220px' %>
          <%= f.submit 'Email token', class: 'btn btn-sm btn-outline-dark ms-1' %>
        <% end %>
        <%= form_with url: download_link_admin_jwt_token_path(@token), method: :post, local: true, class: 'd-inline ms-2' do |f| %>
          <%= f.hidden_field :raw_jwt, value: flash[:raw_jwt] %>
          <%= f.submit 'Download .txt', class: 'btn btn-sm btn-outline-secondary' %>
        <% end %>
      </div>
    </div>
  <% end %>

  <div class="card mb-4">
    <div class="card-body">
      <dl class="row mb-0">
        <dt class="col-sm-3">Status</dt>
        <dd class="col-sm-9">
          <%= render 'shared/status_badge', status: @token.status.to_s %>
          <% if @token.revoked? %>
            <small class="text-muted ms-2">Revoked <%= @token.revoked_at.strftime('%d %b %Y at %H:%M UTC') %></small>
          <% end %>
        </dd>

        <dt class="col-sm-3">Name</dt>
        <dd class="col-sm-9"><%= @token.name %></dd>

        <% if @token.description.present? %>
          <dt class="col-sm-3">Description</dt>
          <dd class="col-sm-9"><%= @token.description %></dd>
        <% end %>

        <dt class="col-sm-3">Restaurant</dt>
        <dd class="col-sm-9"><%= @token.restaurant&.name %></dd>

        <dt class="col-sm-3">Scopes</dt>
        <dd class="col-sm-9">
          <% @token.scopes.each do |scope| %>
            <span class="badge bg-secondary me-1"><%= scope %></span>
          <% end %>
        </dd>

        <dt class="col-sm-3">Expires</dt>
        <dd class="col-sm-9"><%= @token.expires_at.strftime('%d %B %Y at %H:%M UTC') %></dd>

        <dt class="col-sm-3">Rate limit</dt>
        <dd class="col-sm-9"><%= @token.rate_limit_per_minute %>/min &middot; <%= @token.rate_limit_per_hour %>/hr</dd>

        <dt class="col-sm-3">Usage</dt>
        <dd class="col-sm-9">
          <%= @token.usage_count %> requests
          <% if @token.last_used_at %>
            &middot; last used <%= @token.last_used_at.strftime('%d %b %Y at %H:%M UTC') %>
          <% end %>
        </dd>

        <dt class="col-sm-3">Issued by</dt>
        <dd class="col-sm-9"><%= @token.admin_user&.email %></dd>

        <dt class="col-sm-3">Created</dt>
        <dd class="col-sm-9"><%= @token.created_at.strftime('%d %b %Y at %H:%M UTC') %></dd>
      </dl>
    </div>
  </div>

  <% recent_logs = @token.usage_logs.recent.limit(20) %>
  <% if recent_logs.any? %>
    <h5 class="mb-3">Recent usage (last 20)</h5>
    <div class="table-responsive">
      <table class="table table-sm table-hover">
        <thead class="table-light">
          <tr>
            <th>Time</th>
            <th>Method</th>
            <th>Endpoint</th>
            <th>Status</th>
            <th>IP</th>
          </tr>
        </thead>
        <tbody>
          <% recent_logs.each do |log| %>
            <tr>
              <td class="text-nowrap"><%= log.created_at.strftime('%d %b %H:%M:%S') %></td>
              <td><span class="badge bg-secondary"><%= log.http_method %></span></td>
              <td><code class="small"><%= log.endpoint %></code></td>
              <td>
                <% status_class = log.response_status < 400 ? 'text-success' : 'text-danger' %>
                <span class="<%= status_class %> fw-semibold"><%= log.response_status %></span>
              </td>
              <td><code class="small"><%= log.ip_address %></code></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% else %>
    <p class="text-muted small">No usage logs yet.</p>
  <% end %>
</div>
