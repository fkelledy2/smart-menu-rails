<%= form_with model: [:admin, policy], local: true do |f| %>
  <% if policy.errors.any? %>
    <div class="alert alert-danger">
      <ul class="mb-0">
        <% policy.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="row g-3">
    <div class="col-md-3">
      <%= f.label :key, class: 'form-label' %>
      <%= f.text_field :key, class: 'form-control', placeholder: 'e.g. default' %>
    </div>
    <div class="col-md-3">
      <%= f.label :target_gross_margin_pct, 'Target Gross Margin (%)', class: 'form-label' %>
      <%= f.number_field :target_gross_margin_pct, class: 'form-control', min: 1, max: 99, step: 0.5 %>
    </div>
    <div class="col-md-3">
      <%= f.label :floor_gross_margin_pct, 'Floor Gross Margin (%)', class: 'form-label' %>
      <%= f.number_field :floor_gross_margin_pct, class: 'form-control', min: 1, max: 99, step: 0.5 %>
    </div>
  </div>

  <div class="mt-3">
    <%= f.submit class: 'btn btn-primary' %>
    <%= link_to 'Cancel', admin_margin_policies_path, class: 'btn btn-link' %>
  </div>
<% end %>
