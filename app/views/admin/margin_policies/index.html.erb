<div class="container-fluid py-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3 mb-1">Margin Policies</h1>
    <%= link_to 'New Policy', new_admin_margin_policy_path, class: 'btn btn-primary btn-sm' %>
  </div>

  <div class="card">
    <div class="table-responsive">
      <table class="table table-sm table-hover mb-0">
        <thead class="table-light">
          <tr>
            <th>Key</th><th>Target Margin</th><th>Floor Margin</th><th>Status</th><th></th>
          </tr>
        </thead>
        <tbody>
          <% @policies.each do |policy| %>
            <tr>
              <td><strong><%= policy.key %></strong></td>
              <td><%= policy.target_gross_margin_pct %>%</td>
              <td><%= policy.floor_gross_margin_pct %>%</td>
              <td>
                <%= render 'shared/status_badge', status: policy.status %>
              </td>
              <td class="text-end">
                <% if policy.inactive? %>
                  <%= button_to 'Activate', activate_admin_margin_policy_path(policy),
                        method: :patch, class: 'btn btn-outline-success btn-sm me-1' %>
                <% else %>
                  <%= button_to 'Deactivate', deactivate_admin_margin_policy_path(policy),
                        method: :patch, class: 'btn btn-outline-warning btn-sm me-1' %>
                <% end %>
                <%= link_to 'Edit', edit_admin_margin_policy_path(policy), class: 'btn btn-outline-secondary btn-sm me-1' %>
                <%= button_to 'Delete', admin_margin_policy_path(policy), method: :delete,
                      class: 'btn btn-outline-danger btn-sm',
                      form: { data: { turbo_confirm: 'Delete this margin policy?' } } %>
              </td>
            </tr>
          <% end %>
          <% if @policies.empty? %>
            <tr><td colspan="5" class="text-center text-muted py-3">No margin policies configured.</td></tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
</div>
