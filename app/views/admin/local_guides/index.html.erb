<% content_for :title, 'Local Guides — Admin' %>
<div class="container-fluid py-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3 mb-1">Local Guides</h1>
    <%= link_to 'New Guide', new_admin_local_guide_path, class: 'btn btn-primary btn-sm' %>
  </div>

  <div class="d-flex gap-1 flex-wrap mb-4">
    <%= link_to 'All', admin_local_guides_path, class: "btn btn-sm #{params[:status].present? ? 'btn-outline-secondary' : 'btn-secondary'}" %>
    <% LocalGuide.statuses.keys.each do |s| %>
      <%= link_to s.titleize, admin_local_guides_path(status: s), class: "btn btn-sm #{params[:status] == s ? 'btn-secondary' : 'btn-outline-secondary'}" %>
    <% end %>
  </div>

  <% if @local_guides.any? %>
    <div class="table-responsive">
    <table class="table table-sm table-hover align-middle">
      <thead>
        <tr>
          <th>Title</th>
          <th>City</th>
          <th>Category</th>
          <th>Status</th>
          <th>Updated</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% @local_guides.each do |guide| %>
          <tr>
            <td><%= link_to guide.title, admin_local_guide_path(guide) %></td>
            <td><%= guide.city %>, <%= guide.country %></td>
            <td><%= guide.category || '—' %></td>
            <td>
              <%= render 'shared/status_badge', status: guide.status %>
            </td>
            <td><%= time_ago_in_words(guide.updated_at) %> ago</td>
            <td>
              <%= link_to 'Edit', edit_admin_local_guide_path(guide), class: 'btn btn-sm btn-outline-secondary' %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
    </div>
  <% else %>
    <%= render 'shared/empty_state', title: 'No local guides found', description: 'Create the first guide to surface city recommendations.', icon: 'bi-map' %>
  <% end %>
</div>
