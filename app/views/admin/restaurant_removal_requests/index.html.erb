<% content_for :title, 'Removal Requests — Admin' %>
<div class="container-fluid py-4">
  <div class="d-flex align-items-center justify-content-between mb-3">
    <h1 class="h3 mb-1">Removal Requests</h1>
    <div class="d-flex gap-2">
      <% %w[received actioned_unpublished resolved].each do |s| %>
        <%= link_to s.humanize, admin_restaurant_removal_requests_path(status: s),
            class: "btn btn-sm #{@status == s ? 'btn-primary' : 'btn-outline-secondary'}" %>
      <% end %>
      <%= link_to 'All', admin_restaurant_removal_requests_path,
          class: "btn btn-sm #{@status.blank? ? 'btn-primary' : 'btn-outline-secondary'}" %>
    </div>
  </div>

  <% if @removal_requests.empty? %>
    <%= render 'shared/empty_state', title: 'No removal requests found', icon: :default %>
  <% else %>
    <div class="table-responsive">
      <table class="table table-sm table-hover align-middle">
        <thead class="table-light">
          <tr>
            <th>ID</th>
            <th>Restaurant</th>
            <th>Email</th>
            <th>Reason</th>
            <th>Status</th>
            <th>Submitted</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>
          <% @removal_requests.each do |rr| %>
            <tr>
              <td><%= rr.id %></td>
              <td><%= rr.restaurant.name %></td>
              <td><%= rr.requested_by_email %></td>
              <td class="text-truncate mw-0" title="<%= rr.reason %>"><%= rr.reason %></td>
              <td>
                <%= render 'shared/status_badge', status: rr.status %>
              </td>
              <td><%= rr.created_at.strftime('%Y-%m-%d %H:%M') %></td>
              <td>
                <div class="d-flex gap-1">
                  <%= link_to 'View', admin_restaurant_removal_request_path(rr), class: 'btn btn-sm btn-outline-primary' %>
                  <% if rr.received? %>
                    <%= button_to 'Unpublish', action_unpublish_admin_restaurant_removal_request_path(rr),
                        method: :patch, class: 'btn btn-sm btn-danger',
                        data: { turbo_confirm: 'Unpublish this restaurant preview?' } %>
                  <% end %>
                  <% if !rr.resolved? %>
                    <%= button_to 'Resolve', resolve_admin_restaurant_removal_request_path(rr),
                        method: :patch, class: 'btn btn-sm btn-success' %>
                  <% end %>
                </div>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% end %>
</div>
