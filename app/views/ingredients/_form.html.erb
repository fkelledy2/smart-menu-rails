<%= form_with(model: ingredient) do |form| %>
  <div class="mb-3">
    <%= form.label :name, class: 'form-label' %>
    <%= form.text_field :name, class: 'form-control' %>
  </div>

  <div class="mb-3">
    <%= form.label :description, class: 'form-label' %>
    <%= form.text_area :description, class: 'form-control' %>
  </div>

  <% if ingredient.errors.any? %>
    <div class="alert alert-danger mb-3" role="alert">
      <div class="fw-semibold mb-1">Errors</div>
      <ul class="mb-0">
        <% ingredient.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="d-flex justify-content-end gap-2">
    <% if ingredient.persisted? %>
      <%= button_to 'Delete', ingredient, method: :delete, class: 'btn btn-outline-danger', data: { turbo_confirm: 'Are you sure?' } %>
    <% end %>
    <%= form.submit value: 'Save', class: 'btn btn-dark' %>
  </div>
<% end %>
