<%#
  Edit Ingredient - 2025 Design System
  Modern form layout with consistent styling
%>

<% in_frame = defined?(turbo_frame_request?) && turbo_frame_request? %>

<!-- Page Header -->
<% unless in_frame %>
  <div class="container-fluid px-0 pb-4">
    <div class="d-flex justify-content-between align-items-start flex-wrap gap-3">
      <div>
        <!-- Breadcrumb -->
        <div class="text-sm text-gray-500 mb-2">
          <%= link_to @restaurant.name, edit_restaurant_path(@restaurant), class: 'text-primary' %>
          <i class="bi bi-chevron-right"></i>
          <%= link_to t('.ingredients', default: 'Ingredients'), restaurant_ingredients_path(@restaurant), class: 'text-primary' %>
          <i class="bi bi-chevron-right"></i>
          <%= @ingredient.name %>
        </div>

        <h1 class="text-2xl font-semibold text-gray-900 mb-1">
          <i class="bi bi-box-seam"></i>
          <%= t('.edit_ingredient', default: 'Edit Ingredient') %>
        </h1>
        <p class="text-sm text-gray-500">
          <%= t('.description', default: 'Update ingredient details and cost information') %>
        </p>
      </div>

      <div class="d-flex gap-2">
        <%= link_to restaurant_ingredients_path(@restaurant),
            class: 'btn btn-ghost' do %>
          <i class="bi bi-arrow-left"></i> <%= t('.back_to_ingredients', default: 'Back to Ingredients') %>
        <% end %>
      </div>
    </div>
  </div>
<% end %>

<!-- Form Card -->
<div class="content-card" data-skip-form-manager="true">
  <h2 class="content-card-title">
    <i class="bi bi-box-seam"></i>
    <%= t('.ingredient_details', default: 'Ingredient Details') %>
  </h2>

  <%= render 'form', ingredient: @ingredient %>
</div>

<style>
  .text-2xl {
    font-size: 1.5rem;
    line-height: 2rem;
  }

  .text-gray-900 {
    color: var(--color-gray-900);
  }

  .text-gray-500 {
    color: var(--color-gray-500);
  }

  .text-sm {
    font-size: 0.875rem;
  }
</style>
