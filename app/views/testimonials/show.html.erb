<!-- Page Header -->
<div class="container-fluid px-0 pb-4">
  <div class="d-flex justify-content-between align-items-start flex-wrap gap-3">
    <div>
      <div class="small text-muted mb-2">
        <%= link_to t('.back'), testimonials_path, class: 'text-primary' %>
        <i class="bi bi-chevron-right"></i>
        <%= t('.title') %>
      </div>
      <h1 class="fs-4 fw-semibold mb-1">
        <i class="bi bi-chat-quote"></i>
        <%= t('.title') %>
      </h1>
    </div>

    <div class="d-flex gap-2">
      <%= link_to testimonials_path, class: 'btn btn-ghost' do %>
        <i class="bi bi-arrow-left"></i> <%= t('.back') %>
      <% end %>
      <%= link_to edit_testimonial_path(@testimonial), class: 'btn btn-primary' do %>
        <i class="bi bi-pencil"></i> <%= t('.edit') %>
      <% end %>
    </div>
  </div>
</div>

<!-- Testimonial Details Card -->
<div class="content-card">
  <h2 class="content-card-title">
    <i class="bi bi-chat-quote"></i>
    <%= t('.testimonial_details') %>
  </h2>

  <dl class="row mt-3">
    <dt class="col-sm-3 text-muted"><%= t('testimonials.testimonial.testimonial') %></dt>
    <dd class="col-sm-9"><%= @testimonial.testimonial %></dd>

    <dt class="col-sm-3 text-muted"><%= t('testimonials.testimonial.user') %></dt>
    <dd class="col-sm-9"><%= @testimonial.user&.name %></dd>

    <dt class="col-sm-3 text-muted"><%= t('testimonials.testimonial.restaurant') %></dt>
    <dd class="col-sm-9"><%= @testimonial.restaurant&.name %></dd>
  </dl>
</div>
