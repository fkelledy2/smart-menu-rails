<!-- Page Header -->
<div class="container-fluid px-0 pb-4">
  <div class="d-flex justify-content-between align-items-start flex-wrap gap-3">
    <div>
      <div class="small text-muted mb-2">
        <%= link_to t('testimonials.index.testimonials'), testimonials_path, class: 'text-primary' %>
        <i class="bi bi-chevron-right"></i>
        <%= t('.title') %>
      </div>
      <h1 class="fs-4 fw-semibold mb-1">
        <i class="bi bi-pencil"></i>
        <%= t('.title') %>
      </h1>
      <p class="small text-muted">
        <%= t('.description') %>
      </p>
    </div>

    <div class="d-flex gap-2">
      <%= link_to testimonials_path, class: 'btn btn-ghost' do %>
        <i class="bi bi-x-lg"></i> <%= t('.cancel') %>
      <% end %>
      <%= link_to @testimonial,
          data: { turbo_method: :delete, turbo_confirm: t('.confirm_delete') },
          class: 'btn btn-ghost text-danger' do %>
        <i class="bi bi-trash"></i> <%= t('.delete') %>
      <% end %>
    </div>
  </div>
</div>

<!-- Form Card -->
<div class="content-card">
  <h2 class="content-card-title">
    <i class="bi bi-chat-quote"></i>
    <%= t('.testimonial_details') %>
  </h2>

  <%= render 'form', testimonial: @testimonial %>
</div>
