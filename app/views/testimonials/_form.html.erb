<%= form_with(model: testimonial) do |form| %>
  <% if testimonial.errors.any? %>
    <div class="alert alert-danger" role="alert">
      <strong><%= pluralize(testimonial.errors.count, 'error') %> prohibited this testimonial from being saved:</strong>
      <ul class="mb-0 mt-1">
        <% testimonial.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="mb-3">
    <%= form.label :testimonial, class: 'form-label' %>
      <%= form.text_field :testimonial, class: 'form-control' %>
    </div>

  <div class="mb-3">
    <%= form.label :user_id, class: 'form-label' %>
    <%= form.select :user_id, @users, { include_blank: true }, class: 'form-select' %>
  </div>

  <div class="mb-3">
    <%= form.label :restaurant_id, class: 'form-label' %>
    <%= form.select :restaurant_id, @restaurants, { include_blank: true }, class: 'form-select' %>
  </div>

  <div class="d-flex gap-2 mt-4">
    <%= form.submit t('testimonials.form.save'), class: 'btn btn-primary' %>
  </div>
<% end %>
