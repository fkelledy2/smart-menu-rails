      </div>

      <h5 class="mt-4">Cost Components</h5>
      
      <div class="row">
        <div class="col-md-6">
          <div cl          <
            <%= form.label :ingredient_cost, 'Ingredient Cost', class: 'form-label' %>
            <%= form.number_field :ingredient_cost, class: 'form-control', step: 0.01, min: 0, value: 0 %>
          </div>
        </div>
        <div class="col-md-6">
          <div class="mb-3">
            <%= form.label :labor_cost, 'Labor Cost', class: 'form-label' %>
            <%= form.number_field :labor_cost, class: 'form-control', step: 0.01, min: 0, value: 0 %>
          </div>
        </div>
      </div>

      <div class="row">
        <div class="col-md-6">
          <div class="mb-3">
            <%= form.label :packaging_cost, 'Packaging Cost', class: 'form-label' %>
            <%= form.number_field :packaging_cost, class: 'form-control', step: 0.01, min: 0, value: 0 %>
          </div>
        </div>
        <div class="col-md-6">
          <div class="mb-3">
            <%= form.label :overhead_cost, 'Overhead Cost', class: 'form-label' %>
            <%= form.number_field :overhead_cost, class: 'form-control', step: 0.01, min: 0, value: 0 %>
          </div>
        </div>
      </div>

      <div class="mb-3">
        <%= form.label :cost_source, 'Cost Source', class: 'form-label' %>
        <%= form.select :cost_source, 
            [['Manual Entry', 'manual'], ['Recipe Calculated', 'recipe_calculated'], ['AI Estimated', 'ai_estimated']],
            {}, class: 'form-select' %>
      </div>

      <div class="mb-3">
        <%= form.label :effective_date, 'Effective Date', class: 'form-label' %>
        <%= form.date_field :effective_date, class: 'form-control', required: true %>
      </div>

      <div class="mb-3">
        <%= form.label :notes, class: 'form-label' %>
        <%= form.text_area :notes, class: 'form-control', rows: 3, placeholder: 'Optional notes about this cost entry' %>
      </div>

      <div class="mt-4">
        <%= form.submit 'Save Cost Data', class: 'btn btn-primary' %>
        <%= link_to 'Cancel', edit_restaurant_menu_path(@restaurant, @menu), class: 'btn btn-secondary' %>
      </div>
    <% end %>
  </div>

  <div class="col-md-4">
    <div cla    <div">
      <div class="card-header">
