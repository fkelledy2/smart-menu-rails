<div class="page-header">
  <h4>Add Cost Data for <%= @menuitem.localised_name('en') %></h4>
</div>

<div class="row">
  <div class="col-md-8">
    <%= form_with(model: @menuitem_cost, url: restaurant_menu_menusection_menuitem_menuitem_costs_path(@restaurant, @menu, @menuitem.menusection, @menuitem), local: true) do |form| %>
      <% if @menuitem_cost.errors.any? %>
