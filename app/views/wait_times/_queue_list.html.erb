<% if queue.empty? %>
  <div class="text-center py-5 text-muted">
    <i class="bi bi-people display-5" aria-hidden="true"></i>
    <p class="mt-3 mb-0">No one in the queue right now.</p>
    <p class="small">Use the form to add walk-in guests.</p>
  </div>
<% else %>
  <div class="list-group list-group-flush">
    <% queue.each do |entry| %>
      <div class="list-group-item px-3 py-3" id="wait_queue_entry_<%= entry.id %>">
        <div class="d-flex justify-content-between align-items-start">
          <div class="d-flex align-items-center gap-3">
            <%# Position badge %>
            <span class="badge text-bg-secondary rounded-circle fs-6 d-flex align-items-center justify-content-center"
                  style="width:2rem;height:2rem;"
                  title="Queue position">
              <%= entry.queue_position %>
            </span>
            <div>
              <div class="fw-semibold"><%= entry.customer_name %></div>
              <div class="small text-muted">
                <i class="bi bi-people me-1" aria-hidden="true"></i>Party of <%= entry.party_size %>
                <% if entry.customer_phone.present? %>
                  &nbsp;&middot;&nbsp;
                  <i class="bi bi-telephone me-1" aria-hidden="true"></i><%= entry.customer_phone %>
                <% end %>
              </div>
              <div class="small text-muted">
                Joined <%= time_ago_in_words(entry.joined_queue_at) %> ago
                <% if entry.estimated_seat_time %>
                  &nbsp;&middot;&nbsp;
                  <% if entry.estimated_seat_time > Time.current %>
                    <span class="text-warning">
                      ~<%= distance_of_time_in_words(Time.current, entry.estimated_seat_time) %> remaining
                    </span>
                  <% else %>
                    <span class="text-danger fw-medium">Overdue</span>
                  <% end %>
                <% end %>
              </div>
            </div>
          </div>

          <%# Action buttons %>
          <div class="d-flex gap-2 flex-shrink-0">
            <%# Seat button — shows table selector dropdown %>
            <div class="dropdown">
              <%= button_tag class: 'btn btn-sm btn-success dropdown-toggle',
                    type: 'button',
                    data: { bs_toggle: 'dropdown', bs_auto_close: 'outside' },
                    aria: { expanded: false } do %>
                <i class="bi bi-chair me-1" aria-hidden="true"></i>Seat
              <% end %>
              <ul class="dropdown-menu dropdown-menu-end p-2" style="min-width:220px;">
                <li class="mb-2">
                  <small class="text-muted px-2">Select a table (optional)</small>
                </li>
                <%= form_with url: seat_wait_times_queue_entry_restaurant_path(restaurant, entry_id: entry.id),
                              method: :patch,
                              local: true do |f| %>
                  <li>
                    <%= f.select :tablesetting_id,
                          options_for_select(
                            [['No specific table', '']] +
                            local_assigns[:tablesettings]&.map { |t| ["#{t.name} (seats #{t.capacity})", t.id] }.to_a,
                          ),
                          {},
                          class: 'form-select form-select-sm mb-2' %>
                  </li>
                  <li>
                    <%= f.submit 'Confirm Seat', class: 'btn btn-success btn-sm w-100' %>
                  </li>
                <% end %>
              </ul>
            </div>

            <%# No-show button %>
            <%= button_to no_show_wait_times_queue_entry_restaurant_path(restaurant, entry_id: entry.id),
                  method: :patch,
                  class: 'btn btn-sm btn-outline-warning',
                  title: 'No-show',
                  form: { "data-turbo-confirm": "Mark #{entry.customer_name} as no-show?" } do %>
              <i class="bi bi-person-x" aria-hidden="true"></i>
            <% end %>

            <%# Remove button %>
            <%= button_to cancel_wait_times_queue_entry_restaurant_path(restaurant, entry_id: entry.id),
                  method: :patch,
                  class: 'btn btn-sm btn-outline-danger',
                  title: 'Remove from queue',
                  form: { "data-turbo-confirm": "Remove #{entry.customer_name} from the queue?" } do %>
              <i class="bi bi-x-lg" aria-hidden="true"></i>
            <% end %>
          </div>
        </div>

        <% if entry.notified? %>
          <div class="mt-2">
            <span class="badge text-bg-info">
              <i class="bi bi-bell me-1" aria-hidden="true"></i>Notified
            </span>
          </div>
        <% end %>
      </div>
    <% end %>
  </div>
<% end %>
