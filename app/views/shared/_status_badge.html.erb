<%
  status ||= local_assigns[:status]
  label ||= local_assigns[:label] || status.to_s.titleize
  size ||= local_assigns[:size] || 'md'

  variant_map = {
    'active'      => 'success',
    'published'   => 'success',
    'completed'   => 'success',
    'approved'    => 'success',
    'inactive'    => 'secondary',
    'archived'    => 'secondary',
    'secondary'   => 'secondary',
    'draft'       => 'warning',
    'unapproved'  => 'warning',
    'pending'     => 'warning',
    'reviewing'   => 'warning',
    'processing'  => 'info',
    'started'     => 'info',
    'failed'      => 'danger',
    'rejected'    => 'danger',
    'cancelled'   => 'danger',
  }

  variant = variant_map[status.to_s.downcase] || 'secondary'

  size_classes = {
    'sm' => 'small',
    'md' => '',
    'lg' => 'fs-6'
  }

  size_class = size_classes[size] || ''
%>

<span class="badge text-bg-<%= variant %> <%= size_class %>"><%= label %></span>
