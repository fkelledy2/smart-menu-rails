<%
  status ||= local_assigns[:status]
  label ||= local_assigns[:label] || status.to_s.titleize
  size ||= local_assigns[:size] || 'md'

  variant_map = {
    'active'                => 'success',
    'published'             => 'success',
    'completed'             => 'success',
    'approved'              => 'success',
    'linked'                => 'success',
    'on'                    => 'success',
    'resolved'              => 'success',
    'inactive'              => 'secondary',
    'ignored'               => 'secondary',
    'archived'              => 'secondary',
    'secondary'             => 'secondary',
    'expired'               => 'secondary',
    'lost'                  => 'secondary',
    'off'                   => 'secondary',
    'draft'                 => 'warning',
    'unapproved'            => 'warning',
    'pending'               => 'warning',
    'reviewing'             => 'warning',
    'received'              => 'warning',
    'unlinked'              => 'warning',
    'conditional'           => 'warning',
    'processing'            => 'info',
    'started'               => 'info',
    'soft_verified'         => 'info',
    'actioned_unpublished'  => 'info',
    'contacted'             => 'info',
    'booked'                => 'primary',
    'failed'                => 'danger',
    'rejected'              => 'danger',
    'cancelled'             => 'danger',
    'revoked'               => 'danger',
  }

  variant = variant_map[status.to_s.downcase] || 'secondary'

  size_classes = {
    'sm' => 'small',
    'md' => '',
    'lg' => 'fs-6'
  }

  size_class = size_classes[size] || ''
%>

<span class="badge text-bg-<%= variant %> <%= size_class %>"><%= label %></span>
