<%
  # Resource List Component 2025
  # Modern, consistent list view for any entity
  #
  # Usage:
  # <%= render 'shared/resource_list_2025',
  #   title: 'Menus',
  #   items: @menus,
  #   columns: [
  #     { key: :name, label: 'Name', primary: true },
  #     { key: :status, label: 'Status', type: :badge },
  #     { key: :updated_at, label: 'Modified', type: :date }
  #   ],
  #   actions: [
  #     { label: '+ New Menu', path: new_menu_path, class: 'btn btn-primary' }
  #   ]
  #
%>

  title ||= local_assigns[:title] || 'Items'
  items ||= local_assigns[:items] || []
  columns ||= local_assigns[:columns] || []
  actions ||= local_assigns[:actions] || []
  searchable ||= local_assigns[:searchable] || true
  selectable ||= local_assigns[:selectable] || true
  empty_message ||= local_assigns[:empty_message] || "No #{title.downcase} found"
  empty_description ||= local_assigns[:empty_description] || "Get started by creating your first item"
  empty_action ||= local_assigns[:empty_action]
%>

<div class="resource-list">
  <!-- Header -->
  <div class="resource-list-header">
    <div>
      <h2 class="resource-list-title"><%= title %></h2>
      <p class="resource-list-subtitle"><%= pluralize(items.count, 'item') %></p>
    </div>

    <div class="resource-list-actions">
      <% if searchable %>
        <input type="search"
               placeholder="Search <%= title.downcase %>..."
               class="form-control"
               style="width: 300px;"
               autocomplete="off">
      <% end %>

      <% actions.each do |action| %>
        <%= link_to action[:label], action[:path], class: action[:class] || 'btn btn-primary' %>
      <% end %>
    </div>
  </div>

  <!-- Filters (if needed) -->
  <% if local_assigns[:filters] %>
    <div class="resource-list-filters">
      <%= filters %>
    </div>
  <% end %>

  <!-- Table -->
  <% if items.any? %>
    <div class="resource-list-table">
      <!-- Header Row -->
      <div class="resource-list-row resource-list-header-row">
        <% if selectable %>
          <div class="resource-list-cell">
            <input type="checkbox" id="select-all" class="form-check-input">
          </div>
        <% end %>

        <% columns.each do |column| %>
          <div class="resource-list-cell <%= 'resource-list-cell-primary' if column[:primary] %>">
            <%= column[:label] %>
          </div>
        <% end %>

        <div class="resource-list-cell resource-list-cell-actions">
          Actions
        </div>
      </div>

      <!-- Data Rows -->
      <% items.each do |item| %>
        <div class="resource-list-row" data-id="<%= item.id %>">
          <% if selectable %>
            <div class="resource-list-cell">
              <input type="checkbox" value="<%= item.id %>" class="form-check-input item-checkbox">
            </div>
          <% end %>

          <% columns.each do |column| %>
            <div class="resource-list-cell <%= 'resource-list-cell-primary' if column[:primary] %>">
              <% value = item.send(column[:key]) %>

              <% if column[:type] == :badge %>
                <%= render 'shared/status_badge', status: value %>
              <% elsif column[:type] == :date %>
                <%= time_ago_in_words(value) %> ago
              <% elsif column[:type] == :currency %>
                <%= number_to_currency(value) %>
              <% elsif column[:link] %>
                <%= link_to value, column[:link].call(item), class: 'resource-list-link' %>
              <% else %>
                <%= value %>
              <% end %>
            </div>
          <% end %>

          <div class="resource-list-cell resource-list-cell-actions">
            <% dropdown_items = if local_assigns[:item_actions]
              item_actions.map do |action|
                {
                  label: action[:label],
                  href: action[:path].call(item),
                  method: action[:method],
                  class: action[:class],
                  data: action[:data]
                }
              end
            else
              [
                { label: 'Edit', href: [:edit, item] },
                { label: 'Delete', href: item, method: :delete, class: 'text-danger', data: { turbo_confirm: 'Are you sure?' } }
              ]
            end %>

            <%= render 'shared/actions_dropdown',
                aria_label: 'Actions',
                button_class: 'btn btn-sm btn-outline-secondary',
                items: dropdown_items %>
          </div>
        </div>
      <% end %>
    </div>

    <!-- Footer -->
    <div class="resource-list-footer">
      <span class="text-sm text-gray-500">
        Showing <%= items.count %> <%= title.downcase %>
      </span>
    </div>
  <% else %>
    <!-- Empty State -->
    <div class="resource-list-empty">
      <div class="resource-list-empty-icon">
        <i class="bi bi-inbox fs-icon-xl text-muted" aria-hidden="true"></i>
      </div>
      <h3 class="resource-list-empty-title"><%= empty_message %></h3>
      <p class="resource-list-empty-description"><%= empty_description %></p>
      <% if empty_action %>
        <%= link_to empty_action[:label], empty_action[:path], class: 'btn btn-primary mt-4' %>
      <% end %>
    </div>
  <% end %>
</div>
