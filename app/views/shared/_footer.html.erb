  <footer class="container-fluid py-2 my-0 border-top">
    <div class="row align-items-center">
      <div class="col-auto">
        <%= link_to root_path, class: "navbar-brand" do %>
          <%= image_tag "qr-icon.svg", height: '48' %>
        <% end %>
      </div>

      <div class="col d-flex flex-column align-items-end gap-1">
        <ul class="nav justify-content-end mb-0">
          <% if @current_user && @current_user.plan %>
            <% plan_key = @current_user.plan.key.to_s %>
            <li class="nav-item">
              <small class="px-2 text-muted"><%= t(".plan") %>: <%= plan_key.present? ? t(plan_key, default: plan_key) : '-' %></small>
            </li>
          <% end %>
          <li class="nav-item"><small><%= link_to t(".terms"), terms_path, class: "px-2 text-muted" %></small></li>
          <li class="nav-item"><small><%= link_to t(".privacy"), privacy_path, class: "px-2 text-muted" %></small></li>
        </ul>

        <% unless current_user %>
          <div class="d-flex align-items-center justify-content-end gap-2">
            <% if build_number.present? %>
              <span class="text-muted fs-build"><%= build_number %></span>
            <% end %>
            <ul class="nav mb-0">
              <li class="nav-item"><a href="#" class="px-1 text-muted" aria-label="<%= t('shared.footer.facebook') %>"><i class="bi bi-facebook"></i></a></li>
              <li class="nav-item"><a href="#" class="px-1 text-muted" aria-label="<%= t('shared.footer.instagram') %>"><i class="bi bi-instagram"></i></a></li>
              <li class="nav-item"><a href="#" class="px-1 text-muted" aria-label="<%= t('shared.footer.twitter') %>"><i class="bi bi-twitter-x"></i></a></li>
              <li class="nav-item"><a href="#" class="px-1 text-muted" aria-label="<%= t('shared.footer.linkedin') %>"><i class="bi bi-linkedin"></i></a></li>
            </ul>
          </div>
        <% else %>
          <% if build_number.present? %>
            <div class="text-end">
              <span class="text-muted fs-build"><%= build_number %></span>
            </div>
          <% end %>
        <% end %>
    </div>
  </footer>
