  <footer class="container-fluid py-2 my-0 border-top">
    <div class="row align-items-center">
      <div class="col-auto">
        <%= link_to root_path, class: "navbar-brand" do %>
          <%= image_tag "qr-icon.svg", height: '48' %>
        <% end %>
        <span class="max-height-40"><%= render 'shared/notices' %></span>
      </div>

      <div class="col d-flex flex-column align-items-end gap-1">
        <ul class="nav justify-content-end mb-0">
          <% if @current_user && @current_user.plan %>
            <% plan_key = @current_user.plan.key.to_s %>
            <li class="nav-item">
              <small class="px-2 text-muted"><%= t(".plan") %>: <%= plan_key.present? ? t(plan_key, default: plan_key) : '-' %></small>
            </li>
          <% end %>
          <li class="nav-item"><small><%= link_to t(".terms"), terms_path, class: "px-2 text-muted" %></small></li>
          <li class="nav-item"><small><%= link_to t(".privacy"), privacy_path, class: "px-2 text-muted" %></small></li>
        </ul>

        <% unless current_user %>
          <ul class="nav justify-content-end mb-0">
            <li class="nav-item"><a href="#" aria-label="<%= t('shared.footer.facebook') %>"><i class="px-2 text-muted fab fa-facebook"></i></a></li>
            <li class="nav-item"><a href="#" aria-label="<%= t('shared.footer.instagram') %>"><i class="px-2 text-muted fab fa-instagram"></i></a></li>
            <li class="nav-item"><a href="#" aria-label="<%= t('shared.footer.twitter') %>"><i class="px-2 text-muted fab fa-twitter"></i></a></li>
            <li class="nav-item"><a href="#" aria-label="<%= t('shared.footer.linkedin') %>"><i class="px-2 text-muted fab fa-linkedin"></i></a></li>
          </ul>
        <% end %>
      </div>

      <% if build_number.present? %>
        <div class="col-12 text-end mt-1">
          <small class="text-muted"><%= t(".build") %>: <%= build_number %></small>
        </div>
      <% end %>
    </div>
  </footer>
