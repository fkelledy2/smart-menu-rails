<% flash_type_map = { 'notice' => 'success', 'alert' => 'danger', 'error' => 'danger', 'warning' => 'warning', 'info' => 'info' } %>
<% flash.each do |msg_type, message| %>
  <% bg_class = "text-bg-#{flash_type_map.fetch(msg_type.to_s, 'secondary')}" %>
  <div class="toast align-items-center <%= bg_class %> border-0" role="alert" aria-live="assertive" aria-atomic="true">
    <div class="d-flex">
      <div class="toast-body"><%= message %></div>
      <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" aria-label="Close"></button>
    </div>
  </div>
<% end %>
