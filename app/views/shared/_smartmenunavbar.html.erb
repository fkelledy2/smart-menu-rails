<% if current_user != true_user %>
  <div class="alert alert-warning text-center">
    <%= t('shared.navbar.impersonated_as') %> <b><%= current_user.name %> (<%= current_user.email %>)</b>
    <%= button_to admin_impersonation_path,
          method: :delete,
          form: { class: 'd-inline', data: { testid: 'stop-impersonation-form' } },
          class: 'btn btn-link p-0 align-baseline',
          data: { testid: 'stop-impersonation-btn' } do %><i class="fas fa-times" aria-hidden="true"></i> <%= t('shared.navbar.logout') %> <% end %>
  </div>
<% end %>

<nav class="p-0 navbar navbar-expand-md navbar-light bg-light">
  <div class="container-fluid mx-auto">
    <%= link_to root_path, class: "navbar-brand d-flex align-items-center gap-2", style: "text-decoration:none;" do %>
        <%= image_tag "qr-icon.svg", height:'56' %>
        <span class="sm-text-logo">
          <span class="sm-text-logo__title">mellow.menu</span>
          <span class="sm-text-logo__tagline">menu's only smarter</span>
        </span>
    <% end %>
    <div class="d-flex align-items-center" data-controller="theme-toggle">
      <button type="button" class="theme-toggle-btn" data-action="click->theme-toggle#toggle" title="Toggle theme" data-testid="theme-toggle-btn">
        <i class="bi bi-circle-half" data-theme-toggle-target="icon"></i>
      </button>
    </div>
  </div>
</nav>
