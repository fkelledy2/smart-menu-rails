<div class="page-header">
  <h4>New Profit Margin Target</h4>
</div>

<div class="row">
  <div class="col-md-8">
    <%= form_with(model: @target, url: restaurant_profit_margin_targets_path(@restaurant), local: true) do |form| %>
      <div class="mb-3">
        <%= form.label :target_level, 'Target Level', class: 'form-label' %>
        <%= form.select :target_level, 
            [['Restaurant-wide', 'restaurant'], ['Menu Section', 'menusection'], ['Individual Item', 'menuitem']],
            {}, 
            class: 'form-select',
            id: 'target_level_select',
            onchange: 'updateTargetLevelFields(this.value)' %>
      </div>

      <div id="restaurant_field">
        <%= form.hidden_field :restaurant_id, value: @restaurant.id %>
      </div>

      <div id="menusection_field" style="display: none;">
        <div class="mb-3">
          <%= form.label :menusection_id, 'Menu Section', class: 'form-label' %>
