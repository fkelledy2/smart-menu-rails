<div class="container mt-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3 mb-0">Margin Targets</h1>
    <%= link_to 'New Target', new_restaurant_profit_margin_target_path(@restaurant),
        class: 'btn btn-primary btn-sm' %>
  </div>

  <% if @targets.any? %>
    <div class="table-responsive">
      <table class="table table-hover align-middle">
        <thead class="table-light">
          <tr>
            <th>Scope</th>
            <th class="text-end">Target %</th>
            <th class="text-end">Minimum %</th>
            <th>Effective From</th>
            <th>Effective To</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          <% @targets.each do |target| %>
            <tr>
              <td>
                <% if target.menuitem_id %>
                  <span class="badge bg-secondary me-1">Item</span>
                  <%= target.menuitem&.name %>
                <% elsif target.menusection_id %>
                  <span class="badge bg-info text-dark me-1">Section</span>
                  <%= target.menusection&.name %>
                <% else %>
                  <span class="badge bg-primary me-1">Restaurant</span>
                  Restaurant-wide
                <% end %>
              </td>
              <td class="text-end fw-semibold"><%= number_to_percentage(target.target_margin_percentage, precision: 1) %></td>
              <td class="text-end text-muted"><%= target.minimum_margin_percentage ? number_to_percentage(target.minimum_margin_percentage, precision: 1) : '—' %></td>
              <td><%= target.effective_from&.strftime('%b %d, %Y') %></td>
              <td><%= target.effective_to&.strftime('%b %d, %Y') || '—' %></td>
              <td class="text-end">
                <%= link_to 'Edit',
                    edit_restaurant_profit_margin_target_path(@restaurant, target),
                    class: 'btn btn-xs btn-outline-secondary me-1' %>
                <%= link_to 'Delete',
                    restaurant_profit_margin_target_path(@restaurant, target),
                    class: 'btn btn-xs btn-outline-danger',
                    data: { turbo_method: :delete, turbo_confirm: 'Delete this target?' } %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% else %>
    <div class="text-center py-5 text-muted">
      <i class="bi bi-bullseye fs-1 d-block mb-3"></i>
      <p class="mb-3">No margin targets yet.</p>
      <%= link_to 'Set your first target', new_restaurant_profit_margin_target_path(@restaurant),
          class: 'btn btn-outline-primary' %>
    </div>
  <% end %>
</div>
