<%= turbo_frame_tag 'inline_target_form' do %>
  <div class="card mb-3">
    <div class="card-header fw-semibold">Edit Margin Target</div>
    <div class="card-body">
      <%= form_with(model: @target,
                    url: restaurant_profit_margin_target_path(@restaurant, @target),
                    method: :patch,
                    local: true,
                    data: { turbo_frame: 'restaurant_content' }) do |form| %>
        <% if @target.errors.any? %>
          <div class="alert alert-danger py-2">
            <ul class="mb-0 ps-3">
              <% @target.errors.full_messages.each do |msg| %>
                <li class="small"><%= msg %></li>
              <% end %>
            </ul>
          </div>
        <% end %>

        <div class="row g-3 mb-3">
          <div class="col-6">
            <%= form.label :target_margin_percentage, 'Target %', class: 'form-label form-label-sm' %>
            <%= form.number_field :target_margin_percentage, class: 'form-control form-control-sm', step: 0.1, min: 0, max: 100, required: true %>
          </div>
          <div class="col-6">
            <%= form.label :minimum_margin_percentage, 'Minimum %', class: 'form-label form-label-sm' %>
            <%= form.number_field :minimum_margin_percentage, class: 'form-control form-control-sm', step: 0.1, min: 0, max: 100 %>
          </div>
          <div class="col-6">
            <%= form.label :effective_from, 'From', class: 'form-label form-label-sm' %>
            <%= form.date_field :effective_from, class: 'form-control form-control-sm', required: true %>
          </div>
          <div class="col-6">
            <%= form.label :effective_to, 'To (optional)', class: 'form-label form-label-sm' %>
            <%= form.date_field :effective_to, class: 'form-control form-control-sm' %>
          </div>
        </div>

        <div class="d-flex gap-2">
          <%= form.submit 'Update Target', class: 'btn btn-sm btn-primary' %>
          <%= link_to 'Cancel',
              edit_restaurant_path(@restaurant, section: 'profitability_targets'),
              class: 'btn btn-sm btn-outline-secondary',
              data: { turbo_frame: 'restaurant_content', turbo_action: 'advance' } %>
        </div>
      <% end %>
    </div>
  </div>
<% end %>
