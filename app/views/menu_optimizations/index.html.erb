});

function applySelectedOpfunction applySelectest selected = Array.from(document.querySelectorAll('.action-checkbox:checked'))
    .map(cb => cb.dataset.actionId);
  
  if (selected.length === 0) {
    alert('Please select at least one action to apply');
    return;
  }
  
  if (confirm(`Apply ${selected.length} optimization(s)?`)) {
    fetch('<%= restaurant_menu_optimizations_apply_path(@restaurant) %>', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'X-CSRF-Token': document.querySelector('[name="csrf-token"]').content
      },
      body: JSON.stringify({ selected_actions: selected })
    }).then(response => {
      if (response.ok) {
        window.location.reload();
      }
    });
  }
}
</script>
