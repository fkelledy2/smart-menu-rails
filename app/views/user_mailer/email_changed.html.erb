<h1 style="margin: 0 0 16px 0; font-size: 24px; font-weight: 700; color: #111827; line-height: 1.3;">
  Email address update
</h1>

<p style="margin: 0 0 16px 0; font-size: 16px; color: #374151; line-height: 1.6;">
  Hi <strong><%= @email %></strong>,
</p>

<% if @resource.try(:unconfirmed_email?) %>
  <p style="margin: 0 0 16px 0; font-size: 16px; color: #374151; line-height: 1.6;">
    We're letting you know that a request has been made to change the email address on your Mellow Menu account to <strong><%= @resource.unconfirmed_email %></strong>.
  </p>
  <p style="margin: 0 0 0 0; font-size: 16px; color: #374151; line-height: 1.6;">
    You'll receive a confirmation email at the new address before the change takes effect.
  </p>
<% else %>
  <p style="margin: 0 0 0 0; font-size: 16px; color: #374151; line-height: 1.6;">
    The email address on your Mellow Menu account has been successfully changed to <strong><%= @resource.email %></strong>.
  </p>
<% end %>

<p style="margin: 32px 0 0 0; font-size: 13px; color: #6B7280; line-height: 1.6;">
  If you did not make this change, please <a href="https://www.mellow.menu/#contact" style="color: #2563EB; text-decoration: none;">contact us</a> immediately.
</p>
