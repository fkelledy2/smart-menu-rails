<div class="pt-4 border-top first:pt-0" data-controller="menu-section" data-menu-section-section-id="<%= section.id %>">
  <div class="d-flex align-items-center justify-content-between">
    <div class="flex-grow-1">
      <h3 class="h6 mb-1 fw-semibold"><%= section.name %></h3>
      <% if section.description.present? %>
        <p class="mt-1 text-muted small mb-0"><%= section.description %></p>
      <% end %>
    </div>
    <div class="ms-3 flex-shrink-0">
      <button type="button"
              data-action="menu-section#toggleItems"
              class="btn btn-link btn-sm p-0 fw-medium">
        <span data-menu-section-target="toggleText"><%= t('.hide') %></span> <%= t('.items') %>
      </button>
    </div>
  </div>

  <div class="mt-3" data-menu-section-target="itemsContainer">
    <div class="bg-white shadow-sm overflow-hidden rounded">
      <ul class="list-group list-group-flush">
        <% section.ocr_menu_items.ordered.each do |item| %>
          <li class="list-group-item px-3 py-3">
            <div class="d-flex align-items-center justify-content-between">
              <div class="flex-grow-1 min-w-0">
                <div class="d-flex align-items-center gap-2 flex-wrap">
                  <span class="fw-medium text-primary text-truncate"><%= item.name %></span>
                  <% if item.price.present? %>
                    <span class="badge bg-primary bg-opacity-10 text-primary border border-primary border-opacity-25">
                      <%= number_to_currency(item.price) %>
                    </span>
                  <% end %>
                </div>
                <% if item.description.present? %>
                  <p class="mt-1 text-muted small mb-0"><%= item.description %></p>
                <% end %>

                <% if item.allergens.present? || item.dietary_restrictions.present? %>
                  <div class="mt-2 d-flex flex-wrap gap-1">
                    <% if item.allergens.present? %>
                      <% item.allergens.each do |allergen| %>
                        <span class="badge bg-danger bg-opacity-10 text-danger border border-danger border-opacity-25">
                          <%= allergen %>
                        </span>
                      <% end %>
                    <% end %>

                    <% if item.dietary_restrictions.present? %>
                      <% item.dietary_restrictions.each do |restriction| %>
                        <span class="badge bg-success bg-opacity-10 text-success border border-success border-opacity-25">
                          <%= restriction.humanize %>
                        </span>
                      <% end %>
                    <% end %>
                  </div>
                <% end %>
              </div>
              <div class="ms-3 flex-shrink-0">
                <button type="button"
                        class="btn btn-link btn-sm p-0 text-muted fw-medium"
                        data-action="click->menu-import#editItem"
                        data-item-id="<%= item.id %>"
                        data-item-name="<%= item.name %>"
                        data-item-description="<%= item.description %>"
                        data-item-price="<%= item.price %>"
                        data-item-allergens="<%= item.allergens.to_json %>"
                        data-item-dietary-restrictions="<%= item.dietary_restrictions.to_json %>">
                  <%= t('.edit') %>
                </button>
              </div>
            </div>
          </li>
        <% end %>
      </ul>
    </div>
  </div>
</div>
