<%= form_with(model: smartmenu) do |form| %>
  <% if smartmenu.errors.any? %>
    <div class="alert alert-danger mb-3" role="alert">
      <div class="fw-semibold mb-1"><%= pluralize(smartmenu.errors.count, 'error') %> prohibited this smartmenu from being saved:</div>
      <ul class="mb-0">
        <% smartmenu.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="mb-3">
    <%= form.label :slug, class: 'form-label' %>
    <%= form.text_field :slug, class: 'form-control' %>
  </div>

  <div class="mb-3">
    <%= form.label :restaurant_id, class: 'form-label' %>
    <%= form.text_field :restaurant_id, class: 'form-control' %>
  </div>

  <div class="mb-3">
    <%= form.label :menu_id, class: 'form-label' %>
    <%= form.text_field :menu_id, class: 'form-control' %>
  </div>

  <div class="mb-3">
    <%= form.label :tablesetting_id, class: 'form-label' %>
    <%= form.text_field :tablesetting_id, class: 'form-control' %>
  </div>

  <div class="d-flex justify-content-end gap-2 align-items-center">
    <% if smartmenu.persisted? %>
      <%= button_to t('common.delete'), smartmenu, method: :delete, class: 'btn btn-link text-danger p-0', data: { turbo_confirm: t('common.confirm') } %>
    <% end %>

    <%= form.submit value: t('common.save'), class: 'btn btn-dark' %>

    <% if smartmenu.persisted? %>
      <%= link_to t('common.cancel'), smartmenu, class: 'btn btn-link' %>
    <% else %>
      <%= link_to t('common.cancel'), smartmenus_path, class: 'btn btn-link' %>
    <% end %>
  </div>
<% end %>
