<div class="col-12 col-sm-6 col-md-4 col-lg-4 menu-item-card" data-name="<%= menuitem.name.to_s.downcase %>" data-description="<%= menuitem.description.to_s.downcase %>" data-testid="menu-item-<%= menuitem.id %>" data-controller="quick-add">
   <% if !order || ( order.status != 'billrequested' && order.status != 'closed' ) %>
     <div class="staff-item-row">
       <div class="staff-item-name">
         <div class="d-flex align-items-center gap-2 mb-2">
           <button type="button" class="btn btn-outline-secondary btn-sm" data-action="click->quick-add#decrement" data-quick-add-target="decrement" aria-label="Decrease quantity">-</button>
           <input type="number" class="form-control form-control-sm text-center" value="1" min="1" max="99" step="1" inputmode="numeric" data-action="input->quick-add#syncInput change->quick-add#syncInput" data-quick-add-target="input" style="max-width: 5rem;">
           <span class="fw-semibold" data-quick-add-target="qty">1</span>
           <button type="button" class="btn btn-outline-secondary btn-sm" data-action="click->quick-add#increment" aria-label="Increase quantity">+</button>
         </div>
         <div class="btn-group">
           <button type="button" class="addItemToOrder btn btn-sm btn-dark" data-bs-toggle="modal" data-bs-target="#addItemToOrderModal"
               data-bs-menusection_from_offset="<%= menuitem.menusection.fromOffset %>"
               data-bs-menusection_to_offset="<%= menuitem.menusection.toOffset %>"
               data-bs-ordr_id="<%= order&.id %>"
               data-bs-menuitem_id="<%= menuitem.id %>"
               data-bs-menuitem_name="<%= menuitem.name %>"
               data-bs-menuitem_price="<%= menuitem.price %>"
               data-bs-menuitem_description="<%= menuitem.description %>"
               data-bs-menuitem_image="<%= menuitem.optimised_modal_url %>"
               data-action="click->quick-add#storeQty"
               data-testid="add-item-btn-<%= menuitem.id %>">
                 <%= menuitem.name %>
           </button>
           <% if menuitem.menuitem_size_mappings.any? %>
             <button type="button" class="addItemToOrder btn btn-sm btn-dark dropdown-toggle dropdown-toggle-split max-w-50px" data-bs-toggle="dropdown" aria-expanded="false"
                 data-bs-menusection_from_offset="<%= menuitem.menusection.fromOffset %>"
                 data-bs-menusection_to_offset="<%= menuitem.menusection.toOffset %>">
               <span class="visually-hidden">Toggle Dropdown</span>
             </button>
             <ul class="dropdown-menu">
               <% menuitem.menuitem_size_mappings.each do |menuitemsize| %>
                 <li>
                   <a class="dropdown-item" href="#">
                     <button type="button" class="addItemToOrder btn-reset" data-bs-toggle="modal" data-bs-target="#addItemToOrderModal"
                         data-bs-menusection_from_offset="<%= menuitem.menusection.fromOffset %>"
                         data-bs-menusection_to_offset="<%= menuitem.menusection.toOffset %>"
                         data-bs-ordr_id="<%= order&.id %>"
                         data-bs-menuitem_id="<%= menuitem.id %>"
                         data-bs-menuitem_name="<%= menuitem.name %>"
                         data-bs-menuitem_price="<%= menuitemsize.price %>"
                         data-bs-menuitem_description="<%= menuitem.description %> (<%= menuitemsize.size.name %>)"
                         data-bs-menuitem_image="<%= menuitem.optimised_modal_url %>"
                         data-action="click->quick-add#storeQty">
                           <i class="bi bi-plus"></i> <%= menuitemsize.size.name %>
                     </button>
                   </a>
                 </li>
               <% end %>
             </ul>
           <% end %>
         </div>
       </div>
     </div>
   <% else %>
     <div class="staff-item-row staff-item-row-disabled">
       <div class="staff-item-name">
         <div class="d-flex align-items-center gap-2 mb-2">
           <button type="button" class="btn btn-outline-secondary btn-sm" disabled aria-label="Decrease quantity">-</button>
           <input type="number" class="form-control form-control-sm text-center" value="1" min="1" max="99" step="1" inputmode="numeric" disabled style="max-width: 5rem;">
           <span class="fw-semibold">1</span>
           <button type="button" class="btn btn-outline-secondary btn-sm" disabled aria-label="Increase quantity">+</button>
         </div>
         <div class="btn-group">
           <button class="btn btn-sm btn-dark" disabled>
             <%= menuitem.name %>
           </button>
           <% if menuitem.menuitem_size_mappings.any? %>
             <button class="btn btn-sm btn-dark dropdown-toggle dropdown-toggle-split max-w-50px" data-bs-toggle="dropdown" aria-expanded="false" disabled>
               <span class="visually-hidden">Toggle Dropdown</span>
             </button>
             <ul class="dropdown-menu">
               <% menuitem.menuitem_size_mappings.each do |menuitemsize| %>
                 <li>
                   <a class="dropdown-item" href="#">
                     <button class="btn-reset" disabled>
                       <i class="bi bi-plus"></i> <%= menuitemsize.size.name %>
                     </button>
                   </a>
                 </li>
               <% end %>
             </ul>
           <% end %>
         </div>
       </div>
     </div>
   <% end %>
 </div>
