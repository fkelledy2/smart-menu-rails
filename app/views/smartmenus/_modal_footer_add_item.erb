<div class="modal-footer flex-column" id="a2o_footer">
  <div class="d-flex align-items-center justify-content-center gap-2 w-100 mb-2" id="a2o_qty_controls">
    <button type="button" class="btn btn-outline-secondary btn-sm" id="a2o_qty_decr" aria-label="<%= t('smartmenus.showModals.decrease_qty', default: 'Decrease quantity') %>">
      <i class="bi bi-dash" aria-hidden="true"></i>
    </button>
    <input type="number" class="form-control form-control-sm text-center" id="a2o_qty_input" value="1" min="1" max="99" step="1" inputmode="numeric" style="max-width: 5rem;">
    <button type="button" class="btn btn-outline-secondary btn-sm" id="a2o_qty_incr" aria-label="<%= t('smartmenus.showModals.increase_qty', default: 'Increase quantity') %>">
      <i class="bi bi-plus" aria-hidden="true"></i>
    </button>
  </div>
  <div class="d-flex gap-2 w-100">
    <button type="button" class="btn btn-outline-secondary flex-fill" data-bs-dismiss="modal" aria-label="<%= t('common.close') %>"><%= t('smartmenus.showModals.cancel') %></button>
    <button id="addItemToOrderButton" type="button" class="btn btn-primary flex-fill">
      <i class="bi bi-plus" aria-hidden="true"></i>
      <%= restaurantCurrency.symbol ? restaurantCurrency.symbol : "" %><span id="a2o_menuitem_price"></span>
    </button>
  </div>
</div>
