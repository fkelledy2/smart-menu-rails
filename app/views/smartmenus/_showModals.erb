<div id="modalsContainer">

    <%# Start Order modal — staff/admin only (customers use the bottom sheet) %>
    <% if current_user || current_employee %>
    <div class="modal fade" id="openOrderModal" tabindex="-1" aria-labelledby="openOrderModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-scrollable modal-dialog-centered modal-fullscreen-sm-down">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="openOrderModalLabel"><%= t(".startOrder") %></h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="<%= t('common.close') %>"></button>
                </div>
                <div class="modal-body">
                    <% if tablesetting %>
                        <div class="d-flex flex-column gap-3">
                            <div class="text-center">
                                <div class="fs-4 fw-bold"><%= t(".partySize") %></div>
                            </div>

                            <div class="d-flex align-items-center justify-content-center gap-3">
                                <button type="button" class="btn btn-outline-secondary btn-lg" id="orderCapacityDecrement">-</button>
                                <div class="text-center order-capacity-value">
                                    <div id="orderCapacityValue" class="display-4 mb-0">1</div>
                                </div>
                                <button type="button" class="btn btn-outline-secondary btn-lg" id="orderCapacityIncrement">+</button>
                            </div>

                            <input type="hidden" id="orderCapacity" value="1" data-min="1" data-max="<%= tablesetting.capacity %>">

                            <div class="d-flex flex-wrap justify-content-center gap-2">
                                <button type="button" class="btn btn-outline-primary orderCapacityPreset" data-capacity="1">1</button>
                                <% if tablesetting.capacity.to_i >= 2 %>
                                    <button type="button" class="btn btn-outline-primary orderCapacityPreset" data-capacity="2">2</button>
                                <% end %>
                                <% if tablesetting.capacity.to_i >= 4 %>
                                    <button type="button" class="btn btn-outline-primary orderCapacityPreset" data-capacity="4">4</button>
                                <% end %>
                                <% if tablesetting.capacity.to_i >= 6 %>
                                    <button type="button" class="btn btn-outline-primary orderCapacityPreset" data-capacity="6">6</button>
                                <% end %>
                                <button type="button" class="btn btn-outline-primary orderCapacityPreset" data-capacity="<%= tablesetting.capacity %>">Full (<%= tablesetting.capacity %>)</button>
                            </div>
                        </div>
                    <% end %>
                </div>
                <div class="modal-footer gap-2">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal" aria-label="<%= t('common.close') %>"><%= t(".cancel") %></button>
                    <button id="start-order" type="button" data-bs-dismiss="modal" class="btn btn-primary"><%= t(".start") %></button>
                </div>
            </div>
        </div>
    </div>
    <% end %>

    <div class="modal fade" id="addItemToOrderModal" tabindex="-1" aria-labelledby="addItemToOrderModalLabel" aria-hidden="true">
      <div class="modal-dialog modal-dialog-scrollable modal-dialog-centered modal-fullscreen-sm-down">
        <div class="modal-content">
          <%= render partial: "smartmenus/modal_header_add_item" %>
          <div class="modal-body p-0">
                <% if (menu.displayImages == true && menu.restaurant.displayImages == true) || (menu.displayImagesInPopup == true && menu.restaurant.displayImagesInPopup == true) %>
                    <div class="row">
                        <div class="col-12">
                            <div class="image-container position-relative">
                                <!-- Placeholder image (same size as final image) -->
                                <img id="placeholder" src="https://placehold.co/600x400/white/white" class="w-100" style="visibility: visible;">
                                <!-- Spinner overlay -->
                                <div id="spinner" class="position-absolute top-50 start-50 translate-middle">
                                    <div class="spinner-border text-primary"></div>
                                </div>
                                <%= image_tag "",
                                    :id => "a2o_menuitem_image",
                                    :title => "",
                                    :class => "addItemToOrderImage card-img-top",
                                    :style => "display:none; position:absolute; top:0; left:0; width:100%;"
                                %>
                            </div>
                        </div>
                    </div>
                    <div class="mt-3"></div>
            <% end %>
            <span style="display:none" id="a2o_ordr_id"></span>
            <span style="display:none" id="a2o_menuitem_id"></span>
            <span style="display:none" id="a2o_size_name"></span>
            <div class="row px-3">
                <div class="col-12">
                    <span class="h4" id="a2o_menuitem_name"></span>
                </div>
            </div>
            <div class="row px-3">
                <div class="col-12">
                    <span id="a2o_menuitem_description"></span>
                </div>
            </div>
            <div class="row px-3 mt-3">
                <div class="col-12">
                    <label for="a2o_item_note" class="form-label"><%= t('smartmenus.showModals.special_requests', default: 'Special requests') %></label>
                    <textarea class="form-control" id="a2o_item_note" rows="2" placeholder="<%= t('smartmenus.showModals.special_requests_placeholder', default: 'e.g., no onions, extra sauce...') %>"></textarea>
                </div>
            </div>
            <div class="row px-3 mt-2" id="a2o_tasting_controls" hidden>
              <div class="col-12 d-flex align-items-center gap-2 flex-wrap">
                <div class="input-group input-group-sm tasting-qty-group">
                  <button class="btn btn-outline-secondary" type="button" id="a2o_tasting_qty_decr" aria-label="<%= t('.decrease') %>">-</button>
                  <input type="number" class="form-control text-center" id="a2o_tasting_qty" value="1" min="1">
                  <button class="btn btn-outline-secondary" type="button" id="a2o_tasting_qty_incr" aria-label="<%= t('.increase') %>">+</button>
                </div>
                <div class="form-check form-check-inline" id="a2o_tasting_pairing_wrap" hidden>
                  <input class="form-check-input" type="checkbox" id="a2o_tasting_pairing">
                  <label class="form-check-label" for="a2o_tasting_pairing"><%= t('.pairing') %></label>
                </div>
              </div>
            </div>
          </div>
          <%= render partial: "smartmenus/modal_footer_add_item", locals: { restaurantCurrency: restaurantCurrency } %>
        </div>
      </div>
    </div>

    <%# filterOrderModal has been merged into the combined allergen modal (#allergenModal) %>
    <%# viewOrderModal removed - all ordering now uses bottom sheet (_cart_bottom_sheet.html.erb) for both customers and staff %>

    <div class="modal fade" id="requestBillModal" tabindex="-1" aria-labelledby="requestBillModalLabel" aria-hidden="true">
      <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
          <div class="modal-header">
            <h5 class="modal-title" id="requestBillModalLabel"><%= t(".requestBill") %></h5>
            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="<%= t('common.close') %>"></button>
          </div>
          <div class="modal-body text-center py-4">
            <i class="bi bi-exclamation-triangle-fill text-warning fs-1 mb-3 d-block"></i>
            <p class="fw-bold mb-2"><%= t('smartmenus.showModals.request_bill_confirm_title', default: 'Are you sure?') %></p>
            <p class="text-muted"><%= t('smartmenus.showModals.request_bill_confirm_body', default: 'Once you request the bill, you will no longer be able to add items to your order.') %></p>
          </div>
          <%= render partial: "smartmenus/modal_footer_primary", locals: { primary_id: 'request-bill-confirm', primary_text: t('.requestBill'), disabled: !(order && order.gross.to_f > 0) } %>
        </div>
      </div>
    </div>

    <%# Pay Bill modal — staff/admin only (customers use the inline bottom sheet pay section) %>
    <% if current_user || current_employee %>
    <div class="modal fade" id="payOrderModal" tabindex="-1" aria-labelledby="payOrderModalLabel" aria-hidden="true" data-controller="order-totals" data-tip-presets="<%= restaurant.tips.sort_by(&:percentage).map(&:percentage).to_json %>" data-currency-symbol="<%= restaurantCurrency.symbol || '' %>">
        <div class="modal-dialog modal-lg modal-dialog-scrollable modal-dialog-centered modal-fullscreen-sm-down">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="payOrderModalLabel"><%= t(".payBill") %></h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="<%= t('common.close') %>"></button>
                </div>
                <div class="modal-body">
                  <% if order %>
                    <% cur = restaurantCurrency.symbol.presence || "" %>
                    <div class="bill-line bill-line-header"><span><b><%= t('.item') %></b></span><span><b><%= t('.price') %></b></span></div>
                    <% if order.covercharge.to_f > 0 %>
                      <div class="bill-line"><span><%= t('.cover_charge') %></span><span class="bill-amount" id="orderCoverCharge"><%= number_to_currency(order.covercharge, unit: cur) %></span></div>
                    <% end %>
                    <div class="bill-line"><span><%= t('.nett') %></span><span class="bill-amount" id="orderNett"><%= number_to_currency(order.nett, unit: cur) %></span></div>
                    <% if order.service.to_f > 0 %>
                      <div class="bill-line"><span><%= t('.service') %></span><span class="bill-amount" id="orderService"><%= number_to_currency(order.service, unit: cur) %></span></div>
                    <% end %>
                    <% if order.tax.to_f > 0 %>
                      <div class="bill-line"><span><%= t('.tax') %></span><span class="bill-amount" id="orderTax"><%= number_to_currency(order.tax, unit: cur) %></span></div>
                    <% end %>
                    <hr>
                    <div class="bill-line bill-line-total"><span><b><%= t('.total') %></b> <i>(<%= t('.excluding_tip') %>)</i></span><span class="bill-amount"><b><%= cur %><span id="orderGross"><%= number_to_currency(order.gross, unit: "") %></span></b></span></div>
                    <div class="bill-tip-row">
                      <div class="d-flex flex-wrap align-items-center justify-content-end gap-2 mt-3 mb-3">
                        <% restaurant.tips.sort_by(&:percentage).each do |tip| %>
                          <button type="button" class="btn-touch-secondary btn-touch-sm tip-preset-btn"><span class="tipPreset"><%= tip.percentage %>%</span></button>
                        <% end %>
                        <input id="tipNumberField" type="number" min="0.00" max="<%= number_to_currency(order.gross, unit: cur) %>" class="form-control form-control-sm text-end tip-number-input" value="0.00">
                      </div>
                    </div>
                    <hr>
                    <div class="bill-line bill-line-total"><span><b><%= t('.total') %></b> <i>(<%= t('.including_tip') %>)</i></span><span class="bill-amount"><b><span id="orderGrandTotal"><%= number_to_currency(order.gross, unit: cur) %></span></b></span></div>

                    <%# Hidden inputs for existing payment JS %>
                    <input type="hidden" id="openOrderId" value="<%= order.id %>">
                    <input type="hidden" id="paymentAmount" value="<%= order.grossInCents %>">
                    <input type="hidden" id="paymentCurrency" value="<%= restaurantCurrency.code %>">
                    <input type="hidden" id="paymentRestaurantName" value="<%= t('.bill_prefix') %> <%= order.restaurant.name %>">
                    <input type="hidden" id="paymentRestaurantId" value="<%= order.restaurant.id %>">

                    <%# Payment method tabs %>
                    <% sq_app_id = restaurant.try(:square_application_id).presence || (defined?(SquareConfig) ? SquareConfig.app_id : '') %>
                    <div class="mt-4"
                         data-controller="collect-payment"
                         data-collect-payment-cash-url-value="<%= payments_cash_restaurant_ordr_path(restaurant, order) %>"
                         data-collect-payment-qr-url-value="<%= payments_checkout_qr_restaurant_ordr_path(restaurant, order) %>"
                         data-collect-payment-amount-cents-value="<%= order.grossInCents %>"
                         data-collect-payment-currency-value="<%= restaurantCurrency.code %>"
                         data-collect-payment-order-id-value="<%= order.id %>"
                         data-collect-payment-square-app-id-value="<%= sq_app_id %>"
                         data-collect-payment-square-pos-available-value="<%= restaurant&.square_provider? ? 'true' : 'false' %>">

                      <ul class="nav nav-pills nav-fill mb-3" role="tablist" id="collectPaymentTabs">
                        <% unless restaurant&.square_provider? && !restaurant&.square_inline? %>
                          <li class="nav-item" role="presentation">
                            <button class="nav-link active" id="collect-card-tab"
                                    data-bs-toggle="tab" data-bs-target="#collect-card-pane"
                                    type="button" role="tab"
                                    aria-controls="collect-card-pane" aria-selected="true">
                              <i class="bi bi-credit-card me-1"></i><%= t('smartmenus.showModals.payment_method_card', default: 'Card') %>
                            </button>
                          </li>
                        <% end %>
                        <li class="nav-item" role="presentation">
                          <button class="nav-link <%= 'active' if restaurant&.square_provider? && !restaurant&.square_inline? %>"
                                  id="collect-qr-tab"
                                  data-bs-toggle="tab" data-bs-target="#collect-qr-pane"
                                  type="button" role="tab"
                                  aria-controls="collect-qr-pane" aria-selected="false"
                                  data-action="click->collect-payment#loadQr">
                            <i class="bi bi-qr-code me-1"></i><%= t('smartmenus.showModals.payment_method_qr', default: 'Customer QR') %>
                          </button>
                        </li>
                        <li class="nav-item" role="presentation">
                          <button class="nav-link"
                                  id="collect-cash-tab"
                                  data-bs-toggle="tab" data-bs-target="#collect-cash-pane"
                                  type="button" role="tab"
                                  aria-controls="collect-cash-pane" aria-selected="false">
                            <i class="bi bi-cash me-1"></i><%= t('smartmenus.showModals.payment_method_cash', default: 'Cash') %>
                          </button>
                        </li>
                        <% if restaurant&.square_provider? %>
                          <li class="nav-item" role="presentation">
                            <button class="nav-link"
                                    id="collect-square-pos-tab"
                                    data-bs-toggle="tab" data-bs-target="#collect-square-pos-pane"
                                    type="button" role="tab"
                                    aria-controls="collect-square-pos-pane" aria-selected="false">
                              <i class="bi bi-phone me-1"></i><%= t('smartmenus.showModals.payment_method_pos', default: 'Square POS') %>
                            </button>
                          </li>
                        <% end %>
                      </ul>

                      <div class="tab-content">
                        <%# Card tab: existing inline payment form (Stripe wallet or Square inline) %>
                        <% unless restaurant&.square_provider? && !restaurant&.square_inline? %>
                          <div class="tab-pane fade show active" id="collect-card-pane" role="tabpanel" aria-labelledby="collect-card-tab">
                            <div class="d-flex flex-column align-items-center gap-3 pt-2">
                              <% if restaurant&.square_provider? && restaurant&.square_inline? %>
                                <%= render partial: 'smartmenus/square_inline_payment',
                                           locals: { order: order, restaurant: restaurant, restaurantCurrency: restaurantCurrency } %>
                              <% else %>
                                <div id="wallet-button-container" data-controller="stripe-wallet" data-stripe-wallet-open-order-id-value="<%= order&.id %>" data-stripe-wallet-amount-cents-value="<%= order&.grossInCents %>" data-stripe-wallet-currency-value="<%= restaurantCurrency.code %>"></div>
                              <% end %>
                            </div>
                          </div>
                        <% end %>

                        <%# QR Code tab: generate hosted checkout link, show as scannable QR %>
                        <div class="tab-pane fade <%= 'show active' if restaurant&.square_provider? && !restaurant&.square_inline? %>"
                             id="collect-qr-pane" role="tabpanel" aria-labelledby="collect-qr-tab">
                          <div class="text-center py-3">
                            <p class="text-muted small mb-3">
                              <%= t('smartmenus.showModals.qr_instructions', default: 'Show this QR code to the customer. They can scan it and pay on their own device.') %>
                            </p>
                            <div data-collect-payment-target="qrSpinner" class="py-3">
                              <div class="spinner-border text-primary" role="status">
                                <span class="visually-hidden">Loading…</span>
                              </div>
                              <p class="text-muted small mt-2"><%= t('smartmenus.showModals.qr_generating', default: 'Generating payment link…') %></p>
                            </div>
                            <div data-collect-payment-target="qrImage" class="d-none mx-auto" style="max-width: 260px;"></div>
                            <div data-collect-payment-target="qrError" class="d-none alert alert-danger small mt-2"></div>
                          </div>
                        </div>

                        <%# Cash tab: one-tap cash confirmation %>
                        <div class="tab-pane fade" id="collect-cash-pane" role="tabpanel" aria-labelledby="collect-cash-tab">
                          <div class="text-center py-4">
                            <p class="text-muted mb-4">
                              <%= t('smartmenus.showModals.cash_instructions', default: 'Confirm that the customer has paid in cash. This will close the order.') %>
                            </p>
                            <button type="button"
                                    class="btn btn-success btn-lg"
                                    data-collect-payment-target="cashButton"
                                    data-action="click->collect-payment#cashPayment">
                              <i class="bi bi-cash-coin me-1"></i><%= t('smartmenus.showModals.cash_confirm_btn', default: 'Mark as Cash Paid') %>
                            </button>
                            <div data-collect-payment-target="cashSpinner" class="d-none mt-3">
                              <div class="spinner-border spinner-border-sm text-success" role="status"></div>
                              <span class="text-muted small ms-2"><%= t('smartmenus.showModals.cash_recording', default: 'Recording…') %></span>
                            </div>
                            <div data-collect-payment-target="cashSuccess" class="d-none alert alert-success mt-3 small">
                              <i class="bi bi-check-circle me-1"></i><%= t('smartmenus.showModals.cash_success', default: 'Cash payment recorded. Order closed.') %>
                            </div>
                          </div>
                        </div>

                        <%# Square POS tab: deep-link into Square POS app for Tap to Pay %>
                        <% if restaurant&.square_provider? %>
                          <div class="tab-pane fade" id="collect-square-pos-pane" role="tabpanel" aria-labelledby="collect-square-pos-tab">
                            <div class="text-center py-4">
                              <p class="text-muted mb-3">
                                <%= t('smartmenus.showModals.square_pos_instructions', default: 'Opens the Square Point of Sale app on this device for Tap to Pay or card-present payment.') %>
                              </p>
                              <button type="button"
                                      class="btn btn-warning btn-lg"
                                      data-collect-payment-target="squarePosButton"
                                      data-action="click->collect-payment#openSquarePos">
                                <i class="bi bi-phone me-1"></i><%= t('smartmenus.showModals.square_pos_btn', default: 'Open Square POS') %>
                              </button>
                              <p class="text-muted small mt-3">
                                <%= t('smartmenus.showModals.square_pos_note', default: 'Requires the Square Point of Sale app installed on this device.') %>
                              </p>
                            </div>
                          </div>
                        <% end %>
                      </div>
                    </div>
                  <% end %>
                </div>
                <%# Footer: only shown when card tab is active — hidden by collect-payment controller for other tabs %>
                <div class="modal-footer gap-2" id="payOrderModalFooter">
                  <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal" aria-label="<%= t('common.close') %>"><%= t('smartmenus.showModals.cancel') %></button>
                  <button id="pay-order-confirm" type="button" class="btn btn-primary" data-bs-dismiss="modal" <%= 'disabled' unless order && order.gross.to_f > 0 %>><%= t('.confirmPayment') %></button>
                </div>
            </div>
        </div>
    </div>
    <% end %>

    <div class="modal fade" id="addNameToParticipantModal" tabindex="-1" aria-labelledby="addNameToParticipantModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-scrollable modal-dialog-centered modal-fullscreen-sm-down">
            <div class="modal-content">
                <div class="modal-header">
                    <h1 class="modal-title fs-5" id="addNameToParticipantModalLabel"><%= t(".customiseOrderWithName") %></h1>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="<%= t('common.close') %>"></button>
                </div>
                <div class="modal-body">
                    <form>
                        <input type="hidden" class="form-control" id="ordr_id">
                          <div class="form-group row">
                            <div class="col-3">
                            <label for="name" class="form-label"><%= t('.name_label') %></label>
                            </div>
                            <div class="col-9">
                            <input type="text" class="form-control" id="name">
                            </div>
                          </div>
                    </form>
                </div>
                <div class="modal-footer gap-2">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal" aria-label="<%= t('common.close') %>"><%= t(".cancel") %></button>
                    <button id="addNameToParticipantButton" type="button" class="btn btn-primary" data-bs-dismiss="modal"><i class="bi bi-plus"></i> <%= t(".add") %></button>
                </div>
            </div>
        </div>
    </div>
</div>