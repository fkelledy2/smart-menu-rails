<span class="menu-name">
  <% if ordrparticipant && ordrparticipant.preferredlocale %>
    <%= menu.localised_name(ordrparticipant.preferredlocale) %>
  <% else %>
    <%= menu.name %>
  <% end %>
</span>

<div class="order-button-group">
  <div class="layout-toggle-group" role="group">
    <button type="button" class="layout-toggle-btn active" data-action="click->menu-layout#setCard" data-menu-layout-target="cardBtn">
      <i class="bi bi-grid"></i>
    </button>
    <button type="button" class="layout-toggle-btn" data-action="click->menu-layout#setList" data-menu-layout-target="listBtn">
      <i class="bi bi-list-ul"></i>
    </button>
    <button type="button" class="layout-toggle-btn" data-bs-toggle="modal" data-bs-target="#allergenModal">
      <i class="bi bi-shield-exclamation"></i>
    </button>
  </div>
</div>
