<%# Customer self-service receipt request form.
    Rendered in the SmartMenu cart/payment confirmation area after the order reaches paid/closed state.
    locals: order (Ordr) %>
<% return unless Flipper.enabled?(:receipt_email) %>
<% return unless order&.paid? || order&.closed? %>

<div id="receipt-request-section"
     class="mt-4 p-3"
     style="background-color: #F9FAFB; border-radius: 10px; border: 1px solid #E5E7EB;"
     data-controller="receipt-request">

  <h6 class="fw-semibold mb-1" style="font-size: 15px; color: #111827;">
    <i class="bi bi-envelope"></i>
    Get a receipt
  </h6>
  <p class="mb-3" style="font-size: 13px; color: #6B7280; margin: 0 0 12px 0;">
    Enter your email and we'll send you a copy of your receipt.
  </p>

  <form data-action="submit->receipt-request#submit"
        data-receipt-request-target="form">
    <%= hidden_field_tag :ordr_id, order.id %>

    <div class="d-flex gap-2 align-items-start">
      <div class="flex-grow-1">
        <input type="email"
               name="recipient_email"
               class="form-control form-control-sm"
               placeholder="your@email.com"
               required
               data-receipt-request-target="emailInput"
               style="border-radius: 8px;">
      </div>
      <button type="submit"
              class="btn btn-sm btn-primary"
              style="white-space: nowrap; border-radius: 8px;"
              data-receipt-request-target="submitButton">
        Send
      </button>
    </div>

    <div class="mt-2" style="font-size: 12px; color: #9CA3AF;">
      <input type="checkbox"
             id="receipt-consent-<%= order.id %>"
             name="consent"
             value="1"
             required>
      <label for="receipt-consent-<%= order.id %>">
        I consent to my email being used to send this receipt. It will not be used for marketing.
      </label>
    </div>

    <div data-receipt-request-target="status" class="mt-2" style="display: none;"></div>
  </form>
</div>
