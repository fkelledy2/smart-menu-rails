        <span class="menu-name">
            <% if ordrparticipant && ordrparticipant.preferredlocale %>
                <%= menu.localised_name(ordrparticipant.preferredlocale) %>
            <% else %>
                <%= menu.name %>
            <% end %>
        </span>
        <div class="order-button-group">
                    <% if tablesetting %>
                        <% if order %>
                            <% if order.status == 'opened' %>
                                <% if order.nett.to_f > 0 %>
                                    <% if order.addedCount > 0 %>
                                        <button type="button" class="btn-touch-primary btn-touch-sm" data-action="click->bottom-sheet#setState" data-bottom-sheet-state-param="full" data-testid="staff-view-order-btn">
                                            <i id="orderCart" class="bi bi-cart"></i>
                                            <%= t(".order") %>
                                            <div id="orderCartSpinner" class="spinner-border spinner-border-sm d-none" role="status"></div>
                                        </button>
                                    <% else %>
                                        <button type="button" class="btn-touch-primary btn-touch-sm" data-action="click->bottom-sheet#setState" data-bottom-sheet-state-param="full" data-testid="staff-view-order-btn">
                                            <i id="orderCart" class="bi bi-cart"></i>
                                            <%= t(".order") %>
                                            <div id="orderCartSpinner" class="spinner-border spinner-border-sm d-none" role="status"></div>
                                        </button>
                                    <% end %>
                                <% else %>
                                    <button type="button" class="btn-touch-secondary btn-touch-sm" disabled data-testid="staff-view-order-disabled-btn">
                                        <i id="orderCart" class="bi bi-cart"></i>
                                        <%= t(".order") %>
                                    </button>
                                <% end %>
                            <% end %>
                                <% if order.status == 'ordered' || order.status == 'preparing' || order.status == 'ready'  || order.status == 'delivered' %>
                                    <button type="button" class="btn-touch-primary btn-touch-sm" data-bs-toggle="modal" data-bs-restaurant="<%= restaurant.id %>" data-bs-menu="<%= menu.id %>" data-bs-target="#requestBillModal" data-testid="staff-request-bill-btn">
                                        <i class="bi bi-receipt"></i>
                                        <%= t(".bill") %>
                                    </button>
                                    <% if needs_age_check %>
                                      <% return_to_path = (defined?(smartmenu) && smartmenu.present?) ? smartmenu_path(smartmenu) : nil %>
                                      <%= button_to ack_alcohol_restaurant_ordr_path(restaurant, order, return_to: return_to_path),
                                          method: :post,
                                          class: 'btn-touch-secondary btn-touch-sm ms-2',
                                          data: { testid: 'ack-age-check-btn' } do %>
                                        <i class="bi bi-check2"></i>
                                        <span><%= t('smartmenus.alcohol.age_check', default: 'Age check') %></span>
                                      <% end %>
                                    <% end %>
                                    <% if order.addedCount > 0 %>
                                        <button type="button" class="btn-touch-primary btn-touch-sm" data-action="click->bottom-sheet#setState" data-bottom-sheet-state-param="full" data-testid="staff-view-order-btn">
                                            <i id="orderCart" class="bi bi-cart"></i>
                                            <%= t(".order") %>
                                            <div id="orderCartSpinner" style='display:none' class="spinner-border spinner-border-sm" role="status"></div>
                                        </button>
                                    <% else %>
                                        <button type="button" class="btn-touch-secondary btn-touch-sm" data-action="click->bottom-sheet#setState" data-bottom-sheet-state-param="full" data-testid="staff-view-order-btn">
                                            <i id="orderCart" class="bi bi-cart"></i>
                                            <%= t(".order") %>
                                        </button>
                                    <% end %>
                                <% end %>
                                <% if order.status == 'billrequested' %>
                                        <button type="button" class="btn-touch-dark btn-touch-sm" data-bs-toggle="modal" data-bs-restaurant="<%= restaurant.id %>" data-bs-menu="<%= menu.id %>" data-bs-target="#payOrderModal" data-testid="staff-pay-btn">
                                            <i class="bi bi-credit-card"></i>
                                            <%= t(".takePayment") %>
                                        </button>
                                <% end %>
                                <% if order.status == 'closed' %>
                                    <% if menu.allowOrdering == true && menu.restaurant.allowOrdering == true %>
                                        <button type="button" class="btn-touch-primary btn-touch-sm" data-bs-toggle="modal" data-bs-restaurant="<%= restaurant.id %>" data-bs-menu="<%= menu.id %>" data-bs-target="#openOrderModal" data-testid="staff-start-order-btn">
                                            <i class="bi bi-plus-circle"></i>
                                            <%= t(".startOrder") %>
                                        </button>
                                    <% end %>
                                <% end %>
                        <% else %>
                            <% if menu.allowOrdering == true && menu.restaurant.allowOrdering == true %>
                                <button type="button" class="btn-touch-primary btn-touch-sm" data-bs-toggle="modal" data-bs-restaurant="<%= restaurant.id %>" data-bs-menu="<%= menu.id %>" data-bs-target="#openOrderModal" data-testid="staff-start-order-btn">
                                    <i class="bi bi-plus-circle"></i>
                                    <%= t(".startOrder") %>
                                </button>
                            <% end %>
                        <% end %>
                    <% end %>
        </div>
        
        <%# Auto Pay tip — shown once per staff session when order is active and feature is enabled %>
        <% if order && order.status == 'ordered' && Flipper.enabled?(:auto_pay_and_leave, restaurant) && !order.payment_on_file? %>
          <div class="alert alert-info alert-dismissible fade show mt-2 py-2 small d-flex align-items-center gap-2"
               role="alert"
               data-testid="auto-pay-tip-banner">
            <i class="bi bi-credit-card me-1" aria-hidden="true"></i>
            <span><strong>Tip:</strong> Mention Auto Pay to this table — they can add a card now and skip the bill wait.</span>
            <button type="button" class="btn-close btn-close-sm ms-auto" data-bs-dismiss="alert" aria-label="Close"></button>
          </div>
        <% end %>

        <%# Floating Action Button for Cart - Mobile Optimized (Staff View) %>
        <% if order && order.status == 'opened' && order.nett.to_f > 0 %>
          <div class="order-fab">
            <button type="button" class="fab-button <%= 'has-new-items' if order.addedCount > 0 %>" data-action="click->bottom-sheet#setState" data-bottom-sheet-state-param="full" aria-label="<%= t('.view_cart', default: 'View cart') %>" data-testid="staff-fab-cart-btn">
              <i class="bi bi-cart"></i>
              <% if order.totalItemsCount > 0 %>
                <span class="fab-badge"><%= order.totalItemsCount %></span>
              <% end %>
            </button>
          </div>
        <% end %>