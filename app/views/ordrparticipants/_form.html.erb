<%= form_with(model: [@restaurant, ordrparticipant]) do |form| %>
  <% if ordrparticipant.errors.any? %>
    <div class="alert alert-danger mb-3" role="alert">
      <div class="fw-semibold mb-1"><%= pluralize(ordrparticipant.errors.count, 'error') %> prohibited this ordrparticipant from being saved:</div>
      <ul class="mb-0">
        <% ordrparticipant.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="mb-3">
    <%= form.label :sessionid, class: 'form-label' %>
    <%= form.text_field :sessionid, class: 'form-control' %>
  </div>

  <div class="mb-3">
    <%= form.label :action, class: 'form-label' %>
    <%= form.number_field :action, class: 'form-control' %>
  </div>

  <div class="mb-3">
    <%= form.label :role, class: 'form-label' %>
    <%= form.number_field :role, class: 'form-control' %>
  </div>

  <div class="mb-3">
    <%= form.label :employee_id, class: 'form-label' %>
    <%= form.text_field :employee_id, class: 'form-control' %>
  </div>

  <div class="mb-3">
    <%= form.label :ordr_id, class: 'form-label' %>
    <%= form.text_field :ordr_id, class: 'form-control' %>
  </div>

  <div class="mb-3">
    <%= form.label :ordritem_id, class: 'form-label' %>
    <%= form.text_field :ordritem_id, class: 'form-control' %>
  </div>

  <div class="d-flex justify-content-end gap-2 align-items-center">
    <% if ordrparticipant.persisted? %>
      <%= button_to t('common.delete'), [@restaurant, ordrparticipant], method: :delete, class: 'btn btn-link text-danger p-0', data: { turbo_confirm: t('common.confirm') } %>
    <% end %>

    <%= form.submit value: t('common.save'), class: 'btn btn-dark' %>

    <% if ordrparticipant.persisted? %>
      <%= link_to t('common.cancel'), [@restaurant, ordrparticipant], class: 'btn btn-link' %>
    <% else %>
      <%= link_to t('common.cancel'), restaurant_ordrparticipants_path(@restaurant), class: 'btn btn-link' %>
    <% end %>
  </div>
<% end %>
