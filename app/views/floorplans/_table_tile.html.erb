<%# Floorplan table tile partial.
    Locals: tablesetting (Tablesetting), ordr (Ordr | nil) %>
<% delayed = ordr && floorplan_tile_delayed?(ordr) %>
<div id="table-tile-<%= tablesetting.id %>"
     class="table-tile card shadow-sm h-100 <%= 'border-warning' if delayed %>"
     data-tablesetting-id="<%= tablesetting.id %>"
     data-filter-status="<%= ordr ? ordr.status : 'available' %>">
  <div class="card-body p-3">
    <%# Table name and capacity %>
    <div class="d-flex justify-content-between align-items-start mb-2">
      <h6 class="card-title mb-0 fw-bold text-truncate" title="<%= tablesetting.name %>">
        <%= tablesetting.name %>
      </h6>
      <span class="badge bg-secondary-subtle text-secondary ms-1 flex-shrink-0" aria-label="Capacity">
        <i class="bi bi-people-fill" aria-hidden="true"></i>
        <%= tablesetting.capacity %>
      </span>
    </div>

    <% if ordr %>
      <%# Status chip — colour-coded, always includes text for accessibility %>
      <div class="mb-2">
        <span class="badge <%= floorplan_status_badge_class(ordr.status) %>" role="status">
          <%= floorplan_status_label(ordr.status) %>
        </span>
        <% if ordr.respond_to?(:payment_on_file) && ordr.payment_on_file? %>
          <span class="badge bg-info-subtle text-info ms-1" title="Payment on file">
            <i class="bi bi-credit-card-fill" aria-hidden="true"></i>
          </span>
        <% end %>
      </div>

      <%# Time since order opened %>
      <div class="text-muted small mb-1">
        <i class="bi bi-clock" aria-hidden="true"></i>
        <span class="floorplan-elapsed-time" data-opened-at="<%= ordr.created_at.iso8601 %>">
          <%= floorplan_elapsed_label(ordr.created_at) %>
        </span>
      </div>

      <%# Participant count %>
      <div class="text-muted small mb-1">
        <i class="bi bi-person" aria-hidden="true"></i>
        <span class="visually-hidden">Diners:</span>
        <%= ordr.ordrparticipants_count %>
      </div>

      <%# Bill requested badge %>
      <% if ordr.billrequested? %>
        <div class="mt-2">
          <span class="badge bg-purple text-white">
            <i class="bi bi-receipt" aria-hidden="true"></i>
            Bill Requested
          </span>
        </div>
      <% end %>

      <%# Attention badge for delayed tables %>
      <% if delayed %>
        <div class="mt-1">
          <span class="badge text-bg-warning">
            <i class="bi bi-exclamation-triangle-fill" aria-hidden="true"></i>
            Delayed
          </span>
        </div>
      <% end %>

    <% else %>
      <%# Available — no active order %>
      <div>
        <span class="badge text-bg-success" role="status">
          <i class="bi bi-check-circle" aria-hidden="true"></i>
          Available
        </span>
      </div>
    <% end %>
  </div>
</div>
