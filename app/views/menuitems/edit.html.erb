<%#
  Edit Menu Item - 2025 Design System
  Modern form layout with breadcrumb navigation
%>

<!-- Page Header -->
<div class="container-fluid px-0 pb-4">
  <div class="d-flex justify-content-between align-items-start flex-wrap gap-3">
    <div>
      <!-- Breadcrumb -->
      <div class="text-gray-500 mb-2">
        <%= link_to @menuitem.menusection.menu.restaurant.name, edit_restaurant_path(@menuitem.menusection.menu.restaurant), class: 'text-primary' %>
        <i class="bi bi-chevron-right"></i>
        <%= link_to @menuitem.menusection.menu.name, edit_restaurant_menu_path(@menuitem.menusection.menu.restaurant, @menuitem.menusection.menu), class: 'text-primary' %>
        <i class="bi bi-chevron-right"></i>
        <%= link_to @menuitem.menusection.name, edit_restaurant_menu_menusection_path(@menuitem.menusection.menu.restaurant, @menuitem.menusection.menu, @menuitem.menusection), class: 'text-primary' %>
        <i class="bi bi-chevron-right"></i>
        <%= @menuitem.name %>
      </div>

      <h1 class="text-2xl font-semibold text-gray-900 mb-1">
        <i class="bi bi-pencil"></i>
        <%= @menuitem.name %>
      </h1>
      <p class="text-sm text-gray-500">
        <%= t('.description', default: 'Edit menu item details, pricing, and options') %>
      </p>
    </div>

    <div class="d-flex gap-2">
      <%= link_to edit_restaurant_menu_menusection_path(@menuitem.menusection.menu.restaurant, @menuitem.menusection.menu, @menuitem.menusection),
          class: 'btn btn-ghost' do %>
        <i class="bi bi-arrow-left"></i> <%= t('.back_to_section', default: 'Back to Section') %>
      <% end %>
    </div>
  </div>
</div>

<div class="menu-content-positioned">
  <div class="tab-content">
    <div class="tab-pane fade show active" role="tabpanel">
      <div class="row">
        <div class="col-12">
          <%= render 'form', menuitem: @menuitem %>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  .text-2xl {
    font-size: 1.5rem;
    line-height: 2rem;
  }

  .text-gray-900 {
    color: var(--color-gray-900);
  }

  .text-gray-500 {
    color: var(--color-gray-500);
  }

  .text-sm {
    font-size: 0.875rem;
  }
</style>
