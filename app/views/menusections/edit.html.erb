<%#
  Edit Menu Section - 2025 Design System
  Modern form layout with tab navigation
%>

<!-- Page Header -->
<div class="container-fluid px-0 pb-4">
  <div class="d-flex justify-content-between align-items-start flex-wrap gap-3">
    <div>
      <!-- Breadcrumb -->
      <div class="text-gray-500 mb-2">
        <%= link_to @menusection.menu.restaurant.name, edit_restaurant_path(@menusection.menu.restaurant), class: 'text-primary' %>
        <i class="bi bi-chevron-right"></i>
        <%= link_to @menusection.menu.name, edit_restaurant_menu_path(@menusection.menu.restaurant, @menusection.menu), class: 'text-primary' %>
        <i class="bi bi-chevron-right"></i>
        <%= @menusection.name %>
      </div>

      <h1 class="text-2xl font-semibold text-gray-900 mb-1">
        <i class="bi bi-pencil"></i>
        <%= @menusection.name %>
      </h1>
      <p class="text-sm text-gray-500">
        <%= t('.description', default: 'Edit section configuration and menu items') %>
      </p>
    </div>

    <div class="d-flex gap-2">
      <%= link_to edit_restaurant_menu_path(@menusection.menu.restaurant, @menusection.menu),
          class: 'btn btn-ghost' do %>
        <i class="bi bi-arrow-left"></i> <%= t('.back_to_menu', default: 'Back to Menu') %>
      <% end %>
    </div>
  </div>
</div>

<ul class="nav nav-tabs overflow-auto flex-nowrap menu-tabs-main" id="sectionTabs" role="tablist">
  <li class="nav-item" role="presentation">
    <button class="nav-link link-dark active" id="section-tab" data-bs-toggle="tab" data-bs-target="#section" type="button" role="tab" aria-controls="sectionConfig" aria-selected="true"><%= t(".section") %></button>
  </li>
  <li class="nav-item" role="presentation">
    <button class="nav-link link-dark" id="menuitem-tab" data-bs-toggle="tab" data-bs-target="#menuitem" type="button" role="tab" aria-controls="menuitemConfig" aria-selected="false"><%= t(".items") %></button>
  </li>
  <li class="nav-item" role="presentation">
    <button class="nav-link link-dark" id="inventory-tab" data-bs-toggle="tab" data-bs-target="#inventory" type="button" role="tab" aria-controls="inventoryConfig" aria-selected="false"><%= t(".inventories") %></button>
  </li>
</ul>

<div class="menu-content-positioned">
  <div class="tab-content" id="sectionConfig">
    <div class="tab-pane fade show active" id="section" role="tabpanel" aria-labelledby="section-tab">
      <div class="row">
        <div class="col-11">
          <%= render 'form', menusection: @menusection %>
        </div>
      </div>
    </div>
  </div>
  <div class="tab-content" id="menuitemConfig">
    <div class="tab-pane fade" id="menuitem" role="tabpanel" aria-labelledby="menuitem-tab">
      <div class="row">
        <div class="col-12">
          <%= render 'showMenuitems', menusection: @menusection, edit: false %>
        </div>
      </div>
    </div>
  </div>
  <div class="tab-content" id="inventoryConfig">
    <div class="tab-pane fade" id="inventory" role="tabpanel" aria-labelledby="inventory-tab">
      <div class="row">
        <div class="col-12">
          <%= render 'showInventories', menusection: @menusection, edit: false %>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  .text-2xl {
    font-size: 1.5rem;
    line-height: 2rem;
  }

  .text-gray-900 {
    color: var(--color-gray-900);
  }

  .text-gray-500 {
    color: var(--color-gray-500);
  }

  .text-sm {
    font-size: 0.875rem;
  }
</style>
