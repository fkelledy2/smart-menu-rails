<%# Change Role modal form — rendered inside a Turbo Frame, submitted via Turbo Stream %>
<% employee   = local_assigns[:employee] %>
<% restaurant = local_assigns[:restaurant] %>
<% error      = local_assigns[:error] %>

<% current_user_employee = restaurant.employees.find_by(user: current_user) %>
<% is_demotion = ->(role) { Employee.roles[role.to_s] < Employee.roles[employee.role.to_s] } %>

<div id="change_role_modal_<%= employee.id %>"
     class="card border-primary mt-3 mb-2"
     data-controller="role-change"
     data-role-change-employee-id-value="<%= employee.id %>">
  <div class="card-header d-flex justify-content-between align-items-center bg-primary-subtle">
    <span class="fw-semibold">
      <i class="bi bi-person-gear me-1"></i>
      <%= t('employees.change_role_form.change_role_heading') %> — <%= employee.user&.email&.split('@')&.first || employee.name %>
    </span>
    <button type="button"
            class="btn-close btn-close-sm"
            aria-label="Close"
            data-action="click->role-change#close"
            data-role-change-employee-id-param="<%= employee.id %>">
    </button>
  </div>
  <div class="card-body">
    <% if error.present? %>
      <div class="alert alert-danger alert-sm py-2 mb-3">
        <i class="bi bi-exclamation-triangle me-1"></i>
        <%= error %>
      </div>
    <% end %>

    <p class="text-muted small mb-3">
      <%= t('employees.change_role_form.current_role_label') %>
      <% badge_class = case employee.role
                       when 'manager' then 'text-bg-primary'
                       when 'staff'   then 'text-bg-info'
                       when 'admin'   then 'text-bg-danger'
                       else 'text-bg-secondary'
                       end %>
      <span class="badge <%= badge_class %>"><%= employee.role&.titleize %></span>
    </p>

    <%= form_with url: change_role_restaurant_employee_path(restaurant, employee),
        method: :post,
        data: { turbo_stream: true, controller: 'role-change-form', 'role-change-form-is-demotion-value': 'false' } do |f| %>

      <div class="mb-3">
        <%= f.label :to_role, t('employees.change_role_form.new_role_label'), class: 'form-label fw-semibold' %>
        <% available_roles = if current_user_employee&.admin?
                               Employee.roles.keys.map { |r| [r.titleize, r] }.reject { |_, v| v == employee.role }
                             else
                               [['Manager', 'manager']]
                             end %>
        <%= f.select 'role_change[to_role]',
            available_roles,
            { include_blank: t('employees.change_role_form.select_role_blank') },
            {
              class: 'form-select',
              required: true,
              data: {
                action: 'change->role-change-form#checkDemotion',
                'role-change-form-target': 'roleSelect',
                'current-role': employee.role,
              },
            } %>
      </div>

      <div class="mb-3">
        <%= f.label :reason, t('employees.change_role_form.reason_label'), class: 'form-label fw-semibold' %>
        <%= f.text_area 'role_change[reason]',
            class: 'form-control',
            rows: 3,
            placeholder: t('employees.change_role_form.reason_placeholder'),
            required: true,
            minlength: 10 %>
        <div class="form-text text-muted"><%= t('employees.change_role_form.reason_hint') %></div>
      </div>

      <%# Demotion confirmation — shown by Stimulus when the new role is lower %>
      <div class="alert alert-warning py-2 mb-3 d-none" data-role-change-form-target="demotionWarning">
        <i class="bi bi-exclamation-triangle-fill me-1"></i>
        <%= t('employees.change_role_form.demotion_warning') %>
        <div class="form-check mt-2">
          <%= f.check_box 'role_change[confirm_demotion]',
              { class: 'form-check-input', data: { 'role-change-form-target': 'demotionConfirm', action: 'change->role-change-form#syncSubmit' } },
              '1', '0' %>
          <label class="form-check-label"><%= t('employees.change_role_form.confirm_demotion_label') %></label>
        </div>
      </div>

      <div class="d-flex gap-2 justify-content-end">
        <button type="button"
                class="btn btn-sm btn-outline-secondary"
                data-action="click->role-change#close"
                data-role-change-employee-id-param="<%= employee.id %>">
          <%= t('employees.change_role_form.cancel') %>
        </button>
        <%= f.submit t('employees.change_role_form.submit'),
            class: 'btn btn-sm btn-primary',
            data: { 'role-change-form-target': 'submitBtn' } %>
      </div>

    <% end %>
  </div>
</div>
