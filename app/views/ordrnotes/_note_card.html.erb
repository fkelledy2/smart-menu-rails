<div class="note-card priority-<%= note.priority %> category-<%= note.category %>" 
     data-note-id="<%= note.id %>"
     id="note-<%= note.id %>">
  <div class="note-header d-flex justify-content-between align-items-start mb-2">
    <div class="note-badges">
      <span class="note-category badge bg-<%= note.category_color %> me-1">
        <%= note.category_icon %> <%= note.category.humanize %>
      </span>
      <span class="note-priority badge bg-<%= note.priority_color %>">
        <%= note.priority.humanize %>
      </span>
    </div>
    <div class="note-meta text-muted small">
      <div><%= note.employee.name %></div>
      <div><%= time_ago_in_words(note.created_at) %> ago</div>
    </div>
  </div>
  
  <div class="note-content mb-2">
    <%= simple_format(note.content) %>
  </div>
  
  <div class="note-footer d-flex justify-content-between align-items-center">
    <div class="note-visibility small text-muted">
      <% if note.visible_to_kitchen %>
        <i class="bi bi-eye" title="Visible to kitchen"></i> Kitchen
      <% end %>
      <% if note.visible_to_servers %>
        <i class="bi bi-eye" title="Visible to servers"></i> Servers
      <% end %>
      <% if note.visible_to_customers %>
        <i class="bi bi-eye" title="Visible to customers"></i> Customers
      <% end %>
    </div>
    
    <div class="note-actions">
      <% if note.expires_at %>
        <small class="text-warning me-2">
          <i class="bi bi-clock"></i> Expires <%= time_ago_in_words(note.expires_at) %>
        </small>
      <% end %>
      
      <% if policy(note).update? %>
        <%= link_to edit_restaurant_ordr_ordrnote_path(restaurant, order, note), 
                    class: 'btn btn-sm btn-outline-secondary me-1',
                    title: 'Edit note' do %>
          <i class="bi bi-pencil"></i>
        <% end %>
      <% end %>
      
      <% if policy(note).destroy? %>
        <%= button_to restaurant_ordr_ordrnote_path(restaurant, order, note),
                      method: :delete,
                      class: 'btn btn-sm btn-outline-danger',
                      title: 'Delete note',
                      data: { confirm: 'Are you sure you want to delete this note?' } do %>
          <i class="bi bi-trash"></i>
        <% end %>
      <% end %>
    </div>
  </div>
</div>
