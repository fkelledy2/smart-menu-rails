<div class="container mt-4">
  <div class="row">
    <div class="col-12">
      <h2>Add Order Note</h2>
      
      <%= form_with(model: @ordrnote, url: restaurant_ordr_ordrnotes_path(@restaurant, @order), local: true) do |form| %>
        <% if @ordrnote.errors.any? %>
          <div class="alert alert-danger">
            <h4><%= pluralize(@ordrnote.errors.count, "error") %> prohibited this note from being saved:</h4>
            <ul>
              <% @ordrnote.errors.full_messages.each do |message| %>
                <li><%= message %></li>
              <% end %>
            </ul>
          </div>
        <% end %>

        <div class="mb-3">
          <%= form.label :category, class: 'form-label' %>
          <%= form.select :category, Ordrnote.categories.keys.map { |k| [k.humanize, k] }, {}, class: 'form-select' %>
        </div>

        <div class="mb-3">
          <%= form.label :priority, class: 'form-label' %>
          <%= form.select :priority, Ordrnote.priorities.keys.map { |k| [k.humanize, k] }, {}, class: 'form-select' %>
        </div>

        <div class="mb-3">
          <%= form.label :content, class: 'form-label' %>
          <%= form.text_area :content, rows: 4, class: 'form-control', maxlength: 500 %>
          <small class="text-muted">Maximum 500 characters</small>
        </div>

        <div class="mb-3">
          <div class="form-check">
            <%= form.check_box :visible_to_kitchen, class: 'form-check-input' %>
            <%= form.label :visible_to_kitchen, 'Visible to Kitchen', class: 'form-check-label' %>
          </div>
          <div class="form-check">
            <%= form.check_box :visible_to_servers, class: 'form-check-input' %>
            <%= form.label :visible_to_servers, 'Visible to Servers', class: 'form-check-label' %>
          </div>
          <div class="form-check">
            <%= form.check_box :visible_to_customers, class: 'form-check-input' %>
            <%= form.label :visible_to_customers, 'Visible to Customers', class: 'form-check-label' %>
          </div>
        </div>

        <div class="mb-3">
          <%= form.label :expires_at, 'Expires At (optional)', class: 'form-label' %>
          <%= form.datetime_local_field :expires_at, class: 'form-control' %>
        </div>

        <div class="d-flex gap-2">
          <%= form.submit 'Create Note', class: 'btn btn-primary' %>
          <%= link_to 'Cancel', restaurant_ordr_path(@restaurant, @order), class: 'btn btn-secondary' %>
        </div>
      <% end %>
    </div>
  </div>
</div>
