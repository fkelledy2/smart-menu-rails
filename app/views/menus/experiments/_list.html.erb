<% experiments = local_assigns[:experiments] %>
<% experiment_stats = local_assigns[:experiment_stats] || {} %>

<% if experiments.empty? %>
  <div class="card">
    <div class="card-body text-center py-5">
      <i class="bi bi-flask fs-1 text-muted"></i>
      <h5 class="mt-3 text-muted">No experiments yet</h5>
      <p class="text-muted small">
        Create your first A/B experiment to test two menu versions.
        You need at least two saved versions to start.
      </p>
    </div>
  </div>
<% else %>
  <div class="d-flex flex-column gap-3">
    <% experiments.each do |experiment| %>
      <div id="experiment_<%= experiment.id %>" class="card">
        <div class="card-body">
          <div class="d-flex justify-content-between align-items-start gap-3 flex-wrap">
            <div class="flex-grow-1">
              <div class="d-flex align-items-center gap-2 flex-wrap mb-1">
                <span id="experiment_<%= experiment.id %>_status">
                  <%= render 'menus/experiments/status_badge', experiment: experiment %>
                </span>
                <span class="text-muted small">
                  Created <%= time_ago_in_words(experiment.created_at) %> ago
                </span>
              </div>

              <div class="row g-3 mt-1">
                <div class="col-12 col-md-6">
                  <div class="small fw-semibold text-muted mb-1">CONTROL</div>
                  <div>Version v<%= experiment.control_version.version_number %></div>
                  <% control_count = experiment_stats.dig(experiment.id, :control) || 0 %>
                  <div class="text-muted small"><%= control_count %> exposures</div>
                </div>
                <div class="col-12 col-md-6">
                  <div class="small fw-semibold text-muted mb-1">VARIANT (<%= experiment.allocation_pct %>%)</div>
                  <div>Version v<%= experiment.variant_version.version_number %></div>
                  <% variant_count = experiment_stats.dig(experiment.id, :variant) || 0 %>
                  <div class="text-muted small"><%= variant_count %> exposures</div>
                </div>
              </div>

              <div class="text-muted small mt-2">
                <i class="bi bi-calendar-range"></i>
                <%= experiment.starts_at.strftime('%d %b %Y %H:%M') %>
                &rarr;
                <%= experiment.ends_at.strftime('%d %b %Y %H:%M') %>
              </div>
            </div>

            <div class="d-flex flex-column gap-2">
              <%= link_to restaurant_menu_experiment_path(@restaurant, @menu, experiment),
                  class: 'btn btn-outline-secondary btn-sm' do %>
                <i class="bi bi-bar-chart"></i>
                Results
              <% end %>

              <% if experiment.status_active? %>
                <%= button_to pause_restaurant_menu_experiment_path(@restaurant, @menu, experiment),
                    method: :patch,
                    class: 'btn btn-outline-warning btn-sm',
                    form: { data: { turbo: true } } do %>
                  <i class="bi bi-pause-circle"></i>
                  Pause
                <% end %>
              <% end %>

              <% if experiment.status_active? || experiment.status_paused? %>
                <%= button_to end_experiment_restaurant_menu_experiment_path(@restaurant, @menu, experiment),
                    method: :patch,
                    class: 'btn btn-outline-danger btn-sm',
                    data: { turbo_confirm: 'End this experiment? This cannot be undone.' },
                    form: { data: { turbo: true } } do %>
                  <i class="bi bi-stop-circle"></i>
                  End
                <% end %>
              <% end %>

              <% if experiment.status_draft? %>
                <%= link_to edit_restaurant_menu_experiment_path(@restaurant, @menu, experiment),
                    class: 'btn btn-outline-dark btn-sm' do %>
                  <i class="bi bi-pencil"></i>
                  Edit
                <% end %>

                <%= button_to restaurant_menu_experiment_path(@restaurant, @menu, experiment),
                    method: :delete,
                    class: 'btn btn-outline-danger btn-sm',
                    data: { turbo_confirm: 'Delete this experiment?' },
                    form: { data: { turbo: true } } do %>
                  <i class="bi bi-trash"></i>
                  Delete
                <% end %>
              <% end %>
            </div>
          </div>
        </div>
      </div>
    <% end %>
  </div>
<% end %>
