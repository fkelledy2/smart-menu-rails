<!-- Page Header -->
<div class="container-fluid px-0 pb-4">
  <div class="d-flex justify-content-between align-items-start flex-wrap gap-3">
    <div>
      <h1 class="fs-4 fw-semibold mb-1">
        <i class="bi bi-image"></i>
        Hero Images
      </h1>
      <p class="small text-muted">
        Manage the hero images displayed in the homepage carousel.
      </p>
    </div>

    <div class="d-flex gap-2">
      <div class="btn-group">
        <%= link_to new_hero_image_path, class: 'btn btn-primary' do %>
          <i class="bi bi-plus-circle"></i> New Hero Image
        <% end %>
        <button type="button" class="btn btn-primary dropdown-toggle dropdown-toggle-split" data-bs-toggle="dropdown" aria-expanded="false">
          <span class="visually-hidden">Toggle Dropdown</span>
        </button>
        <ul class="dropdown-menu dropdown-menu-end">
          <li>
            <%= button_to 'Clear Cache', clear_cache_hero_images_path,
                  method: :post,
                  form: { data: { turbo_confirm: 'This clears the Rails cache. Proceed?' } },
                  class: 'dropdown-item text-danger' %>
          </li>
        </ul>
      </div>
    </div>
  </div>
</div>

<!-- Hero Images Table Card -->
<div class="content-card">
  <h2 class="content-card-title mb-4">
    <i class="bi bi-list-ul"></i>
    All Hero Images
  </h2>

  <% if @hero_images.any? %>
    <div class="table-responsive">
      <table class="table table-hover align-middle mb-0">
        <thead class="table-light">
          <tr>
            <th scope="col" style="width: 120px">Preview</th>
            <th scope="col">Alt Text</th>
            <th scope="col" class="text-center" style="width: 80px">Sequence</th>
            <th scope="col" class="text-center" style="width: 110px">Status</th>
            <th scope="col" class="text-end" style="width: 140px">Actions</th>
          </tr>
        </thead>
        <tbody>
          <% @hero_images.each do |hero_image| %>
            <tr>
              <td>
                <img src="<%= hero_image.image_url %>"
                     alt="<%= hero_image.alt_text %>"
                     class="rounded"
                     style="width: 100px; height: 60px; object-fit: cover;">
              </td>
              <td class="fw-medium"><%= hero_image.alt_text.presence || '<em class="text-muted">No alt text</em>'.html_safe %></td>
              <td class="text-center text-muted"><%= hero_image.sequence %></td>
              <td class="text-center">
                <%= render 'shared/status_badge', status: (hero_image.approved? ? 'approved' : 'unapproved') %>
              </td>
              <td class="text-end">
                <div class="d-flex justify-content-end gap-1">
                  <%= link_to hero_image, class: 'btn btn-sm btn-outline-secondary', title: 'View' do %>
                    <i class="bi bi-eye"></i>
                  <% end %>
                  <%= link_to edit_hero_image_path(hero_image), class: 'btn btn-sm btn-outline-primary', title: 'Edit' do %>
                    <i class="bi bi-pencil"></i>
                  <% end %>
                  <%= button_to hero_image_path(hero_image),
                        method: :delete,
                        form: { data: { turbo_confirm: 'Delete this hero image?' } },
                        class: 'btn btn-sm btn-outline-danger',
                        title: 'Delete' do %>
                    <i class="bi bi-trash"></i>
                  <% end %>
                </div>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% else %>
    <div class="text-center py-5 text-muted">
      <i class="bi bi-image fs-1 d-block mb-3"></i>
      <p class="mb-3">No hero images yet.</p>
      <%= link_to new_hero_image_path, class: 'btn btn-primary' do %>
        <i class="bi bi-plus-circle"></i> Add First Hero Image
      <% end %>
    </div>
  <% end %>
</div>
