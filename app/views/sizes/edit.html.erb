<%#
  Edit Size - 2025 Design System
  Modern form layout with consistent styling
%>

<% in_frame = defined?(turbo_frame_request?) && turbo_frame_request? %>

<!-- Page Header -->
<% unless in_frame %>
  <div class="container-fluid px-0 pb-4">
    <div class="d-flex justify-content-between align-items-start flex-wrap gap-3">
      <div>
        <!-- Breadcrumb -->
        <nav aria-label="breadcrumb">
          <ol class="breadcrumb small mb-2">
            <li class="breadcrumb-item">
              <%= link_to @size.restaurant.name, edit_restaurant_path(@size.restaurant), class: 'text-primary' %>
            </li>
            <li class="breadcrumb-item">
              <%= link_to t('.sizes'), restaurant_sizes_path(@size.restaurant), class: 'text-primary' %>
            </li>
            <li class="breadcrumb-item active" aria-current="page"><%= @size.name %></li>
          </ol>
        </nav>

        <h1 class="h3 fw-semibold mb-1">
          <i class="bi bi-pencil"></i>
          <%= t('.edit_size') %>
        </h1>
        <p class="text-muted small mb-0">
          <%= t('.description') %>
        </p>
      </div>

      <div class="d-flex gap-2">
        <%= link_to restaurant_sizes_path(@size.restaurant), class: 'btn btn-ghost' do %>
          <i class="bi bi-x-lg"></i> <%= t('.cancel') %>
        <% end %>

        <%= button_to restaurant_size_path(@size.restaurant, @size),
            method: :delete,
            data: { turbo_confirm: t('.confirm_delete') },
            class: 'btn btn-ghost text-danger' do %>
          <i class="bi bi-trash"></i> <%= t('.delete') %>
        <% end %>
      </div>
    </div>
  </div>
<% end %>

<!-- Form Card -->
<%= turbo_frame_tag 'sizes_edit_size' do %>
  <div class="content-card" data-skip-form-manager="true">
    <h2 class="content-card-title">
      <i class="bi bi-rulers"></i>
      <%= t('.size_details') %>
    </h2>

    <%= render 'form', size: @size %>
  </div>
<% end %>
