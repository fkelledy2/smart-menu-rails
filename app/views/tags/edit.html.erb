<%#
  Edit Tag - 2025 Design System
  Modern form layout with consistent styling
%>

<!-- Page Header -->
<div class="container-fluid px-0 pb-4">
  <div class="d-flex justify-content-between align-items-start flex-wrap gap-3">
    <div>
      <!-- Breadcrumb -->
      <div class="text-sm text-gray-500 mb-2">
        <%= link_to t('.tags', default: 'Tags'), tags_path, class: 'text-primary' %>
        <i class="bi bi-chevron-right"></i>
        <%= @tag.name %>
      </div>

      <h1 class="text-2xl font-semibold text-gray-900 mb-1">
        <i class="bi bi-tag"></i>
        <%= t('.title') %>
      </h1>
    </div>

    <div class="d-flex gap-2">
      <%= link_to tags_path, class: 'btn btn-ghost' do %>
        <i class="bi bi-arrow-left"></i> <%= t('.back_to_tags', default: 'Back to Tags') %>
      <% end %>
    </div>
  </div>
</div>

<!-- Form Card -->
<div class="content-card" data-skip-form-manager="true">
  <h2 class="content-card-title">
    <i class="bi bi-tag"></i>
    <%= t('.tag_details', default: 'Tag Details') %>
  </h2>

  <%= render 'form', tag: @tag %>
</div>

<style>
  .text-2xl {
    font-size: 1.5rem;
    line-height: 2rem;
  }

  .text-gray-900 {
    color: var(--color-gray-900);
  }

  .text-gray-500 {
    color: var(--color-gray-500);
  }

  .text-sm {
    font-size: 0.875rem;
  }
</style>
