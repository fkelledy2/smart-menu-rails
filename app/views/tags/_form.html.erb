<%= form_with(model: tag) do |form| %>
  <div class="mb-3">
    <%= form.label :name, class: 'form-label' %>
    <%= form.text_field :name, class: 'form-control' %>
  </div>

  <div class="mb-3">
    <%= form.label :description, class: 'form-label' %>
    <%= form.text_area :description, class: 'form-control' %>
  </div>

  <% if tag.errors.any? %>
    <div class="alert alert-danger mb-3" role="alert">
      <div class="fw-semibold mb-1"><%= t('common.errors') %></div>
      <ul class="mb-0">
        <% tag.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="d-flex justify-content-end gap-2">
    <% if tag.persisted? %>
      <%= button_to t('common.delete'), tag, method: :delete, class: 'btn btn-outline-danger', data: { turbo_confirm: t('common.confirm') } %>
    <% end %>
    <%= form.submit value: t('common.save'), class: 'btn btn-dark' %>
  </div>
<% end %>
