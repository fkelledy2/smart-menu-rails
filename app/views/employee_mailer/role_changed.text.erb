<%= t('employee_mailer.role_changed.subject') %> — <%= @restaurant.name %>

<%= t('employee_mailer.role_changed.greeting', name: @employee.name) %>

<%= t('employee_mailer.role_changed.intro', restaurant: @restaurant.name, changed_by: @changed_by.name) %>

<%= t('employee_mailer.role_changed.previous_role') %>: <%= @from_role.titleize %>
<%= t('employee_mailer.role_changed.new_role') %>: <%= @to_role.titleize %>

<%= t('employee_mailer.role_changed.reason_label') %>
<%= @audit.reason %>

<%= t('employee_mailer.role_changed.change_date', date: @audit.created_at.strftime('%B %-d, %Y at %I:%M %p')) %>

<%= t('employee_mailer.role_changed.error_contact') %>

---
<%= t('employee_mailer.role_changed.footer') %>
