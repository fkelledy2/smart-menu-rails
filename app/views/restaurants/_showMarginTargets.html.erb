<div class="row">
  <div class="col-6">
    <h4>Profit Margin Targets</h4>
  </div>
  <div class="col-6 text-end">
    <div class="btn-group" role="group">
      <button type="button" class="btn btn-dark">
        <%= link_to new_restaurant_profit_margin_target_path(@restaurant), class: 'link-light' do %>
          <i class="bi bi-plus"></i> Add Target
        <% end %>
      </button>
    </div>
  </div>
</div>

<div class="alert alert-info mt-3">
  <strong>Target Inheritance:</strong> Targets can be set at restaurant, section, or item level. 
  Item-level targets override section-level, which override restaurant-level targets.
</div>

