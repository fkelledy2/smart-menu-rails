<div class="row">
  <div class="col-6">
    <h4>Profit Margin Targets</h4>
  </div>
  <div class="col-6 text-end">
    <div class="btn-group" role="group">
      <button type="button" class="btn btn-dark">
        <%= link_to new_restaurant_profit_margin_target_path(@restaurant), class: 'link-light' do %>
          <i class="bi bi-plus"></i> Add Target
        <% end %>
      </button>
    </div>
  </div>
</div>

<div class="table-responsive mt-3">
  <table class="table table-hover">
    <thead>
      <tr>
        <th>Level</th>
        <th>Target</th>
        <th>Target %</th>
        <th>Minimum %</th>
        <th>Effective From</th>
        <th>Effective To</th>
        <th>Actions</th>
      </tr>
    </thead>
    <tbody>
      <% @restaurant.profit_margin_targets.active.each do |target| %>
        <tr>
          <td>
            <% if target.restaurant_id.present? && target.menusection_id.nil? && target.menuitem_id.nil? %>
              <span class="badge bg-primary">Restaurant</span>
            <% elsif target.menusection_id.present? %>
              <span class="badge bg-info">Section</span>
            <% else %>
              <span class="badge bg-success">Item</span>
            <% end %>
          </td>
          <td>
            <% if target.restaurant_id.present? && target.menusection_id.nil? && target.menuitem_id.nil? %>
              <%= @restaurant.name %>
            <% elsif target.menusection_id.present? %>
              <%= Menusection.find(target.menusection_id).name %>
            <% else %>
              <%= Menuitem.find(target.menuitem_id).localised_name('en') %>
            <% end %>
          </td>
          <td><%= number_to_percentage(target.target_margin_percentage, precision: 1) %></td>
          <td>
            <% if target.minimum_margin_percentage.present? %>
              <%= number_to_percentage(target.minimum_margin_percentage, precision: 1) %>
            <% else %>
              <span class="text-muted">Not set</span>
            <% end %>
          </td>
          <td><%= target.effective_from.strftime('%b %d, %Y') %></td>
          <td>
            <% if target.effective_to.present? %>
              <%= target.effective_to.strftime('%b %d, %Y') %>
            <% else %>
              <span class="text-muted">Ongoing</span>
            <% end %>
          </td>
          <td>
            <%= link_to 'Edit', edit_restaurant_profit_margin_target_path(@restaurant, target), class: 'btn btn-sm btn-outline-primary' %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
