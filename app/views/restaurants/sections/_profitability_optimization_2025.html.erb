<%#
  Profitability: Menu Engineering sub-section
  Stars / Plowhorses / Puzzles / Dogs analysis based on margin + popularity.
%>

<% restaurant = local_assigns[:restaurant] || @restaurant %>

<!-- Section Header -->
<div class="mb-3 p-3 border-bottom d-flex align-items-center justify-content-between flex-wrap gap-2">
  <div>
    <div class="d-flex align-items-center gap-2 mb-1">
      <%= link_to edit_restaurant_path(restaurant, section: 'profitability'),
          class: 'btn btn-sm btn-outline-secondary',
          data: { turbo_frame: 'restaurant_content', turbo_action: 'advance' } do %>
        <i class="bi bi-arrow-left"></i>
      <% end %>
      <h2 class="h5 mb-0 d-flex align-items-center gap-2">
        <i class="bi bi-stars"></i>
        Menu Engineering
      </h2>
    </div>
    <p class="text-muted small mb-0 ms-5">Classify items by profitability and popularity</p>
  </div>
  <%= link_to restaurant_menu_optimizations_path(restaurant),
      class: 'btn btn-sm btn-outline-primary',
      data: { turbo: false } do %>
    <i class="bi bi-box-arrow-up-right me-1"></i>Full Analysis
  <% end %>
</div>

<div class="px-3 pb-3">
  <!-- Quadrant explainer -->
  <div class="row g-3 mb-4">
    <div class="col-6 col-md-3">
      <div class="border rounded p-3 text-center h-100" style="border-color: #198754 !important;">
        <div class="fw-bold text-success mb-1">Stars</div>
        <div class="text-muted small">High margin<br>High popularity</div>
        <div class="mt-2"><i class="bi bi-star-fill text-warning fs-4"></i></div>
      </div>
    </div>
    <div class="col-6 col-md-3">
      <div class="border rounded p-3 text-center h-100" style="border-color: #0d6efd !important;">
        <div class="fw-bold text-primary mb-1">Plowhorses</div>
        <div class="text-muted small">Low margin<br>High popularity</div>
        <div class="mt-2"><i class="bi bi-arrows-expand-vertical text-primary fs-4"></i></div>
      </div>
    </div>
    <div class="col-6 col-md-3">
      <div class="border rounded p-3 text-center h-100" style="border-color: #ffc107 !important;">
        <div class="fw-bold" style="color:#b45309;">Puzzles</div>
        <div class="text-muted small">High margin<br>Low popularity</div>
        <div class="mt-2"><i class="bi bi-question-circle text-warning fs-4"></i></div>
      </div>
    </div>
    <div class="col-6 col-md-3">
      <div class="border rounded p-3 text-center h-100" style="border-color: #dc3545 !important;">
        <div class="fw-bold text-danger mb-1">Dogs</div>
        <div class="text-muted small">Low margin<br>Low popularity</div>
        <div class="mt-2"><i class="bi bi-x-circle text-danger fs-4"></i></div>
      </div>
    </div>
  </div>

  <div class="alert alert-info d-flex align-items-start gap-2">
    <i class="bi bi-info-circle flex-shrink-0 mt-1"></i>
    <div>
      <strong>How it works:</strong> Menu engineering classifies each item based on its gross margin relative to your average, and its order frequency relative to other items. Items need cost data and order history for classification.
      <div class="mt-2">
        <%= link_to 'View full analysis', restaurant_menu_optimizations_path(restaurant),
            class: 'btn btn-sm btn-primary me-2',
            data: { turbo: false } %>
        <%= link_to edit_restaurant_path(restaurant, section: 'profitability_margins'),
            class: 'btn btn-sm btn-outline-secondary',
            data: { turbo_frame: 'restaurant_content', turbo_action: 'advance' } do %>
          Add cost data
        <% end %>
      </div>
    </div>
  </div>
</div>
