<%#
  Profitability: Profit Margins sub-section
  Shows all menu items across all active menus with their cost and margin data.
%>

<% restaurant = local_assigns[:restaurant] || @restaurant %>

<%
  items = Menuitem.joins(menusection: :menu)
                  .where(menus: { restaurant_id: restaurant.id, archived: false })
                  .where(menuitems: { archived: false })
                  .includes(:menuitem_costs, menusection: :menu)
                  .order('menus.name, menusections.sequence, menuitems.sequence')

  total_count  = items.count
  costed_count = items.select { |i| i.current_cost.present? }.count
  uncosted     = total_count - costed_count
%>

<!-- Section Header -->
<div class="mb-3 p-3 border-bottom d-flex align-items-center justify-content-between flex-wrap gap-2">
  <div>
    <div class="d-flex align-items-center gap-2 mb-1">
      <h2 class="h5 mb-0 d-flex align-items-center gap-2">
        <i class="bi bi-bar-chart-line"></i>
        Profit Margins
      </h2>
    </div>
    <p class="text-muted small mb-0 ms-5">Cost and margin data for every menu item</p>
  </div>
</div>

<!-- Stats Strip -->
<div class="px-3 mb-3">
  <div class="row g-2">
    <div class="col-4">
      <div class="border rounded p-2 text-center">
        <div class="fw-bold fs-5 text-success"><%= costed_count %></div>
        <div class="text-muted small">Costed</div>
      </div>
    </div>
    <div class="col-4">
      <div class="border rounded p-2 text-center">
        <div class="fw-bold fs-5 <%= uncosted > 0 ? 'text-warning' : 'text-muted' %>"><%= uncosted %></div>
        <div class="text-muted small">Missing</div>
      </div>
    </div>
    <div class="col-4">
      <div class="border rounded p-2 text-center">
        <div class="fw-bold fs-5"><%= total_count %></div>
        <div class="text-muted small">Total</div>
      </div>
    </div>
  </div>
</div>

<% if uncosted > 0 %>
  <div class="px-3 mb-3">
    <div class="alert alert-warning mb-0 d-flex align-items-center gap-2 py-2">
      <i class="bi bi-exclamation-triangle flex-shrink-0"></i>
      <span class="small">
        <strong><%= uncosted %> item<%= uncosted == 1 ? '' : 's' %></strong> missing cost data.
      </span>
    </div>
  </div>
<% end %>

<!-- Inline cost form (populated by Turbo when Add/Edit is clicked) -->
<%= turbo_frame_tag 'inline_cost_form', class: 'px-3 d-block' %>

<!-- Per-item table -->
<div class="px-3 pb-3">
  <% if items.any? %>
    <div class="table-responsive">
      <table class="table table-sm table-hover align-middle">
        <thead class="table-light">
          <tr>
            <th>Item</th>
            <th>Menu</th>
            <th class="text-end">Price</th>
            <th class="text-end">Cost</th>
            <th class="text-end">Margin</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          <% items.each do |item| %>
            <% cost = item.current_cost %>
            <% menu = item.menusection.menu %>
            <% menusection = item.menusection %>
            <tr>
              <td>
                <span class="fw-medium"><%= item.name %></span>
                <small class="text-muted d-block"><%= menusection.name %></small>
              </td>
              <td class="small text-muted"><%= menu.name %></td>
              <td class="text-end"><%= number_to_currency(item.price) %></td>
              <td class="text-end">
                <% if cost %>
                  <%= number_to_currency(cost.total_cost) %>
                <% else %>
                  <span class="text-muted">—</span>
                <% end %>
              </td>
              <td class="text-end">
                <% if cost && item.price.to_f > 0 && cost.total_cost.to_f > 0 %>
                  <% margin_pct = ((item.price.to_f - cost.total_cost.to_f) / item.price.to_f * 100).round(1) %>
                  <span class="badge <%= margin_pct >= 60 ? 'text-bg-success' : margin_pct >= 30 ? 'text-bg-warning' : 'text-bg-danger' %>">
                    <%= margin_pct %>%
                  </span>
                <% else %>
                  <span class="text-muted small">—</span>
                <% end %>
              </td>
              <td class="text-end">
                <% if cost %>
                  <%= link_to 'Edit',
                      edit_restaurant_menu_menusection_menuitem_cost_path(restaurant, menu, menusection, cost, menuitem_id: item.id),
                      class: 'btn btn-sm btn-outline-secondary',
                      data: { turbo_frame: 'inline_cost_form' } %>
                <% else %>
                  <%= link_to 'Add cost',
                      new_restaurant_menu_menusection_menuitem_cost_path(restaurant, menu, menusection, menuitem_id: item.id),
                      class: 'btn btn-sm btn-outline-primary',
                      data: { turbo_frame: 'inline_cost_form' } %>
                <% end %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% else %>
    <p class="text-muted">No menu items yet. <a href="<%= edit_restaurant_path(restaurant, section: 'menus') %>" data-turbo-frame="restaurant_content">Create a menu</a> to get started.</p>
  <% end %>
</div>
