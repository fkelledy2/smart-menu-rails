<% badge_class = case status
               when 'pending'           then 'bg-secondary'
               when 'running'           then 'bg-primary'
               when 'awaiting_approval' then 'bg-warning text-dark'
               when 'completed'         then 'bg-success'
               when 'failed'            then 'bg-danger'
               when 'cancelled'         then 'bg-light text-dark border'
               else 'bg-secondary'
               end %>
<span class="badge <%= badge_class %>"><%= status.humanize %></span>
