<% content_for :title, "AI Workbench — #{@restaurant.name}" %>

<div class="container-fluid py-3">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <div>
      <h4 class="mb-0 fw-bold">
        <i class="bi bi-robot me-2 text-primary" aria-hidden="true"></i>
        AI Workbench
      </h4>
      <p class="text-muted small mb-0"><%= @restaurant.name %></p>
    </div>
    <div>
      <%= link_to digests_restaurant_agent_workbench_index_path(@restaurant),
                  class: 'btn btn-sm btn-outline-success' do %>
        <i class="bi bi-graph-up-arrow me-1" aria-hidden="true"></i> Growth Digest
      <% end %>
    </div>
  </div>

  <% if notice %>
    <div class="alert alert-success alert-dismissible fade show py-2" role="alert">
      <%= notice %>
      <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
  <% end %>
  <% if alert %>
    <div class="alert alert-danger alert-dismissible fade show py-2" role="alert">
      <%= alert %>
      <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
  <% end %>

  <% if @runs.empty? %>
    <div class="card border-0 shadow-sm">
      <div class="card-body text-center py-5">
        <i class="bi bi-cpu display-4 text-muted mb-3" aria-hidden="true"></i>
        <h5 class="text-muted">No AI workflow runs yet</h5>
        <p class="text-muted small">
          AI agents will appear here once the <strong>agent_framework</strong> Flipper flag
          is enabled for this restaurant and a workflow is triggered.
        </p>
      </div>
    </div>
  <% else %>
    <div class="card border-0 shadow-sm">
      <div class="card-header bg-transparent fw-semibold border-bottom d-flex justify-content-between">
        <span>Workflow Runs</span>
        <span class="text-muted small">Showing <%= @runs.count %> of <%= @pagy.count %></span>
      </div>
      <div class="list-group list-group-flush">
        <% @runs.each do |run| %>
          <%= link_to restaurant_agent_workbench_path(@restaurant, run),
                class: 'list-group-item list-group-item-action py-3' do %>
            <div class="d-flex justify-content-between align-items-start">
              <div>
                <div class="fw-semibold text-dark">
                  <%= run.workflow_type.humanize %>
                </div>
                <div class="text-muted small">
                  Triggered by: <em><%= run.trigger_event %></em>
                  &middot;
                  <%= time_ago_in_words(run.created_at) %> ago
                </div>
              </div>
              <div class="d-flex align-items-center gap-2">
                <% if run.agent_approvals.pending.any? %>
                  <span class="badge bg-warning text-dark">
                    <%= run.agent_approvals.pending.count %> pending
                  </span>
                <% end %>
                <%= render 'status_badge', status: run.status %>
              </div>
            </div>
          <% end %>
        <% end %>
      </div>
    </div>

    <% if @pagy.pages > 1 %>
      <div class="d-flex justify-content-center mt-3">
        <%== pagy_bootstrap_nav(@pagy) %>
      </div>
    <% end %>
  <% end %>
</div>
