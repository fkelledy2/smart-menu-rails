<div class="row">
  <div class="col-6">
    <h4>Profit Margin Analysis</h4>
  </div>
  <div class="col-6 text-end">
    <%= link_to 'View Detailed Report', restaurant_profit_margins_report_path(@restaurant), class: 'btn btn-primary' %>
  </div>
</div>

<% menuitems = @restaurant.menus.flat_map { |m| m.menusections.flat_map(&:menuitems) }.select(&:has_cost_data?) %>

<div class="row mt-3">
  <div class="col-md-3">
    <div class="card">
      <div class="card-body">
        <h6 class="card-subtitle mb-2 text-muted">Items with Cost Data</h6>
        <h3><%= menuitems.count %></h3>
      </div>
    </div>
  </div>
  <div class="col-md-3">
    <div class="card">
      <div class="card-body">
        <h6 class="card-subtitle mb-2 text-muted">Avg Margin %</h6>
        <h3>
          <% avg = menuitems.map(&:profit_margin_percentage).compact.sum / [menuitems.count, 1].max %>
          <%= number_to_percentage(avg, precision: 1) %>
        </h3>
      <      <      <     </div>
  <div class="col-md-3">
    <div class="card border-success">
      <div class      <div class      <div class  ard-subtitle mb-2 text-muted">Above Target</h6>
        <h3 class="text-success">
          <%= menuitems.count { |mi| mi.margin_status == 'above_target' } %>
        </h3>
      </div>
    </div>
  </div>
  <div class="col-md-3">
    <div class="card border-danger">
      <div class="card-body">
        <h6 class="card-subtitle mb-2 text-muted">Critical</h6>
        <h3 class="text-danger">
          <%= menuitems.count { |mi| mi.margin_status == 'critical' } %>
        </h3>
      </div>
    </div>
  </div>
</div>

<div class="table-responsive mt-4">
  <table class="table table-hover">
    <thead>
      <tr>
        <th>Menu Item</th>
        <th>Price</th>
        <th>Total Cost</th>
        <th>Margin $</th>
        <th>Margin %</th>
        <th>Status</th>
      </tr>
    </thead>
    <tbody>
      <% menuitems.sort_by(&:profit_margin_percentage).reverse.first(20).each do |menuitem| %>
        <tr>
          <td><%= menuitem.localised_name('en') %></td>
          <td><%= number_to_currency(menuitem.price) %></td>
          <td><%= number_to_currency(menuitem.current_cost.total_cost) %></td>
          <td><%= number_to_currency(menuitem.profit_margin) %></td>
          <td><%= number_to_percentage(menuitem.profit_margin_percentage, precision: 1) %></td>
          <td>
            <% case menuitem.margin_status %>
            <% when 'above_target' %>
              <span class="badge bg-success">Above Target</span>
            <% when 'below_target' %>
              <span class="badge bg-warning text-dark">Below Target</span>
            <% when 'critical' %>
              <span class="badge bg-danger">Critical</span>
            <% else %>
              <span class="badge bg-secondary">No Target</span>
            <% end %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
