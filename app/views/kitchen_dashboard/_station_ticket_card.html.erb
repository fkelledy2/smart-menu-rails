<% order = ticket.ordr %>
<div class="card mb-2 order-card shadow-sm" draggable="true" data-ticket-id="<%= ticket.id %>" data-order-id="<%= order.id %>" data-status="<%= ticket.status %>" data-created-at="<%= order.created_at.to_i %>">
  <div class="card-header py-2 d-flex justify-content-between align-items-center <%= ticket.status == 'ordered' ? 'bg-danger-subtle' : ticket.status == 'preparing' ? 'bg-warning-subtle' : 'bg-success-subtle' %>">
    <div>
      <strong class="fs-5"><%= t('kitchen_dashboard.station_ticket_card.order_number', id: order.id) %></strong>
      <% if order.tablesetting.present? %>
        <span class="badge text-bg-secondary ms-2">
          <%= order.tablesetting.name %>
        </span>
      <% end %>
      <% if order.kitchen_notes.any? %>
        <span class="badge text-bg-warning ms-2" title="<%= t('kitchen_dashboard.station_ticket_card.kitchen_notes_count', count: order.kitchen_notes.count) %>">
          <i class="bi bi-exclamation-triangle"></i> <%= order.kitchen_notes.count %>
        </span>
      <% end %>
    </div>
    <small class="text-muted">
      <i class="bi bi-clock"></i> <%= t('kitchen_dashboard.station_ticket_card.time_ago', time: time_ago_in_words(order.created_at)) %>
    </small>
  </div>

  <div class="card-body py-2">
    <%# Display order-level kitchen notes at the top %>
    <% if order.kitchen_notes.any? %>
      <% order.kitchen_notes.each do |note| %>
        <div class="order-note">
          <i class="bi bi-exclamation-triangle order-note-icon"></i>
          <span class="order-note-text"><%= note.note %></span>
        </div>
      <% end %>
    <% end %>

    <%
      # Calculate prep times and start delays
      items_with_prep = ticket.ordritems.select { |i| i.menuitem.present? }.map do |item|
        prep_time = item.menuitem.preptime || 0
        prep_time = 5 if prep_time == 0 # Default to 5 minutes
        { item: item, prep_time: prep_time }
      end
      
      max_prep_time = items_with_prep.map { |i| i[:prep_time] }.max || 5
      order_age_minutes = ((Time.current - order.created_at) / 60).to_i
      
      items_with_timing = items_with_prep.map do |item_data|
        start_delay = max_prep_time - item_data[:prep_time]
        time_until_start = start_delay - order_age_minutes
        start_delay_percent = max_prep_time > 0 ? (start_delay.to_f / max_prep_time * 100) : 0
        prep_duration_percent = max_prep_time > 0 ? (item_data[:prep_time].to_f / max_prep_time * 100) : 100
        
        item_data.merge({
          start_delay: start_delay,
          time_until_start: time_until_start,
          start_delay_percent: start_delay_percent,
          prep_duration_percent: prep_duration_percent,
          should_flash: time_until_start <= 0 && ticket.status == 'ordered'
        })
      end.sort_by { |item| -item[:prep_time] } # Sort by prep time descending (longest first)
    %>

    <%# Order Timeline Summary %>
    <% if max_prep_time > 0 %>
      <div class="order-timeline-summary mb-2">
        <small class="text-muted">
          <i class="bi bi-clock-history"></i>
          <%= t('kitchen_dashboard.station_ticket_card.total_prep_time') %> <strong><%= max_prep_time %> min</strong>
          <span class="ms-2 text-muted">|</span>
          <span class="ms-2"><%= t('kitchen_dashboard.station_ticket_card.order_age') %> <strong><%= order_age_minutes %> min</strong></span>
        </small>
      </div>
    <% end %>

    <ul class="mb-0 order-items-timeline">
      <% items_with_timing.each do |item_data| %>
        <% item = item_data[:item] %>
        <li class="order-item-with-timeline <%= 'timeline-item-flash' if item_data[:should_flash] %>" 
            data-prep-time="<%= item_data[:prep_time] %>" 
            data-start-delay="<%= item_data[:start_delay] %>">
          
          <%# Timeline Progress Bar - color matches column status %>
<%
  bar_class = case ticket.status
  when 'ordered'
    'timeline-bar--pending'
  when 'preparing'
    'timeline-bar--preparing'
  when 'ready'
    'timeline-bar--ready'
  else
    'timeline-bar--pending'
  end
  
  # Ready items show 100% full bar
  # Preparing items scale to full width based on max prep time
  if ticket.status == 'ready'
    display_width = 100
  elsif ticket.status == 'preparing'
    display_width = (item_data[:prep_time].to_f / max_prep_time * 100)
  else
    display_width = item_data[:prep_duration_percent]
  end
%>

<%# Progress bar as background %>
<div class="timeline-progress" style="--prep-width: <%= display_width %>%;">
  <div class="timeline-bar <%= bar_class %>">
    <span class="prep-time-label"><%= item_data[:prep_time] %>m</span>
  </div>
</div>

<%# Item Content with inline notes on top of progress bar %>
<div class="item-content" data-ordritem-id="<%= item.id %>">
  <div class="item-main">
    <% if item.quantity > 1 %><span class="badge text-bg-primary me-1"><%= item.quantity %>×</span><% end %>
    <span class="item-name"><%= item.menuitem.name %></span>
    <% if item.size_name.present? %>
      <span class="text-muted small">(<%= item.size_name.sub(/\s*\(.*\)/, '') %>)</span>
    <% end %>
    <%# Display item-level notes inline %>
    <% if item.ordritemnotes.any? %>
      <span class="item-note-inline">(<%= item.ordritemnotes.map(&:note).join(', ') %>)</span>
    <% end %>
    <% if Flipper.enabled?(:ordritem_realtime_tracking) %>
      <span class="badge ms-2 ordritem-status-badge ordritem-status-badge--<%= item.fulfillment_status %>"
            data-ordritem-status-badge
            data-status="<%= item.fulfillment_status %>">
        <%= item.fulfillment_status.capitalize %>
      </span>
    <% end %>
  </div>
</div>

<%# Time indicators for non-ready items (except START NOW which is now just an icon) %>
<% unless ticket.status == 'ready' %>
  <% if ticket.status != 'preparing' || item_data[:time_until_start] > 0 %>
    <div class="prep-time-text">
      <% if item_data[:time_until_start] <= 5 %>
        <i class="bi bi-hourglass-split text-warning"></i>
        <small class="text-warning"><%= t('kitchen_dashboard.station_ticket_card.start_in_min', minutes: item_data[:time_until_start]) %></small>
      <% elsif item_data[:time_until_start] > 5 %>
        <i class="bi bi-hourglass text-muted"></i>
        <small class="text-muted"><%= t('kitchen_dashboard.station_ticket_card.start_in_min', minutes: item_data[:time_until_start]) %></small>
      <% end %>
    </div>
  <% end %>
<% end %>
        </li>
      <% end %>
    </ul>
  </div>

  <div class="card-footer py-2 bg-white border-top">
    <% if ticket.status == 'ordered' %>
      <button class="btn btn-warning w-100 ticket-status-btn" data-ticket-id="<%= ticket.id %>" data-new-status="preparing">
        <%= t('kitchen_dashboard.station_ticket_card.start_preparing') %>
      </button>
    <% elsif ticket.status == 'preparing' %>
      <button class="btn btn-success w-100 ticket-status-btn" data-ticket-id="<%= ticket.id %>" data-new-status="ready">
        <%= t('kitchen_dashboard.station_ticket_card.mark_ready') %>
      </button>
    <% elsif ticket.status == 'ready' %>
      <button class="btn btn-primary w-100 ticket-status-btn" data-ticket-id="<%= ticket.id %>" data-new-status="collected">
        <%= t('kitchen_dashboard.station_ticket_card.mark_as_collected') %>
      </button>
    <% end %>

    <% if Flipper.enabled?(:ordritem_realtime_tracking) %>
      <%# Per-item fulfillment override (secondary/expandable) %>
      <details class="mt-2">
        <summary class="small text-muted" style="cursor:pointer;">
          <i class="bi bi-sliders2"></i> <%= t('kitchen_dashboard.station_ticket_card.item_fulfillment_overrides') %>
        </summary>
        <div class="mt-2">
          <% ticket.ordritems.each do |item| %>
            <% next unless item.menuitem %>
            <div class="d-flex align-items-center justify-content-between py-1 border-bottom"
                 data-ordritem-id="<%= item.id %>">
              <small class="text-truncate me-2">
                <% if item.quantity > 1 %><span class="badge text-bg-secondary me-1"><%= item.quantity %>x</span><% end %>
                <%= item.menuitem.name %>
              </small>
              <div class="d-flex align-items-center gap-1">
                <span class="badge ordritem-status-badge ordritem-status-badge--<%= item.fulfillment_status %>"
                      data-ordritem-status-badge
                      data-status="<%= item.fulfillment_status %>">
                  <%= item.fulfillment_status.capitalize %>
                </span>
                <% next_status = { 'pending' => 'preparing', 'preparing' => 'ready', 'ready' => 'collected' }[item.fulfillment_status] %>
                <% if next_status %>
                  <button type="button"
                          class="btn btn-outline-secondary btn-sm item-fulfillment-advance-btn"
                          data-ordr-id="<%= order.id %>"
                          data-ordritem-id="<%= item.id %>"
                          data-from-status="<%= item.fulfillment_status %>"
                          data-to-status="<%= next_status %>"
                          title="<%= t('kitchen_dashboard.station_ticket_card.advance_to_status', status: next_status) %>">
                    <i class="bi bi-arrow-right-circle"></i>
                  </button>
                <% end %>
              </div>
            </div>
          <% end %>
        </div>
      </details>
    <% end %>
  </div>
</div>
