<div class="page-header">
  <div class="row">
    <div class="col-6">
      <h4>Profit Margin Dashboard - <%= @restaurant.name %></h4>
    </div>
    <div class="col-6 text-end">
      <%= link_to 'Detailed Report', restaurant_profit_margins_report_path(@restaurant), class: 'btn btn-primary' %>
      <%= link_to 'Order Analytics', restaurant_profit_margins_order_analytics_path(@restaurant), class: 'btn btn-outline-primary' %>
    </div>
  </div>
</div>

<div class="row mb-4">
  <div class="col-md-3">
    <div class="card">
      <div class="card-body text-center">
        <h6 class="text-muted">Total Items</h6>
        <h2><%= @stats[:total_items] %></h2>
        <small class="text-muted">with cost data</small>
      </div>
    </div>
  </div>
  <div class="col-md-3">
    <div class="card">
      <div class="card-body text-center">
        <h6 class="text-muted">Avg Margin</h6>
        <h2><%= number_to_percentage(@stats[:average_margin_percentage], precision: 1) %></h2>
        <small class="text-muted">across all items</small>
      </div>
    </div>
  </div>
  <div class="col-md-3">
    <div class="card">
      <div class="card-body text-center">
        <h6 class="text-muted">Potential Profit</h6>
        <h2><%= number_to_currency(@stats[:total_potential_profit]) %></h2>
        <small class="text-muted">per item sold</small>
      </div>
    </div>
  </div>
  <div class="col-md-3">
    <div class="card">
      <div class="card-body text-center">
        <h6 class="text-muted">Target Status</h6>
        <div class="d-flex justify-content-around mt-2">
          <div>
            <div class="text-success fw-bold"><%= @stats[:above_target_count] %></div>
                                                              </div>
          <div>
            <div class="text-warning fw-bold"><%= @stats[:below_target_count] %></div>
            <small class="text-muted">Below</small>
          </div>
          <div>
            <div class="text-danger fw-bold"><%= @stats[:critical_count] %></div>
            <small class="text-muted">Critical</small>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<div class="row mb-4">
  <div class="col-12">
    <div class="card">
      <div class="card-header">
        <h5>Margin Trend (Last 30 Days)</h5>
      </div>
      <div class="card-body">
        <canvas id="marginTrendChart" height="80"></canvas>
      </div>
    </div>
  </div>
</div>

<div class="row mb-4">
  <div class="col-md-6">
    <div class="card">
      <div class="card-header">
        <h5>Category Breakdown</h5>
      </div>
      <div class="card-body">
        <canvas id="categoryChart" height="200"></canvas>
      </div>
    </div>
  </div>
  <div class="col-md-6">
    <div class="card">
      <div class="card-header">
        <h5>Margin Distribution</h5>
      </div>
      <div class="card-body">
        <div class="table-responsive">
          <table class="table table-sm">
            <tbody>
              <tr>
                <td><span class="badge bg-success">Above Target</span></td>
                <td class="text-end"><%= @stats[:above_target_count] %> items</td>
                <td class="text-end"><%= number_to_percentage((@stats[:above_target_count].to_f / @stats[:total_items] * 100), precision: 0) if @stats[:total_items] > 0 %></td>
              </tr>
              <tr>
                <td><span class="badge bg-warning text-dark">Below Target</span></td>
                <td class="text-end"><%= @stats[:below_target_count] %> items</td>
                <td class="text-end"><%= number_to_percentage((@stats[:below_target_count].to_f / @stats[:total_items] * 100), precision: 0) if @stats[:total_items] > 0 %></td>
              </tr>
              <tr>
                <td><span class="badge bg-danger">Critical</span></td>
                <td class="text-end"><%= @stats[:critical_count] %> items</td>
                <td class="text-end"><%= number_to_percentage((@stats[:critical_count].to_f / @stats[:total_items] * 100), precision: 0) if @stats[:total_items] > 0 %></td>
                <td class="text-end"><%= @stats[:no_target_count] %> items</td>
                <td class="text-end"><%= number_to_percentage((@stats[:no_target_count].to_f / @stats[:total_items] * 100), precision: 0) if @stats[:total_items] > 0 %></td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>
</div>

