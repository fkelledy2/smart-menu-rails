<div class="page-header">
  <div class="row">
    <div class="col-6">
      <h4>Profit Margin Report - <%= @restaurant.name %></h4>
    </div>
    <div class="col-6 text-end">
      <%= link_to 'Back to Restaurant', edit_restaurant_path(@restaurant), class: 'btn btn-secondary' %>
    </div>
  </div>
</div>

<div class="row mb-4">
  <div class="col-md-3">
    <div class="card">
      <div class="card-body text-center">
        <h6 class="text-muted">Total Items</h6>
        <h2><%= @stats[:total_items] %></h2>
      </div>
    </div>
  </div>
  <div class="col-md-3">
    <div class="card">
      <div class="card-body text-center">
        <h6 class="text-muted">Avg Margin</h6>
        <h2><%= number_to_percentage(@stats[:avg_margin], precision: 1) %></h2>
      </div>
    </div>
  </div>
  <div class="col-md-2">
    <div class="card border-success">
      <div class="card-body text-center">
        <h6 class="text-muted">Above Target</h6>
        <h2 class="text-success"><%= @stats[:above_target] %></h2>
      </div>
    </div>
  </div>
  <div class="col-md-2">
    <div class="card border-warning">
      <div class="card-body text-center">
        <h        <h        <h        <h et</h6>
