<div class="page-header">
  <div class="row">
    <div class="col-6">
      <h4>Profit Margin Report - <%= @restaurant.name %></h4>
    </div>
    <div class="col-6 text-end">
      <%= link_to 'Back to Restaurant', edit_restaurant_path(@restaurant), class: 'btn btn-secondary' %>
    </div>
  </div>
</div>

<div class="row mb-4">
  <div class="col-md-3">
    <div class="card">
      <div class="card-body text-center">
        <h6 class="text-muted">Total Items</h6>
        <h2><%= @stats[:total_items] %></h2>
      </div>
    </div>
  </div>
  <div class="col-md-3">
    <div class="card">
      <div class="card-body text-center">
        <h6 class="text-muted">Avg Margin</h6>
        <h2><%= number_to_percentage(@stats[:average_margin_percentage], precision: 1) %></h2>
      </div>
    </div>
  </div>
  <div class="col-md-2">
    <div class="card border-success">
      <div class="card-body text-center">
        <h6 class="text-muted">Above Target</h6>
        <h2 class="text-success"><%= @stats[:above_target_count] %></h2>
      </div>
    </div>
  </di  </di  </di  </di  </d-  </di  </di  </di  </di  </d-  </di  </di  </di  </di  </d-ca  </di  <ext-center">
        <h6 class="text-muted">Below Target</h6>
        <h2 class="text-warning"><%= @stats[:below_target_count] %></h2>
      </div>
    </div>
  </div>
  <div class="col-md-2">
    <div class="card border-danger">
      <div class="card-body text-center">
        <h6 class="text-muted">Critical</h6>
        <h2 class="text-danger"><%= @stats[:critical_count] %></h2>
      </div>
    </div>
  </div>
</div>

<div class="card">
  <div class="card-header">
    <h5>Detailed Cost Breakdown</h5>
  </div>
  <div class="card-body">
    <div class="table-responsive">
      <table class="table table-hover">
        <thead>
          <tr>
            <th>Category</th>
            <th>Item</th>
            <th>Price</th>
            <th>Ingredient</th>
            <th>Labor</th>
            <th>Packaging</th>
            <th>Overhead</th>
            <th>Total Cost</th>
            <th>Margin $</th>
            <th>Margin %</th>
            <th>Status</th>
          </tr>
        </thead>
        <tbody>
          <% @menuitems.each do |menuitem| %>
            <% cost = menuitem.current_cost %>
            <% next unless cost %>
            <tr>
              <td><%= menuitem.menusection.name %></td>
              <td><%= menuitem.localised_name('en') %></td>
              <td><%= number_to_currency(menuitem.price) %></td>
              <td><%= number_to_currency(cost.ingredient_cost) %></td>
              <td><%= number_to_currency(cost.labor_cost) %></td>
              <td><%= number_to_currency(cost.packaging_cost) %></td>
              <td><%= number_to_currency(cost.overhead_cost) %></td>
              <td><%= number_to_currency(cost.total_cost) %></td>
              <td><%= number_to_currency(menuitem.profit_margin) %></td>
              <td><%= number_to_percentage(menuitem.profit_margin_percentage, precision: 1) %></td>
              <td>
                <% case menuitem.margin_status %>
                <% when 'above_target' %>
                  <span class="badge bg-success">Above Target</span>
                <% when 'below_target' %>
                  <span class="badge bg-warning">Below Target</span>
                <% when 'critical' %>
                  <span class="badge bg-danger">Critical</span>
                <% else %>
                  <span class="badge bg-secondary">No Target</span>
                <% end %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
</div>
